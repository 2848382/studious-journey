<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>ShelterProtocol</title>
<link rel="manifest" href="manifest.json">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="Protocol">
<meta name="theme-color" content="#111113">
<link rel="apple-touch-icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 192 192'%3E%3Crect width='192' height='192' fill='%23111113'/%3E%3Ctext x='96' y='120' font-size='96' text-anchor='middle' font-family='monospace' fill='%23dc2626'%3E⚠%3C/text%3E%3C/svg%3E">
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;700;900&family=IBM+Plex+Mono:wght@400;500;600&family=Orbitron:wght@700;900&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#111113;--bg2:#18181b;--bg3:#1f1f23;--bgi:#0d0d0f;--bd:#27272a;--bd2:#303035;
  --tx:#d4d4d8;--txd:#71717a;--txf:#52525b;--w:#fafafa;
  --ac:#b91c1c;--acl:#dc2626;--acbg:rgba(185,28,28,.06);
  --grn:#22c55e;--blu:#3b82f6;--ylw:#eab308;--pur:#a855f7;--org:#f97316;
  --f:'Noto Sans KR',sans-serif;--m:'IBM Plex Mono',monospace;--o:'Orbitron',sans-serif;
  --ls:-.02em;--lsm:.06em
}
*{margin:0;padding:0;box-sizing:border-box}
body{background:var(--bg);color:var(--tx);font-family:var(--f);font-size:14px;line-height:1.65;min-height:100vh;-webkit-tap-highlight-color:transparent;letter-spacing:var(--ls);word-break:keep-all}
input,select,textarea,button{font-family:var(--f);letter-spacing:var(--ls)}
::-webkit-scrollbar{width:3px}::-webkit-scrollbar-track{background:var(--bg)}::-webkit-scrollbar-thumb{background:var(--bd2)}
button{cursor:pointer;font-family:var(--f)}a{color:var(--acl);text-decoration:none}

  #first-tos-overlay {
  position: fixed; top: 0; left: 0; width: 100%; height: 100%;
  background: #0a0a0c; z-index: 999999;
  display: none; flex-direction: column; justify-content: center; align-items: center;
  padding: 20px; box-sizing: border-box; color: #ddd;
}
.first-tos-box { background: #1a1a1c; border: 1px solid #dc2626; border-radius: 8px; width: 100%; max-width: 400px; padding: 20px; box-shadow: 0 0 20px rgba(220,38,38,0.2); }
.first-tos-content { height: 250px; overflow-y: auto; background: #000; border: 1px solid #333; padding: 15px; font-size: 0.9em; margin-bottom: 20px; color: #aaa; line-height: 1.5; }
.first-tos-content::-webkit-scrollbar { width: 4px; }
.first-tos-content::-webkit-scrollbar-thumb { background: #dc2626; }
.first-tos-label { display: flex; align-items: center; gap: 10px; margin-bottom: 20px; cursor: pointer; font-size: 1.05em; font-weight: bold; color: #fff; }
.first-tos-btns { display: flex; gap: 10px; }
.first-tos-btns button { flex: 1; padding: 14px; border: none; border-radius: 4px; font-weight: bold; cursor: pointer; font-size: 1em; }
.btn-tos-yes { background: #dc2626; color: white; }
.btn-tos-no { background: #333; color: #aaa; }
  
/* AUTH */
#auth{position:fixed;top:0;left:0;width:100%;height:100%;background:#000;z-index:9000;display:flex;align-items:center;justify-content:center;transition:opacity .8s}
#auth.done{opacity:0;pointer-events:none}
.auth-box{width:min(520px,92vw);background:rgba(0,15,0,.3);border:1px solid rgba(0,255,65,.15);padding:24px;position:relative}
.auth-box::before{content:'RED AEGIS :: TERMINAL v4.2';position:absolute;top:-9px;left:16px;font-family:var(--m);font-size:9px;color:rgba(0,255,65,.4);background:#000;padding:1px 8px}
#auth-lines{font-family:var(--m);font-size:12px;color:#00ff41;line-height:1.9}
.auth-bar{margin-top:14px;height:2px;background:rgba(0,255,65,.1);overflow:hidden}
.auth-bar-fill{height:100%;width:0;background:#00ff41;transition:width .3s}
#auth-ok{font-family:var(--o);font-size:20px;color:#00ff41;text-align:center;margin-top:12px;opacity:0;transition:opacity .4s}
#auth-ok.show{opacity:1}
.auth-skip{position:absolute;bottom:10px;right:14px;font-family:var(--m);font-size:9px;color:rgba(0,255,65,.3);background:none;border:none}

/* LOGIN */
#login-screen{position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.95);z-index:8000;display:none;align-items:center;justify-content:center}
#login-screen.show{display:flex}
.login-box{width:min(360px,90vw);background:var(--bg2);border:1px solid var(--bd);padding:22px}

/* TOPBAR */
.topbar{display:flex;align-items:center;justify-content:space-between;height:44px;padding:0 12px;border-bottom:1px solid var(--bd);position:sticky;top:0;z-index:100;background:var(--bg)}
.topbar-l{display:flex;align-items:center;gap:6px}
.topbar-dot{width:6px;height:6px;border-radius:50%;background:var(--ac);animation:p 2s infinite;cursor:pointer}
@keyframes p{0%,100%{opacity:1}50%{opacity:.3}}
.topbar-t{font-weight:700;font-size:13px;color:var(--w)}
.topbar-r{display:flex;align-items:center;gap:6px;font-family:var(--m);font-size:10px;color:var(--txf)}
.topbar-r button{background:none;border:1px solid var(--bd);color:var(--txd);padding:2px 6px;font-family:var(--m);font-size:10px}
.dday{color:var(--acl);font-weight:600}

/* TABS */
.tabs{display:flex;border-bottom:1px solid var(--bd);background:var(--bg);position:sticky;top:44px;z-index:99;overflow-x:auto;-webkit-overflow-scrolling:touch;scrollbar-width:none}
.tabs::-webkit-scrollbar{display:none}
.tab{padding:9px 12px;font-size:11px;font-weight:500;color:var(--txf);cursor:pointer;border-bottom:2px solid transparent;white-space:nowrap;flex-shrink:0;transition:color .15s;letter-spacing:.01em}
.tab:hover{color:var(--txd)}
.tab.on{color:var(--w);border-bottom-color:var(--acl)}

/* PAGES */
.pg{display:none;max-width:1100px;margin:0 auto;padding:14px}.pg.on{display:block}
.sl{font-family:var(--m);font-size:8px;color:var(--txf);letter-spacing:.1em;text-transform:uppercase;margin-bottom:5px;opacity:.8}
.st{font-size:17px;font-weight:700;color:var(--w);margin-bottom:16px;letter-spacing:-.02em;line-height:1.25}.st .d{color:var(--acl)}
.card{background:var(--bg2);border:1px solid var(--bd);padding:12px;margin-bottom:8px;transition:border-color .15s}
.card:hover{border-color:var(--bd2)}
.clbl{font-family:var(--m);font-size:9px;color:var(--ylw);margin-bottom:3px;text-transform:uppercase}
.ctit{font-size:13px;font-weight:700;color:var(--w);margin-bottom:4px}
.ctx{font-size:12px;color:var(--txd);line-height:1.8}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.g5{display:grid;grid-template-columns:repeat(5,1fr);gap:6px}
.btn{padding:7px 16px;background:none;border:1px solid var(--bd2);color:var(--tx);font-size:11px;font-weight:500;transition:all .15s;letter-spacing:.01em}
.btn:hover{border-color:var(--acl);color:var(--acl);background:var(--acbg)}
.btn-o{padding:7px 14px;background:none;border:1px solid var(--bd);color:var(--txd);font-size:11px;transition:all .15s}
.btn-o:hover{border-color:var(--bd2);color:var(--tx)}
.fg{margin-bottom:8px;position:relative}.fl{display:block;font-size:9px;font-weight:500;color:var(--txf);margin-bottom:2px;letter-spacing:.04em;text-transform:uppercase}
.fi,.fsl{width:100%;background:var(--bgi);border:1px solid var(--bd);color:var(--tx);padding:7px 10px;font-family:var(--f);font-size:13px;outline:none;border-radius:0}
.fsl{cursor:pointer;appearance:none}
.fta{width:100%;background:var(--bgi);border:1px solid var(--bd);color:var(--tx);padding:7px 10px;font-family:var(--f);font-size:13px;outline:none;min-height:70px;resize:vertical}
.fr{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.tl{display:flex;gap:10px;padding:7px 0;border-bottom:1px solid rgba(255,255,255,.03);font-size:12px}
.tl-d{font-family:var(--m);font-size:10px;color:var(--ylw);min-width:46px}
.zc{background:var(--bg2);border:1px solid var(--bd);padding:8px;text-align:center;position:relative;overflow:hidden}
.zc::after{content:'';position:absolute;bottom:0;left:0;width:100%;height:2px}
.z1::after{background:var(--grn)}.z2::after{background:var(--ylw)}.z3::after{background:var(--org)}.z4::after{background:var(--ac)}.z5::after{background:var(--pur)}
.zcd{font-family:var(--m);font-size:8px}.z1 .zcd{color:var(--grn)}.z2 .zcd{color:var(--ylw)}.z3 .zcd{color:var(--org)}.z4 .zcd{color:var(--ac)}.z5 .zcd{color:var(--pur)}
.zcn{font-weight:700;font-size:11px;color:var(--w)}.zcr{font-size:8px;color:var(--txd)}
.ftbl{width:100%;border-collapse:collapse;font-size:11px}
.ftbl th{font-family:var(--m);font-size:9px;color:var(--ylw);text-align:left;padding:5px 6px;border-bottom:1px solid var(--bd)}
.ftbl td{padding:5px 6px;border-bottom:1px solid rgba(255,255,255,.03)}
.fv{font-family:var(--m);color:var(--grn)}
.fb{font-family:var(--m);font-size:8px;padding:1px 3px;border-radius:2px}
.fbr{color:#f87171;background:rgba(185,28,28,.1)}.fbp{color:#c084fc;background:rgba(139,0,255,.1)}

/* INFECTION VIZ */
.infection-viz{position:relative;height:220px;background:var(--bgi);border:1px solid var(--bd);overflow:hidden;margin:10px 0}
.inf-cell{position:absolute;width:7px;height:7px;border-radius:50%;transition:all 1s}
.inf-cell.healthy{background:var(--grn);box-shadow:0 0 3px var(--grn)}
.inf-cell.infected{background:var(--ac);box-shadow:0 0 5px var(--acl)}
.inf-cell.mutant{background:var(--pur);box-shadow:0 0 6px var(--pur)}
.inf-cell.dead{background:var(--txf);box-shadow:none;opacity:.3}
.inf-legend{display:flex;gap:10px;justify-content:center;margin-top:6px;font-size:10px;color:var(--txd)}
.inf-legend span::before{content:'';display:inline-block;width:7px;height:7px;border-radius:50%;margin-right:3px;vertical-align:middle}
.inf-l-h::before{background:var(--grn)}.inf-l-i::before{background:var(--ac)}.inf-l-m::before{background:var(--pur)}.inf-l-d::before{background:var(--txf)}

/* MAP */
.map-wrap{background:var(--bgi);border:1px solid var(--bd);overflow:hidden}
.map-header{display:flex;justify-content:space-between;align-items:center;padding:6px 10px;border-bottom:1px solid var(--bd);background:rgba(0,0,0,.3)}
.map-header-label{font-family:var(--m);font-size:8px;color:var(--txf);letter-spacing:.06em}
.map-header-status{font-family:var(--m);font-size:8px;color:var(--grn);animation:p 2s infinite}
.map-body{display:flex;align-items:stretch}
.map-body svg{flex:1;min-width:0;max-width:100%}
.map-legend{width:90px;min-width:90px;flex-shrink:0;border-left:1px solid var(--bd);padding:10px 8px;display:flex;flex-direction:column;gap:3px;background:rgba(0,0,0,.25);overflow:hidden}
.map-leg-title{font-family:var(--m);font-size:7px;color:var(--txf);letter-spacing:.05em;margin-bottom:2px;white-space:nowrap}
.map-leg-item{display:flex;align-items:center;gap:4px;font-family:var(--m);font-size:8px;color:var(--txd);white-space:nowrap}
.map-leg-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0}
.map-leg-divider{height:1px;background:var(--bd);margin:3px 0}
.blink-dot{animation:p 1s infinite}
.map-city circle{transition:r .2s}
.map-city:hover circle:first-child{filter:brightness(1.3)}
.map-info{background:var(--bg2);border:1px solid var(--bd);border-top:1px solid var(--bd2);padding:14px;margin-top:0;display:none}
.map-info.show{display:block;animation:fu .3s}
@keyframes fu{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}
@media(max-width:480px){
  .map-body{flex-direction:column}
  .map-legend{width:100%;min-width:0;border-left:none;border-top:1px solid var(--bd);flex-direction:row;flex-wrap:wrap;gap:6px 12px;padding:8px 10px}
  .map-leg-divider{display:none}
  .map-leg-title{width:100%;margin-bottom:0}
}

/* BOARD */
.blay{display:flex;flex-direction:row;gap:0;border:1px solid var(--bd);min-height:400px;align-items:stretch;border-radius:4px;overflow:hidden;width:100%}
.bside{width:0;flex-shrink:0;border-right:none;padding:0;background:var(--bg2);display:none}
.bsi{display:block;width:100%;padding:8px 14px;font-size:11px;color:var(--txd);cursor:pointer;position:relative;letter-spacing:-.01em;transition:background .1s;box-sizing:border-box}
.bsi:hover{color:var(--tx);background:var(--bg3)}
.bsi.on{color:var(--w);background:var(--acbg)}
.bsi.on::before{content:'';position:absolute;left:0;top:50%;transform:translateY(-50%);width:3px;height:16px;background:var(--ac);border-radius:0 2px 2px 0}
.bsic{float:right;font-family:var(--m);font-size:8px;color:var(--txf);margin-top:1px}
.bmain{flex:1;min-width:0;padding:14px 16px 12px;display:flex;flex-direction:column}
.ptbl-wrap{flex:1;display:flex;flex-direction:column;width:100%}
.ptbl-head{display:flex;align-items:center;padding:7px 10px;border-bottom:1px solid var(--bd);font-family:var(--m);font-size:9px;color:var(--txf);letter-spacing:-.02em;gap:8px;margin-bottom:2px}
.ptbl-head .hm{text-align:right}
.ptr{display:flex;align-items:center;padding:11px 10px;border-bottom:1px solid rgba(255,255,255,.04);cursor:pointer;gap:8px;transition:background .12s;width:100%;box-sizing:border-box}
.ptr:hover{background:rgba(255,255,255,.03)}.ptr.cen{opacity:.3;text-decoration:line-through;pointer-events:none}
.ptr-num{font-family:var(--m);font-size:9px;color:var(--txf);width:28px;text-align:center;flex-shrink:0}
.ptr-cat{width:48px;flex-shrink:0}
.ptr-title{flex:1;min-width:0;overflow:hidden}
.ptr-auth{width:70px;font-size:10px;color:var(--txd);text-align:right;flex-shrink:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.ptr-auth.adm{color:var(--acl)}
.pb{font-size:9px;font-weight:600;padding:2px 5px;border-radius:3px;letter-spacing:-.02em;white-space:nowrap}
.pbn{background:rgba(185,28,28,.12);color:#f87171}.pbr{background:rgba(59,130,246,.1);color:#60a5fa}.pbs{background:rgba(34,197,94,.1);color:#4ade80}.pbsg{background:rgba(251,191,36,.1);color:#fbbf24}.pbm{background:rgba(168,85,247,.1);color:#c084fc}.pbg{background:rgba(255,255,255,.05);color:var(--txd)}.pbl{background:rgba(185,28,28,.06);color:var(--acl)}
.ptt{font-size:13px;color:var(--tx);letter-spacing:-.02em;line-height:1.4}.ptt.pin{color:var(--w);font-weight:600}
.ppin{font-family:var(--m);font-size:8px;color:var(--acl);margin-right:3px}
.pa{font-size:10px;color:var(--txd);width:52px;letter-spacing:-.02em}.pa.adm{color:var(--acl)}
/* NEW: realtime indicator */
.board-live{display:flex;align-items:center;gap:4px;font-family:var(--m);font-size:8px;color:var(--grn)}
.board-live-dot{width:5px;height:5px;border-radius:50%;background:var(--grn);animation:p 1s infinite}
.board-new-flash{animation:newRow .8s ease-out}
@keyframes newRow{0%{background:rgba(34,197,94,.15)}100%{background:transparent}}

/* MODAL */
.mo{display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.8);z-index:200;align-items:center;justify-content:center;backdrop-filter:blur(4px)}
.mo.open{display:flex}
.mob{background:var(--bg2);border:1px solid var(--bd2);width:min(620px,96vw);max-height:92vh;overflow-y:auto;position:relative;border-radius:2px;box-shadow:0 20px 60px rgba(0,0,0,.7)}
.mox{position:absolute;top:10px;right:10px;background:rgba(255,255,255,.07);border:1px solid var(--bd);color:var(--txd);width:28px;height:28px;display:flex;align-items:center;justify-content:center;font-size:13px;z-index:5;border-radius:2px;transition:background .15s}
.mox:hover{background:rgba(255,255,255,.12)}
.moh{padding:18px 20px 12px;border-bottom:1px solid var(--bd)}
.mot{font-size:16px;font-weight:700;color:var(--w);margin-bottom:5px;line-height:1.4;letter-spacing:-.02em;padding-right:30px}
.mom{font-size:11px;color:var(--txf);font-family:var(--m);display:flex;gap:10px}
.mbd{padding:16px 20px;font-size:14px;color:var(--tx);line-height:1.9;white-space:pre-line;letter-spacing:-.01em}
.mcm{border-top:1px solid var(--bd);padding:12px 20px}
.cmt{padding:8px 0;border-bottom:1px solid rgba(255,255,255,.04)}
.cmt-author{font-size:11px;font-weight:600;color:var(--acl);margin-bottom:3px;font-family:var(--m)}
.cmt-body{font-size:13px;color:var(--tx);line-height:1.6}
.cmtw{display:flex;gap:6px;margin-top:10px}
.cmti{flex:1;background:var(--bgi);border:1px solid var(--bd);color:var(--tx);padding:8px 10px;font-family:var(--f);font-size:13px;outline:none;border-radius:2px}
.cmti:focus{border-color:var(--bd2)}
.wf{padding:16px 20px}

/* DICE */
.dice-a{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.dp{background:var(--bg2);border:1px solid var(--bd);padding:14px}
.dpt{font-size:13px;font-weight:700;color:var(--w);margin-bottom:2px}
.dps{font-size:10px;color:var(--txd);margin-bottom:8px}
.dsel{display:flex;gap:4px;flex-wrap:wrap;margin-bottom:8px}
.dbtn{padding:5px 9px;font-family:var(--m);font-size:10px;border:1px solid var(--bd);background:none;color:var(--txd)}
.dbtn.on{border-color:var(--ac);background:var(--acbg);color:var(--acl)}
.dr{text-align:center;padding:14px;background:var(--bgi);border:1px solid var(--bd);margin-bottom:8px;min-height:60px;display:flex;flex-direction:column;align-items:center;justify-content:center}
.dn{font-family:var(--o);font-size:36px;font-weight:900;color:var(--w)}
.dn.roll{animation:droll .5s}
@keyframes droll{0%{transform:scale(.5) rotate(-180deg);opacity:.3}50%{transform:scale(1.2)}100%{transform:scale(1)}}
.dl{font-family:var(--m);font-size:9px;color:var(--txf);margin-top:3px}
.drbtn{width:100%;padding:7px;background:var(--ac);color:#fff;border:none;font-size:12px;font-weight:600}

/* SUPPLY */
.sup-hero{background:var(--bg2);border:1px solid var(--bd);padding:18px 16px;margin-bottom:10px;text-align:center}
.sup-ht{font-family:var(--m);font-size:11px;color:var(--txf);letter-spacing:var(--lsm);margin-bottom:4px}
.sup-hs{font-size:12px;color:var(--txd);letter-spacing:var(--ls);margin-bottom:12px}
.sup-ok{font-family:var(--m);font-size:10px;color:var(--grn);padding:5px 14px;border:1px solid rgba(34,197,94,.3);background:rgba(34,197,94,.05);display:inline-block;letter-spacing:var(--lsm)}
.sup-btn{padding:10px 28px;background:none;border:1px solid var(--bd2);color:var(--tx);font-size:13px;font-weight:500;transition:all .18s;letter-spacing:var(--ls)}
.sup-btn:hover{border-color:var(--acl);color:var(--acl);background:var(--acbg)}
.sup-items{display:grid;grid-template-columns:repeat(auto-fill,minmax(80px,1fr));gap:6px;margin-top:10px}
.sup-item{background:var(--bg2);border:1px solid var(--bd);padding:10px 6px;text-align:center;transition:border-color .15s}
.sup-item:hover{border-color:var(--bd2)}
.kit-show{display:none;margin-top:10px}.kit-show.show{display:block;animation:fu .4s}
.kit-c{background:var(--bg2);border:1px solid rgba(34,197,94,.3);padding:14px;text-align:center}
.kit-i{display:flex;flex-wrap:wrap;gap:5px;justify-content:center;margin-top:8px}
.kit-q{font-family:var(--m);color:var(--ylw);margin-left:3px}

/* QUIZ */
.quiz-q{background:var(--bg2);border:1px solid var(--bd);padding:14px 16px;margin-bottom:8px;transition:border-color .15s}
.quiz-q:hover{border-color:var(--bd2)}
.quiz-q-text{font-size:13px;font-weight:600;color:var(--w);margin-bottom:10px;line-height:1.5;letter-spacing:var(--ls)}
.quiz-opt{display:flex;flex-direction:column;gap:5px}
.quiz-opt label{display:flex;align-items:center;gap:9px;padding:9px 12px;border:1px solid var(--bd);cursor:pointer;font-size:12px;color:var(--tx);transition:all .14s;letter-spacing:var(--ls)}
.quiz-opt label:hover{border-color:var(--bd2);background:rgba(255,255,255,.02)}
.quiz-opt input{accent-color:var(--acl);flex-shrink:0}
.quiz-result{text-align:center;padding:22px;background:var(--bg2);border:1px solid var(--bd);display:none}
.quiz-result.show{display:block;animation:fu .4s}
.quiz-pct{font-family:var(--o);font-size:42px;font-weight:900;margin-bottom:8px;letter-spacing:-.02em}

/* GUIDE */
.guide-section{background:var(--bg2);border:1px solid var(--bd);border-left:2px solid var(--bd2);padding:13px 16px;margin-bottom:7px;display:flex;gap:14px;align-items:flex-start;transition:border-color .15s}
.guide-section:hover{border-left-color:var(--acl)}
.guide-num{font-family:var(--o);font-size:18px;color:var(--acl);font-weight:900;flex-shrink:0;opacity:.7;margin-top:1px}
.guide-content{flex:1;min-width:0}

/* PASS */
.pass-card{background:var(--bg2);border:2px solid var(--bd);padding:18px;max-width:480px;margin:0 auto;position:relative;overflow:hidden}
.pass-card::before{content:'RED AEGIS 구역 통행증';position:absolute;top:0;left:0;right:0;background:var(--ac);color:#fff;text-align:center;font-family:var(--m);font-size:10px;padding:3px;letter-spacing:.1em}
.pass-info{margin-top:26px;display:flex;justify-content:space-between;align-items:center;margin-bottom:12px}
.pass-name{font-size:14px;font-weight:700;color:var(--w)}.pass-tag{font-family:var(--m);font-size:11px;color:var(--acl)}
.pass-zones{display:grid;grid-template-columns:repeat(5,1fr);gap:6px;margin:12px 0}
.pass-zone{background:var(--bgi);border:2px solid var(--bd);padding:10px 4px;text-align:center;min-height:80px;display:flex;flex-direction:column;align-items:center;justify-content:center}
.pass-zone.stamped{border-color:var(--grn)}
.pz-code{font-family:var(--o);font-size:11px;font-weight:700;margin-bottom:2px}.pz-name{font-size:9px;color:var(--w);font-weight:600}
.pz-stamp{width:32px;height:32px;border-radius:50%;border:2px dashed var(--bd);display:flex;align-items:center;justify-content:center;margin-top:4px;font-size:8px;color:var(--txf)}
.pz-stamp.done{border-style:solid;border-color:var(--grn);color:var(--grn);font-size:13px;background:rgba(34,197,94,.08);animation:stampIn .5s}
@keyframes stampIn{0%{transform:scale(2) rotate(-30deg);opacity:0}60%{transform:scale(.9)}100%{transform:scale(1);opacity:1}}
.pass-input-area{background:var(--bgi);border:1px solid var(--bd);padding:10px;margin-top:10px;text-align:center}
.pass-code-input{background:#000;border:2px solid var(--bd);color:var(--w);padding:8px 12px;font-family:var(--m);font-size:15px;text-align:center;letter-spacing:4px;width:160px;outline:none;text-transform:uppercase}
.pass-code-input:focus{border-color:var(--ylw)}
.pass-code-input.success{border-color:var(--grn)}.pass-code-input.fail{border-color:var(--ac);animation:shake .4s}
@keyframes shake{0%,100%{transform:translateX(0)}25%{transform:translateX(-6px)}75%{transform:translateX(6px)}}
.pass-total{font-family:var(--o);font-size:26px;color:var(--w);font-weight:900;margin-top:8px}

/* MISSION */
.mission-card{background:var(--bg2);border:1px solid var(--bd);padding:12px;margin-bottom:8px;position:relative;overflow:hidden}
.mission-card::before{content:'';position:absolute;left:0;top:0;width:3px;height:100%}
.mission-card.m-active::before{background:var(--ylw)}.mission-card.m-done::before{background:var(--grn)}.mission-card.m-locked::before{background:var(--txf)}
.mission-card.m-locked{opacity:.5}
.mc-header{display:flex;justify-content:space-between}.mc-title{font-size:12px;font-weight:700;color:var(--w)}
.mc-badge{font-family:var(--m);font-size:8px;padding:2px 6px;border-radius:2px}
.mc-badge.active{background:rgba(234,179,8,.1);color:var(--ylw)}.mc-badge.done{background:rgba(34,197,94,.1);color:var(--grn)}.mc-badge.locked{background:rgba(255,255,255,.05);color:var(--txf)}
.mc-desc{font-size:11px;color:var(--txd);margin:5px 0;line-height:1.7}.mc-reward{font-family:var(--m);font-size:9px;color:var(--ylw)}
.mc-chain-line{width:2px;height:16px;background:var(--bd);margin:0 auto}.mc-chain-line.done{background:var(--grn)}
.mc-btn{padding:5px 12px;background:var(--ylw);color:#000;border:none;font-size:10px;font-weight:600;margin-top:5px}

/* TIMER */
.timer-bar{background:var(--bg2);border:1px solid var(--bd);padding:10px;margin-bottom:6px;display:flex;align-items:center;gap:8px}
.timer-icon{font-size:16px}.timer-info{flex:1}.timer-name{font-size:11px;font-weight:600;color:var(--w)}.timer-desc{font-size:9px;color:var(--txd)}
.timer-display{font-family:var(--o);font-size:20px;font-weight:900;color:var(--acl);min-width:80px;text-align:right}
.timer-display.urgent{animation:timerBlink 1s infinite}
@keyframes timerBlink{0%,100%{opacity:1}50%{opacity:.3}}
.timer-progress{width:100%;height:2px;background:var(--bd);margin-top:3px;border-radius:2px;overflow:hidden}
.timer-progress-fill{height:100%;background:var(--ac);border-radius:2px}

/* RADIO */
.radio-body{position:relative}

/* 라디오 메인 유닛 */
.radio-unit{
  background:linear-gradient(170deg,#080f08,#040a04);
  border:1px solid rgba(0,255,65,.15);
  padding:0;
  position:relative;
  overflow:hidden;
}
.radio-unit::before{
  content:'';position:absolute;inset:0;
  background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,255,65,.01) 2px,rgba(0,255,65,.01) 4px);
  pointer-events:none;z-index:0;
}
.radio-unit::after{
  content:'';position:absolute;left:0;right:0;height:80px;
  background:linear-gradient(to bottom,transparent,rgba(0,255,65,.03),transparent);
  animation:rscan 5s linear infinite;pointer-events:none;z-index:0;
}
@keyframes rscan{from{top:-80px}to{top:110%}}
.radio-unit-header{
  display:flex;justify-content:space-between;align-items:center;
  padding:6px 14px;border-bottom:1px solid rgba(0,255,65,.1);
  background:rgba(0,0,0,.4);position:relative;z-index:1;
}
.radio-unit-tag{font-family:var(--m);font-size:8px;color:rgba(0,255,65,.3);letter-spacing:.08em}
.radio-unit-live{display:flex;align-items:center;gap:5px;font-family:var(--m);font-size:8px;color:rgba(0,255,65,.6);letter-spacing:.06em}
.radio-live-dot{width:5px;height:5px;border-radius:50%;background:#00ff41;animation:p 1s infinite;box-shadow:0 0 6px #00ff41}
.radio-unit > *:not(.radio-unit-header){position:relative;z-index:1}
.radio-unit > .radio-display{margin:14px 16px 0}
.radio-unit > .radio-input-row{margin:10px 16px 0}
.radio-unit > .radio-dial-wrap{margin:10px 16px 0}
.radio-unit > .radio-chat{margin:10px 16px 0}
.radio-unit > .radio-btn-row{margin:10px 16px 14px}

/* 주파수 디스플레이 */
.radio-display{
  background:#000;border:1px solid rgba(0,255,65,.3);
  border-radius:3px;padding:12px 16px;margin-bottom:14px;
  display:flex;align-items:center;justify-content:space-between;
  box-shadow:inset 0 0 20px rgba(0,0,0,.8), 0 0 10px rgba(0,255,65,.08);
}
.radio-display-val{
  font-family:var(--o);font-size:32px;font-weight:900;
  color:#00ff41;letter-spacing:-1px;
  text-shadow:0 0 12px rgba(0,255,65,.6), 0 0 30px rgba(0,255,65,.2);
  transition:all .15s;
}
.radio-display-mhz{font-family:var(--m);font-size:9px;color:rgba(0,255,65,.4);align-self:flex-end;margin-bottom:6px;letter-spacing:.1em}
.radio-display-sig{font-family:var(--m);font-size:9px;color:rgba(0,255,65,.5);align-self:flex-end;margin-bottom:6px;text-align:right}
.radio-signal-bars{display:flex;align-items:flex-end;gap:2px;height:16px}
.radio-signal-bars span{display:block;width:3px;background:rgba(0,255,65,.2);border-radius:1px}
.radio-signal-bars span.active{background:#00ff41;box-shadow:0 0 4px rgba(0,255,65,.6)}

/* 다이얼 + 입력 */
.radio-controls-row{display:flex;align-items:center;gap:10px;margin-bottom:12px}
.radio-dial-wrap{flex:1;display:flex;flex-direction:column;gap:4px}
.radio-dial-label{font-family:var(--m);font-size:8px;color:rgba(0,255,65,.35);letter-spacing:.08em}
input[type=range].radio-range{
  width:100%;height:6px;cursor:pointer;
  -webkit-appearance:none;appearance:none;
  background:linear-gradient(to right,rgba(0,255,65,.6) 0%,rgba(0,255,65,.6) var(--pct,18%),rgba(0,255,65,.12) var(--pct,18%),rgba(0,255,65,.12) 100%);
  border-radius:3px;outline:none;
}
input[type=range].radio-range::-webkit-slider-thumb{
  -webkit-appearance:none;width:16px;height:16px;border-radius:50%;
  background:#00ff41;box-shadow:0 0 8px rgba(0,255,65,.8);cursor:pointer;
}
input[type=range].radio-range::-moz-range-thumb{
  width:16px;height:16px;border-radius:50%;border:none;
  background:#00ff41;box-shadow:0 0 8px rgba(0,255,65,.8);cursor:pointer;
}

/* 직접 입력 */
.radio-input-row{display:flex;gap:8px;align-items:stretch;margin-bottom:14px}
.radio-freq-input{
  flex:1;background:rgba(0,255,65,.06);
  border:1px solid rgba(0,255,65,.25);border-radius:3px;
  color:#00ff41;font-family:var(--o);font-size:22px;font-weight:700;
  padding:10px 14px;outline:none;text-align:center;
  -moz-appearance:textfield;
  box-shadow:inset 0 0 10px rgba(0,0,0,.5);
  transition:border-color .2s, box-shadow .2s;
}
.radio-freq-input:focus{border-color:rgba(0,255,65,.6);box-shadow:inset 0 0 10px rgba(0,0,0,.5), 0 0 12px rgba(0,255,65,.15)}
.radio-freq-input::placeholder{color:rgba(0,255,65,.2);font-size:14px}
.radio-freq-input::-webkit-inner-spin-button,.radio-freq-input::-webkit-outer-spin-button{-webkit-appearance:none}
.radio-tune-btn{
  padding:10px 20px;background:rgba(0,255,65,.12);
  border:1px solid rgba(0,255,65,.35);border-radius:3px;
  color:#00ff41;font-family:var(--m);font-size:11px;font-weight:600;
  letter-spacing:.05em;cursor:pointer;white-space:nowrap;
  transition:all .15s;
}
.radio-tune-btn:hover,.radio-tune-btn:active{background:rgba(0,255,65,.25);box-shadow:0 0 14px rgba(0,255,65,.2)}

/* 수신 로그 */
.radio-chat{
  background:#000;border:1px solid rgba(0,255,65,.15);border-radius:3px;
  padding:10px 12px;font-family:var(--m);font-size:11px;color:#00ff41;
  min-height:140px;max-height:220px;overflow-y:auto;line-height:1.8;
  box-shadow:inset 0 0 20px rgba(0,0,0,.6);
}
.radio-chat::-webkit-scrollbar{width:3px}
.radio-chat::-webkit-scrollbar-thumb{background:rgba(0,255,65,.2)}
.radio-msg{padding:3px 0;border-bottom:1px solid rgba(0,255,65,.05);animation:fu .3s}
.radio-msg-time{color:rgba(0,255,65,.35);font-size:9px}
.radio-msg-ch{color:var(--ylw);font-size:9px}

/* 하단 버튼 */
.radio-btn-row{display:flex;gap:6px;margin-top:10px}
.radio-btn{
  padding:7px 14px;font-family:var(--m);font-size:9px;letter-spacing:.05em;
  border:1px solid rgba(0,255,65,.2);background:rgba(0,255,65,.04);
  color:rgba(0,255,65,.7);border-radius:3px;cursor:pointer;transition:all .15s;
}
.radio-btn:hover,.radio-btn:active{background:rgba(0,255,65,.12);color:#00ff41}

/* 유튜브 수신 패널 */
.yt-receive-panel{
  margin-top:12px;
  background:linear-gradient(135deg,rgba(0,20,0,.8),rgba(0,10,0,.9));
  border:1px solid rgba(0,255,65,.25);border-radius:4px;
  overflow:hidden;
  animation:ytPanelIn .4s cubic-bezier(.34,1.3,.64,1);
}
@keyframes ytPanelIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
.yt-panel-header{
  background:rgba(0,255,65,.08);padding:10px 14px;
  display:flex;align-items:center;justify-content:space-between;
  border-bottom:1px solid rgba(0,255,65,.12);
}
.yt-panel-title{font-family:var(--m);font-size:9px;color:#00ff41;letter-spacing:.08em}
.yt-panel-freq{font-family:var(--o);font-size:11px;color:rgba(0,255,65,.6)}
.yt-play-zone{padding:16px;text-align:center}
.yt-play-big-btn{
  display:inline-flex;align-items:center;gap:10px;
  background:rgba(0,255,65,.1);border:1.5px solid rgba(0,255,65,.4);
  border-radius:4px;padding:14px 32px;cursor:pointer;
  font-family:var(--m);font-size:13px;color:#00ff41;letter-spacing:.05em;
  transition:all .2s;
  box-shadow:0 0 20px rgba(0,255,65,.08);
}
.yt-play-big-btn:hover,.yt-play-big-btn:active{background:rgba(0,255,65,.22);box-shadow:0 0 28px rgba(0,255,65,.18)}
.yt-play-big-btn .play-icon{font-size:20px;line-height:1}
.yt-play-hint{font-family:var(--m);font-size:8px;color:rgba(0,255,65,.35);margin-top:8px;letter-spacing:.05em}
.yt-iframe-wrap{padding:0}
.yt-iframe-wrap iframe{display:block;width:100%;border:none}
.cipher-box{background:linear-gradient(170deg,#080f08,#040a04);border:1px solid rgba(0,255,65,.15);overflow:hidden;margin-top:10px}
.cipher-header{display:flex;justify-content:space-between;align-items:center;padding:6px 12px;border-bottom:1px solid rgba(0,255,65,.1);background:rgba(0,0,0,.3)}
.cipher-title{font-family:var(--m);font-size:9px;color:rgba(0,255,65,.7);letter-spacing:.05em}
.cipher-tag{font-family:var(--m);font-size:7px;color:rgba(0,255,65,.25);letter-spacing:.05em}
.cipher-input{width:100%;background:transparent;border:none;border-bottom:1px solid rgba(0,255,65,.12);color:#00ff41;font-family:var(--m);font-size:12px;padding:10px 12px;outline:none;box-sizing:border-box;display:block}
.cipher-input::placeholder{color:rgba(0,255,65,.2)}
.cipher-result{font-family:var(--m);font-size:11px;color:rgba(0,255,65,.8);padding:8px 12px;min-height:22px;white-space:pre-wrap;max-height:80px;overflow-y:auto;background:rgba(0,0,0,.2)}

/* CAPSULE */
.capsule-box{background:var(--bg2);border:1px solid var(--bd);padding:14px}
.capsule-saved{background:var(--bg2);border:1px solid var(--grn);padding:12px;margin-top:8px}

/* ============================================
   PHONE WIDGET (아이폰 15 Pro 목업) - FAB 대체
   ============================================ */
.phone-fab-wrapper{position:fixed;bottom:16px;right:16px;z-index:150}

/* 미니 폰 (평소 상태) */
.phone-mini{width:52px;height:52px;border-radius:50%;background:linear-gradient(145deg,#1a1a1f,#0d0d10);border:2px solid #333;cursor:pointer;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 20px rgba(0,0,0,.6);transition:all .3s;position:relative}
.phone-mini:hover{border-color:#555;transform:scale(1.08)}
.phone-mini svg{width:26px;height:26px}
.phone-mini-badge{position:absolute;top:-3px;right:-3px;width:18px;height:18px;border-radius:50%;background:var(--acl);color:#fff;font-size:9px;font-weight:700;display:none;align-items:center;justify-content:center;font-family:var(--m);border:2px solid var(--bg)}
.phone-mini-badge.show{display:flex}

/* 폰 목업 팝업 */
.phone-popup{position:fixed;bottom:80px;right:16px;z-index:151;display:none;animation:phoneSlideUp .35s cubic-bezier(.34,1.56,.64,1)}
.phone-popup.open{display:block}
@keyframes phoneSlideUp{from{opacity:0;transform:translateY(30px) scale(.9)}to{opacity:1;transform:translateY(0) scale(1)}}

/* 아이폰 15 Pro 셸 */
.iphone-shell{
  width:260px;height:540px;
  background:linear-gradient(160deg,#1c1c1e,#0a0a0c,#1c1c1e);
  border-radius:44px;
  border:1.5px solid rgba(255,255,255,.12);
  box-shadow:
    0 0 0 1px rgba(255,255,255,.04),
    0 30px 80px rgba(0,0,0,.9),
    inset 0 1px 0 rgba(255,255,255,.07);
  position:relative;overflow:hidden;
  display:flex;flex-direction:column;
}
/* 티타늄 프레임 느낌 */
.iphone-shell::before{
  content:'';position:absolute;inset:0;border-radius:44px;
  border:1px solid rgba(255,255,255,.06);pointer-events:none;z-index:10;
}
/* Dynamic Island */
.dynamic-island{
  width:90px;height:30px;
  background:#000;
  border-radius:20px;
  position:absolute;top:10px;left:50%;transform:translateX(-50%);
  z-index:20;
  display:flex;align-items:center;justify-content:center;gap:6px;
  transition:all .4s cubic-bezier(.34,1.56,.64,1);
  overflow:hidden;
}
.dynamic-island.expanded{width:200px;height:46px}
.di-camera{width:10px;height:10px;border-radius:50%;background:#111;border:2px solid #333;flex-shrink:0}
.di-speaker{width:36px;height:5px;background:#111;border-radius:3px;flex-shrink:0}
.di-notif{display:none;font-family:var(--m);font-size:8px;color:var(--acl);white-space:nowrap}
.dynamic-island.expanded .di-notif{display:block}

/* 폰 화면 */
.iphone-screen{
  flex:1;margin:50px 8px 8px;
  border-radius:38px;
  background:#000;
  overflow:hidden;position:relative;
  display:flex;flex-direction:column;
}
/* 화면 꺼진 상태 */
.screen-off{
  position:absolute;inset:0;
  background:#000;z-index:5;
  border-radius:38px;
  transition:opacity .5s;
}
.screen-off.hidden{opacity:0;pointer-events:none}

/* 잠금화면 */
.screen-lock{
  position:absolute;inset:0;z-index:4;
  background:linear-gradient(170deg,#0d0d0f 0%,#111115 60%,#0d0d0f 100%);
  display:flex;flex-direction:column;
  align-items:center;padding-top:54px;
  border-radius:38px;
  transition:opacity .4s;
}
.screen-lock.hidden{opacity:0;pointer-events:none}
.lock-time{font-family:var(--o);font-size:36px;color:#fff;font-weight:700;letter-spacing:-1px}
.lock-date{font-family:var(--f);font-size:10px;color:rgba(255,255,255,.5);margin-top:2px}
.lock-notif-area{width:100%;padding:0 12px;margin-top:16px}
.lock-notif-item{
  background:rgba(255,255,255,.08);
  backdrop-filter:blur(10px);
  border-radius:14px;
  padding:10px 12px;
  margin-bottom:6px;
  display:flex;align-items:center;gap:8px;
  animation:lockNotifIn .4s cubic-bezier(.34,1.3,.64,1);
}
@keyframes lockNotifIn{from{opacity:0;transform:translateY(10px) scale(.95)}to{opacity:1;transform:translateY(0) scale(1)}}
.lock-notif-icon{width:28px;height:28px;border-radius:7px;background:rgba(185,28,28,.8);display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0}
.lock-notif-app{font-size:9px;color:rgba(255,255,255,.5);font-family:var(--m)}
.lock-notif-msg{font-size:10px;color:#fff;line-height:1.3;margin-top:1px}

/* 홈화면 (쪽지 목록) */
.screen-home{
  flex:1;background:linear-gradient(170deg,#0d0d0f,#111115);
  overflow-y:auto;display:flex;flex-direction:column;
}
.screen-home::-webkit-scrollbar{display:none}
.home-header{
  padding:12px 14px 8px;
  background:rgba(0,0,0,.4);
  backdrop-filter:blur(10px);
  border-bottom:1px solid rgba(255,255,255,.05);
  flex-shrink:0;
}
.home-header-title{font-size:13px;font-weight:700;color:#fff;margin-bottom:1px}
.home-header-sub{font-family:var(--m);font-size:8px;color:rgba(255,255,255,.3)}
.home-msgs{padding:8px 6px;flex:1;overflow-y:auto}

/* 긴급연락처 슬롯 */
.ec-slot{
  border:1px dashed rgba(255,0,0,.25);border-radius:6px;
  padding:6px 10px;font-size:9px;min-height:30px;
  display:flex;align-items:center;gap:6px;
  background:rgba(255,0,0,.03);transition:background .15s;
}
.ec-slot.filled{border-style:solid;border-color:rgba(255,80,80,.4);background:rgba(255,0,0,.07);cursor:pointer}
.ec-slot.filled:hover{background:rgba(255,0,0,.13)}
.ec-slot-num{font-family:var(--m);font-size:8px;color:rgba(255,0,0,.4);width:12px;flex-shrink:0}
.ec-slot-info{flex:1;min-width:0}
.ec-slot-name{color:#fff;font-weight:600}
.ec-slot-tag{font-family:var(--m);font-size:8px;color:rgba(255,100,100,.7)}
.ec-slot-remove{font-family:var(--m);font-size:8px;color:rgba(255,80,80,.5)}
.ec-slot-empty{color:rgba(255,255,255,.2);font-family:var(--m);font-size:8px}
.home-msgs::-webkit-scrollbar{display:none}
.home-msg-item{
  background:rgba(255,255,255,.04);
  border:1px solid rgba(255,255,255,.06);
  border-radius:12px;
  padding:8px 10px;
  margin-bottom:5px;
  font-size:10px;
  transition:background .2s;
  cursor:pointer;
}
.home-msg-item:hover{background:rgba(255,255,255,.08)}
.home-msg-item.unread{border-color:rgba(185,28,28,.3);background:rgba(185,28,28,.06)}
.home-msg-from{font-family:var(--m);font-size:8px;color:rgba(255,255,255,.4);display:flex;justify-content:space-between}
.home-msg-body{color:#e0e0e0;margin-top:2px;line-height:1.4}
.home-msg-secret{color:rgba(255,255,255,.15);cursor:pointer;filter:blur(3px);transition:filter .3s}
.home-msg-secret:hover{filter:blur(0);color:#e0e0e0}
.home-msg-badge{display:inline-block;font-family:var(--m);font-size:7px;padding:1px 4px;border-radius:3px;margin-left:4px}
.badge-secret{background:rgba(168,85,247,.2);color:#c084fc}
.badge-urgent{background:rgba(220,38,38,.2);color:#f87171}
/* 쪽지 작성 영역 */
.home-compose{
  padding:8px;border-top:1px solid rgba(255,255,255,.06);
  background:rgba(0,0,0,.4);flex-shrink:0;
  position:relative;
}
/* phone-ac-up 제거됨 — body 레벨 fixed 포탈 사용 */
.compose-row{display:flex;gap:4px;margin-bottom:4px}
.compose-input{
  flex:1;background:rgba(255,255,255,.06);
  border:1px solid rgba(255,255,255,.08);
  color:#fff;padding:5px 8px;font-family:var(--f);font-size:10px;
  outline:none;border-radius:8px;
}
.compose-input::placeholder{color:rgba(255,255,255,.2)}
.compose-btn{
  background:var(--acl);color:#fff;border:none;
  padding:4px 10px;font-size:9px;font-weight:600;
  border-radius:8px;white-space:nowrap;
}
.compose-type-sel{
  background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.08);
  color:#fff;font-size:9px;padding:4px;border-radius:6px;outline:none;
  font-family:var(--m);
}

/* 폰 홈버튼 / 제스처 바 */
.iphone-gesture-bar{
  width:100px;height:4px;
  background:rgba(255,255,255,.25);
  border-radius:2px;
  margin:8px auto 10px;
  flex-shrink:0;
}

/* 전체화면 쪽지 뷰어 */
.phone-fullscreen{
  position:fixed;inset:0;z-index:400;
  background:#000;display:none;flex-direction:column;
  animation:phoneFullIn .4s cubic-bezier(.22,1,.36,1);
}
.phone-fullscreen.open{display:flex}
@keyframes phoneFullIn{from{opacity:0;transform:scale(.95)}to{opacity:1;transform:scale(1)}}
.pf-header{
  padding:50px 16px 14px;
  background:linear-gradient(180deg,#111115,transparent);
  display:flex;align-items:center;justify-content:space-between;
}
.pf-title{font-size:18px;font-weight:700;color:#fff}
.pf-close{background:rgba(255,255,255,.1);border:none;color:#fff;padding:6px 14px;border-radius:20px;font-size:12px}
.pf-msgs{flex:1;overflow-y:auto;padding:12px 16px}
.pf-msg{
  background:rgba(255,255,255,.05);
  border:1px solid rgba(255,255,255,.08);
  border-radius:16px;
  padding:12px 14px;
  margin-bottom:8px;
  animation:fu .3s;
}
.pf-msg.urgent{border-color:rgba(220,38,38,.3)}
.pf-msg.secret{border-color:rgba(168,85,247,.2)}
.pf-msg-header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:6px}
.pf-msg-from{font-family:var(--m);font-size:10px;color:rgba(255,255,255,.5)}
.pf-msg-time{font-family:var(--m);font-size:9px;color:rgba(255,255,255,.25)}
.pf-msg-to{font-size:10px;color:rgba(255,255,255,.3);margin-bottom:4px}
.pf-msg-body{font-size:13px;color:#fff;line-height:1.6}
.pf-msg-secret-body{color:rgba(255,255,255,.12);filter:blur(5px);cursor:pointer;transition:all .3s;font-size:13px;line-height:1.6}
.pf-msg-secret-body:hover, .pf-msg-secret-body.revealed{filter:blur(0);color:#fff}
.pf-compose{
  padding:12px 16px;
  background:rgba(0,0,0,.6);
  border-top:1px solid rgba(255,255,255,.08);
  padding-bottom:30px;
}

/* 진동 애니메이션 */
@keyframes vibrate{
  0%,100%{transform:rotate(0)}
  10%{transform:rotate(-8deg) translateX(-4px)}
  20%{transform:rotate(8deg) translateX(4px)}
  30%{transform:rotate(-6deg) translateX(-3px)}
  40%{transform:rotate(6deg) translateX(3px)}
  50%{transform:rotate(-4deg) translateX(-2px)}
  60%{transform:rotate(4deg) translateX(2px)}
  70%{transform:rotate(-2deg) translateX(-1px)}
  80%{transform:rotate(2deg) translateX(1px)}
}
.vibrating{animation:vibrate .4s ease-out}

/* 화면 켜지는 애니메이션 */
@keyframes screenWake{
  0%{opacity:0;background:#000}
  30%{opacity:1;background:rgba(255,255,255,.06)}
  100%{opacity:0}
}
.screen-wake-flash{
  position:absolute;inset:0;border-radius:38px;
  background:#000;z-index:3;
  animation:screenWake .6s ease-out forwards;
  pointer-events:none;
}

/* TAG MENTION */
.tag-mention{color:var(--acl);font-weight:600;cursor:pointer}
.tag-mention:hover{text-decoration:underline}
/* 자동완성 팝업 */
.tag-autocomplete{
  position:absolute;background:var(--bg2);border:1px solid var(--ac);
  z-index:9999;min-width:200px;max-height:180px;overflow-y:auto;
  box-shadow:0 8px 24px rgba(0,0,0,.8);border-radius:4px;
  top:100%;left:0;right:0;margin-top:2px;
}
.tag-ac-item{padding:9px 12px;font-size:12px;cursor:pointer;display:flex;align-items:center;gap:8px;transition:background .1s}
.tag-ac-item:hover,.tag-ac-item:active{background:var(--acbg)}
.tag-ac-tag{font-family:var(--m);font-size:11px;color:var(--acl);font-weight:600}
.tag-ac-name{color:var(--txd);font-size:11px}

/* 태그 알림 — 우하단 팝업 카드 */
.tag-alert-banner{
  position:fixed;bottom:90px;right:12px;z-index:500;
  width:min(300px,90vw);
  opacity:0;visibility:hidden;
  transform:translateX(20px) scale(.97);
  transition:opacity .3s,visibility .3s,transform .3s cubic-bezier(.34,1.3,.64,1);
  pointer-events:none;
}
.tag-alert-banner.show{opacity:1;visibility:visible;transform:translateX(0) scale(1);pointer-events:all}
.tab-alert-inner{
  background:var(--bg2);
  border:1px solid rgba(220,38,38,.5);
  border-left:3px solid var(--acl);
  padding:12px 14px;
  display:flex;align-items:flex-start;gap:10px;
  box-shadow:0 8px 32px rgba(0,0,0,.6);
  border-radius:3px;
}
.tab-alert-icon{font-size:18px;margin-top:1px}
.tab-alert-text{flex:1;min-width:0}
.tab-alert-source{font-family:var(--m);font-size:9px;color:var(--acl);text-transform:uppercase;letter-spacing:.06em;margin-bottom:3px}
.tab-alert-title{font-size:12px;font-weight:700;color:var(--w);margin-bottom:2px;letter-spacing:-.01em}
.tab-alert-sub{font-size:11px;color:var(--txd);line-height:1.4}
.tab-alert-close{background:none;border:none;color:var(--txf);font-size:14px;padding:0;margin-left:4px;flex-shrink:0;line-height:1}


/* 강탈 결투 오버레이 */
.rob-duel{position:fixed;inset:0;z-index:8200;display:none;align-items:center;justify-content:center;background:rgba(0,0,0,.92)}
.rob-duel.show{display:flex}
.rob-duel-box{width:min(360px,92vw);background:linear-gradient(160deg,#1a0800,#0d0500);border:2px solid var(--org);padding:24px;text-align:center;animation:robIn .4s cubic-bezier(.34,1.3,.64,1)}
@keyframes robIn{from{opacity:0;transform:scale(.8)}to{opacity:1;transform:scale(1)}}
.rob-duel-title{font-family:var(--o);font-size:16px;color:var(--org);margin-bottom:4px;letter-spacing:.05em}
.rob-duel-sub{font-family:var(--m);font-size:9px;color:rgba(249,115,22,.5);margin-bottom:20px;min-height:14px}
.rob-dice-row{display:flex;gap:20px;justify-content:center;align-items:center;margin-bottom:20px}
.rob-dice-side{flex:1;max-width:120px}
.rob-dice-label{font-family:var(--m);font-size:9px;color:var(--txf);margin-bottom:4px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.rob-dice-val{font-family:var(--o);font-size:52px;font-weight:900;line-height:1;margin:4px 0;transition:color .3s}
.rob-dice-val.win{color:var(--grn);text-shadow:0 0 20px rgba(34,197,94,.5)}
.rob-dice-val.lose{color:var(--acl);text-shadow:0 0 20px rgba(220,38,38,.3)}
.rob-dice-val.rolling{animation:diceRoll .1s infinite}
@keyframes diceRoll{0%{transform:rotate(-10deg) scale(1.1)}50%{transform:rotate(10deg) scale(.9)}}
.rob-result{font-size:15px;font-weight:700;margin:10px 0 16px;min-height:22px;letter-spacing:-.01em}
.rob-result.win{color:var(--grn)}
.rob-result.lose{color:var(--acl)}
/* PROFILE */
.prof-card{background:var(--bg2);border:2px solid var(--bd);padding:18px;max-width:380px;position:relative;overflow:hidden}
.prof-card::before{content:'대한민국 봉쇄선 통행증';position:absolute;top:0;left:0;right:0;background:var(--ac);color:#fff;text-align:center;font-family:var(--m);font-size:10px;padding:3px}
.prof-card-watermark{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:160px;height:160px;object-fit:contain;opacity:.15;pointer-events:none;z-index:0}
.prof-info{margin-top:24px;position:relative;z-index:1}.prof-info div{margin-bottom:5px}
.prof-label{font-family:var(--m);font-size:8px;color:var(--txf);text-transform:uppercase}
.prof-val{font-size:13px;font-weight:600;color:var(--w)}.prof-val.tag{color:var(--acl)}
.prof-barcode{margin-top:10px;font-family:var(--m);font-size:6px;color:var(--txf);letter-spacing:2px;text-align:center;padding-top:8px;border-top:1px solid var(--bd)}
.prof-stamp{position:absolute;bottom:12px;right:12px;font-family:var(--m);font-size:9px;color:rgba(34,197,94,.4);transform:rotate(-15deg);border:1px solid rgba(34,197,94,.2);padding:2px 8px}
.inv-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(76px,1fr));gap:6px}

/* 슬롯 베이스 */
.inv-slot{
  background:linear-gradient(135deg,var(--bgi) 0%,rgba(255,255,255,.02) 100%);
  border:1px solid var(--bd2);
  padding:8px 4px 6px;
  text-align:center;min-height:68px;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  position:relative;overflow:hidden;
  cursor:default;
  transition:transform .15s,border-color .15s,box-shadow .15s;
  border-radius:3px;
}
/* 코너 액센트 */
.inv-slot::before{content:'';position:absolute;top:0;left:0;width:6px;height:6px;border-top:1px solid var(--bd2);border-left:1px solid var(--bd2);border-radius:0}
.inv-slot::after{content:'';position:absolute;bottom:0;right:0;width:6px;height:6px;border-bottom:1px solid var(--bd2);border-right:1px solid var(--bd2);border-radius:0}
.inv-slot:hover{transform:translateY(-2px);border-color:rgba(255,255,255,.2);box-shadow:0 4px 16px rgba(0,0,0,.5)}

/* 빈 슬롯 */
.inv-slot.inv-slot-empty{
  background:repeating-linear-gradient(45deg,transparent,transparent 4px,rgba(255,255,255,.01) 4px,rgba(255,255,255,.01) 8px);
  border-style:dashed;border-color:var(--bd);opacity:.4;
}
.inv-slot.inv-slot-empty::before,.inv-slot.inv-slot-empty::after{display:none}
.inv-empty{color:var(--txf);font-size:8px;font-family:var(--m)}

/* 희귀도 색상 비주얼 제거됨 — 구조만 유지 */

/* 만료 임박 */
.inv-slot.expiring{border-color:rgba(249,115,22,.5);box-shadow:0 0 8px rgba(249,115,22,.1);animation:expBlink 2s ease-in-out infinite}
@keyframes expBlink{0%,100%{border-color:rgba(249,115,22,.5)}50%{border-color:rgba(249,115,22,.9)}}

/* 내부 요소 */
.inv-icon{font-size:22px;display:block;margin-bottom:2px;filter:drop-shadow(0 2px 4px rgba(0,0,0,.6))}
.inv-name{font-size:9px;color:var(--tx);font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:68px;line-height:1.2}
.inv-qty{font-family:var(--m);font-size:10px;color:var(--ylw);font-weight:700;margin-top:1px}
.inv-exp-badge{font-family:var(--m);font-size:7px;color:var(--org);margin-top:2px;letter-spacing:.02em}
/* 하단 바 — 단색 */
.inv-rarity-bar{position:absolute;bottom:0;left:0;right:0;height:2px;background:var(--bd2)}
.quest{background:var(--bg2);border:1px solid var(--bd);padding:8px;margin-bottom:5px;display:flex;align-items:center;gap:6px}
.quest.done{opacity:.4}
.quest-chk{width:18px;height:18px;border:2px solid var(--bd);display:flex;align-items:center;justify-content:center;font-size:10px;color:var(--grn);cursor:pointer;flex-shrink:0}
.quest-chk.checked{border-color:var(--grn);background:rgba(34,197,94,.1)}
.quest-txt{font-size:11px;color:var(--tx);flex:1}.quest-rw{font-family:var(--m);font-size:9px;color:var(--ylw)}
.quest.unlocked{border-color:rgba(34,197,94,.3);background:rgba(34,197,94,.03)}
.quest-chk.locked{border-color:rgba(255,255,255,.1);color:var(--txf);font-size:11px;cursor:default}

/* HIDDEN PAGE */
.hidden-page{background:rgba(168,85,247,.02);border:1px solid rgba(168,85,247,.15);padding:18px;position:relative}
.hidden-page::before{content:'TOP SECRET — SC-5';position:absolute;top:-8px;left:14px;font-family:var(--m);font-size:9px;color:var(--pur);background:var(--bg);padding:1px 6px;border:1px solid rgba(168,85,247,.2)}
.hp-section{margin-bottom:14px}.hp-title{font-family:var(--m);font-size:10px;color:var(--pur);text-transform:uppercase;margin-bottom:5px;padding-bottom:3px;border-bottom:1px solid rgba(168,85,247,.1)}
.hp-text{font-size:12px;color:var(--txd);line-height:1.9}
.glitch-text{animation:glitch 3s infinite}
@keyframes glitch{0%,90%,100%{opacity:1}92%{opacity:.8;transform:translateX(2px)}94%{opacity:.6;transform:translateX(-2px)}}

/* MASTER */
.m-header{background:linear-gradient(135deg,rgba(168,85,247,.08),rgba(168,85,247,.02));border:1px solid rgba(168,85,247,.2);padding:12px;margin-bottom:12px;display:flex;justify-content:space-between;align-items:center}
.m-header-t{font-family:var(--o);font-size:13px;color:var(--pur);font-weight:700}.m-header-s{font-family:var(--m);font-size:9px;color:rgba(168,85,247,.5)}
.m-lock-btn{background:none;border:1px solid rgba(168,85,247,.3);color:var(--pur);font-family:var(--m);font-size:9px;padding:3px 10px}
.m-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:6px;margin-bottom:12px}
.m-stat{background:var(--bg2);border:1px solid var(--bd);padding:8px;text-align:center}
.m-stat-v{font-family:var(--o);font-size:16px;font-weight:900}.m-stat-l{font-size:8px;color:var(--txf)}
.m-section{background:var(--bg2);border:1px solid var(--bd);padding:12px;margin-bottom:8px}
.m-section-t{font-family:var(--m);font-size:10px;color:var(--pur);text-transform:uppercase;margin-bottom:8px;padding-bottom:3px;border-bottom:1px solid rgba(168,85,247,.15)}
.m-row{display:flex;gap:5px;margin-bottom:5px;align-items:center;flex-wrap:wrap}
.m-btn{padding:5px 10px;font-family:var(--m);font-size:9px;border:1px solid var(--bd);background:var(--bgi);color:var(--txd)}
.m-btn:hover{border-color:var(--pur);color:var(--pur)}
.m-btn.danger{border-color:rgba(185,28,28,.3);color:var(--acl)}
.m-log{max-height:150px;overflow-y:auto;font-family:var(--m);font-size:9px;color:var(--txf);padding:6px;background:var(--bgi);border:1px solid var(--bd);margin-top:6px}
.m-log-entry{padding:2px 0;border-bottom:1px solid rgba(255,255,255,.02)}.m-log-time{color:var(--pur)}
.m-stat-card{background:var(--bgi);border:1px solid var(--bd);padding:8px 6px;text-align:center}
.m-stat-card-v{font-family:var(--o);font-size:16px;font-weight:900;color:var(--w);line-height:1.2;margin-bottom:2px}
.m-stat-card-l{font-family:var(--m);font-size:7px;color:var(--txf);letter-spacing:.04em}
.m-sched-item{background:var(--bgi);border:1px solid var(--bd);padding:7px 10px;display:flex;justify-content:space-between;align-items:flex-start;gap:6px}
.m-sched-item.fired{border-color:rgba(34,197,94,.3);opacity:.55}
.m-sched-meta{font-family:var(--m);font-size:8px;color:var(--txf);margin-top:2px}
.m-sched-title{font-size:10px;color:var(--tx);font-weight:600;letter-spacing:var(--ls)}
.m-input{background:var(--bgi);border:1px solid var(--bd);color:var(--tx);padding:4px 8px;font-family:var(--f);font-size:11px;outline:none}
.m-select{background:var(--bgi);border:1px solid var(--bd);color:var(--tx);padding:4px 8px;font-family:var(--f);font-size:11px;outline:none;appearance:none}
.m-textarea{width:100%;background:var(--bgi);border:1px solid var(--bd);color:var(--tx);padding:5px 8px;font-family:var(--f);font-size:11px;outline:none;min-height:40px;resize:vertical}
.master-gate{display:flex;align-items:center;justify-content:center;min-height:260px}
.master-gate-box{background:var(--bg2);border:2px solid var(--pur);padding:24px;text-align:center;max-width:300px;width:100%;position:relative}
.master-gate-box::before{content:'AUTHORIZED PERSONNEL ONLY';position:absolute;top:-9px;left:50%;transform:translateX(-50%);font-family:var(--m);font-size:8px;color:var(--pur);background:var(--bg);padding:1px 10px;white-space:nowrap;border:1px solid rgba(168,85,247,.2)}
.mg-input{width:140px;background:var(--bgi);border:2px solid var(--bd);color:var(--w);padding:8px;font-family:var(--m);font-size:16px;text-align:center;letter-spacing:8px;outline:none}
.mg-input:focus{border-color:var(--pur)}.mg-input.wrong{border-color:var(--ac);animation:shake .4s}
.mg-err{font-family:var(--m);font-size:9px;color:var(--ac);margin-top:5px;min-height:14px}
.master-dash{display:none}.master-dash.unlocked{display:block}

/* EMERGENCY */
.emg{display:none;position:fixed;top:0;left:0;width:100%;height:100%;z-index:600;align-items:center;justify-content:center}.emg.show{display:flex}
.emg-bg{position:absolute;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.85)}
.emg-c{position:relative;z-index:1;text-align:center;max-width:360px;padding:24px}
.emg-a{font-family:var(--m);font-size:9px;color:var(--acl);animation:eb .8s infinite}
@keyframes eb{0%,100%{opacity:1}50%{opacity:.3}}
/* ── 재난문자 팝업 ── */
#disaster-sms{
  display:none;position:fixed;inset:0;z-index:8500;
  align-items:center;justify-content:center;padding:16px;
}
#disaster-sms.show{display:flex}
.dsms-bg{position:absolute;inset:0;background:rgba(0,0,0,.6)}
.dsms-box{
  position:relative;z-index:1;width:min(380px,92vw);
  background:#1a0000;border:2px solid #ff2200;
  font-family:var(--f);overflow:hidden;
}
.dsms-flash{animation:dsmsflash .6s infinite}
@keyframes dsmsflash{0%,100%{border-color:#ff2200;box-shadow:0 0 0 0 rgba(255,34,0,.0)}50%{border-color:#ff6600;box-shadow:0 0 18px 4px rgba(255,34,0,.45)}}
.dsms-header{
  background:#cc0000;padding:10px 14px;
  display:flex;align-items:center;gap:10px;
}
.dsms-siren{font-size:18px;animation:sirenrot .5s infinite alternate}
@keyframes sirenrot{from{filter:brightness(1)}to{filter:brightness(1.6)}}
.dsms-header-text{flex:1}
.dsms-sender{font-size:10px;color:rgba(255,255,255,.7);font-family:var(--m);letter-spacing:.05em}
.dsms-title{font-size:13px;font-weight:700;color:#fff;letter-spacing:-.01em}
.dsms-body{padding:16px 16px 12px;line-height:1.85;font-size:13px;color:#f0d0d0;white-space:pre-line}
.dsms-footer{padding:0 14px 14px;display:flex;gap:8px;justify-content:flex-end}
.dsms-confirm{
  background:#cc0000;color:#fff;border:none;
  padding:9px 24px;font-size:13px;font-weight:600;font-family:var(--f);
  cursor:pointer;letter-spacing:-.01em;
}
.dsms-confirm:hover{background:#ff2200}
.dsms-time{font-family:var(--m);font-size:9px;color:rgba(255,180,180,.5);padding:0 14px 8px}

.emg-m{font-size:14px;font-weight:700;color:#fff;margin:6px 0}.emg-s{font-size:11px;color:var(--tx);line-height:1.6;margin-bottom:12px;white-space:pre-line}

/* CENSORSHIP */
.cov{display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(185,28,28,.08);z-index:500;align-items:center;justify-content:center}.cov.show{display:flex}
.cbx{background:var(--bg);border:2px solid var(--ac);padding:18px 24px;text-align:center;max-width:340px}

/* TOAST */

/* 아이템 사용 팝업 */
#item-use-popup{display:none;position:fixed;inset:0;background:rgba(0,0,0,.75);z-index:4000;align-items:center;justify-content:center}
#item-use-popup.show{display:flex}
.item-use-box{background:var(--bg2);border:1px solid var(--bd2);border-top:2px solid var(--grn);width:min(280px,88vw);padding:20px;text-align:center;border-radius:2px;animation:fu .25s}
.item-use-icon{font-size:36px;margin-bottom:6px}
.item-use-name{font-size:14px;font-weight:700;color:var(--w);margin-bottom:4px}
.item-use-desc{font-family:var(--m);font-size:10px;color:var(--txd);margin-bottom:14px}
.item-use-btns{display:flex;gap:8px;justify-content:center}
/* 체력 획득 팝업 */
#hp-popup{display:none;position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);z-index:4100;pointer-events:none}
#hp-popup.show{display:block;animation:hpFloat 1.8s ease-out forwards}
@keyframes hpFloat{0%{opacity:1;transform:translate(-50%,-50%)}100%{opacity:0;transform:translate(-50%,-120%)}}
.hp-text{font-family:var(--o);font-size:28px;font-weight:900;color:var(--grn);text-shadow:0 0 20px rgba(34,197,94,.6)}

.toast{position:fixed;bottom:80px;left:50%;transform:translateX(-50%) translateY(50px);background:var(--bg2);border:1px solid var(--ac);padding:5px 12px;font-family:var(--m);font-size:10px;color:var(--acl);z-index:300;transition:transform .4s,opacity .4s;white-space:nowrap;max-width:90vw;opacity:0;pointer-events:none}
.toast.show{transform:translateX(-50%) translateY(0);opacity:1;pointer-events:all}

/* TRADE */
.trade-card{background:var(--bg2);border:1px solid var(--bd);padding:13px 14px;position:relative;transition:border-color .2s,box-shadow .2s;animation:tradeIn .25s ease;border-radius:2px}
.trade-card:hover{border-color:var(--bd2);box-shadow:0 4px 20px rgba(0,0,0,.4)}
.trade-card.accepted{border-color:rgba(34,197,94,.25);opacity:.55}
.trade-card.robbed{border-color:rgba(249,115,22,.25);opacity:.55}
.trade-card.mine{border-left:2px solid var(--acl)}
.trade-row{display:grid;grid-template-columns:1fr 28px 1fr;align-items:stretch;gap:5px;margin-bottom:8px}
.trade-offer{background:var(--bgi);border:1px solid var(--bd);padding:8px 10px;font-size:12px;color:var(--tx);display:flex;align-items:center;gap:4px;min-height:38px;transition:border-color .15s}
.trade-offer:hover{border-color:var(--bd2)}
.trade-arrow{color:var(--txf);font-size:14px;flex-shrink:0;display:flex;align-items:center;justify-content:center}
.trade-want{background:var(--bgi);border:1px solid var(--bd);padding:8px 10px;font-size:12px;color:var(--txd);display:flex;align-items:center;gap:4px;min-height:38px;transition:border-color .15s}
.trade-want:hover{border-color:var(--bd2)}
.trade-meta{display:flex;justify-content:space-between;align-items:center;font-family:var(--m);font-size:9px;color:var(--txf);flex-wrap:wrap;gap:4px;padding-top:6px;border-top:1px solid rgba(255,255,255,.04)}
.trade-note{font-size:10px;color:var(--txd);margin-bottom:6px;padding:5px 8px;background:rgba(255,255,255,.015);border-left:1px solid var(--bd2)}
.trade-actions{display:flex;gap:5px;flex-wrap:wrap}
.trade-accept-btn{background:none;border:1px solid rgba(34,197,94,.5);color:var(--grn);padding:5px 14px;font-family:var(--m);font-size:9px;cursor:pointer;transition:all .18s;letter-spacing:.03em}
.trade-accept-btn:hover{background:rgba(34,197,94,.1);border-color:var(--grn)}
.trade-rob-btn{background:none;border:1px solid rgba(249,115,22,.4);color:var(--org);padding:5px 14px;font-family:var(--m);font-size:9px;cursor:pointer;transition:all .18s;letter-spacing:.03em}
.trade-rob-btn:hover{background:rgba(249,115,22,.1);border-color:var(--org)}
.trade-cancel-btn{background:none;border:1px solid var(--bd);color:var(--txf);padding:5px 12px;font-family:var(--m);font-size:9px;cursor:pointer;transition:border-color .15s}
.trade-cancel-btn:hover{border-color:var(--bd2);color:var(--txd)}
.trade-accepted-badge{font-family:var(--m);font-size:9px;color:rgba(34,197,94,.7);padding:3px 8px;border:1px solid rgba(34,197,94,.2)}
.trade-robbed-badge{font-family:var(--m);font-size:9px;color:rgba(249,115,22,.7);padding:3px 8px;border:1px solid rgba(249,115,22,.2)}
@keyframes tradeIn{from{opacity:0;transform:translateY(-6px)}to{opacity:1;transform:none}}

/* VISUAL UPGRADE */
.fi{background:var(--bgi);border:1px solid var(--bd);color:var(--tx);padding:9px 12px;font-size:13px;outline:none;width:100%;box-sizing:border-box;transition:border-color .15s;letter-spacing:var(--ls)}
.fi:focus{border-color:var(--bd2)}
.fi::placeholder{color:var(--txf);font-size:12px}
#toast{position:fixed;bottom:80px;left:50%;transform:translateX(-50%);background:var(--bg2);border:1px solid var(--bd2);color:var(--txd);font-family:var(--m);font-size:10px;padding:8px 18px;z-index:9000;pointer-events:none;opacity:0;transition:opacity .25s;white-space:nowrap;letter-spacing:var(--lsm);max-width:88vw;text-align:center}
#toast.show{opacity:1}
.ptr:hover{background:rgba(255,255,255,.02)}

/* 공통 주의사항 박스 */
.notice-box{border:1px solid var(--bd);background:var(--bg2);margin-bottom:14px;overflow:hidden}
.notice-box-header{display:flex;align-items:center;gap:6px;padding:7px 12px;border-bottom:1px solid var(--bd);background:rgba(0,0,0,.2)}
.notice-box-icon{font-size:11px;opacity:.7}
.notice-box-label{font-family:var(--m);font-size:8px;color:var(--txf);letter-spacing:var(--lsm);text-transform:uppercase}
.notice-box-body{padding:10px 12px;font-size:12px;color:var(--txd);line-height:1.8;white-space:pre-line;min-height:28px}
.notice-box-empty{font-style:italic;opacity:.4}

/* 섹션 구분선 */
.sec-divider{height:1px;background:var(--bd);margin:18px 0;opacity:.6}

/* REPORT */
.report-user-card{background:var(--bg2);border:1px solid var(--bd);padding:10px 12px;display:flex;align-items:center;gap:10px}
.report-user-card .ru-name{font-size:13px;font-weight:700;color:var(--w)}
.report-user-card .ru-tag{font-family:var(--m);font-size:10px;color:var(--acl)}
.report-user-card .ru-meta{font-size:10px;color:var(--txd)}
.report-btn{background:rgba(185,28,28,.08);border:1px solid rgba(185,28,28,.3);color:var(--acl);padding:4px 12px;font-family:var(--m);font-size:9px;cursor:pointer;transition:all .2s;margin-left:auto}
.report-btn:hover{background:rgba(185,28,28,.2)}
.report-btn:disabled{opacity:.4;cursor:not-allowed}
.quarantine-card{background:rgba(185,28,28,.05);border:1px solid rgba(185,28,28,.25);padding:10px 12px;display:flex;align-items:center;gap:10px}
.quarantine-card .qc-name{font-size:12px;font-weight:700;color:var(--acl)}
.quarantine-card .qc-tag{font-family:var(--m);font-size:9px;color:var(--txd)}
.quarantine-badge{font-family:var(--m);font-size:8px;padding:2px 6px;border:1px solid var(--ac);color:var(--ac);margin-left:auto;white-space:nowrap}
.quarantine-badge.danger{background:var(--ac);color:#fff;animation:qpulse 1.5s infinite}
@keyframes qpulse{0%,100%{opacity:1}50%{opacity:.5}}
.report-count-bar{display:flex;gap:3px;margin-top:4px}
.report-pip{width:14px;height:4px;background:var(--bd);border-radius:1px}
.report-pip.filled{background:var(--acl)}
.infected-overlay{position:fixed;inset:0;background:rgba(185,28,28,.12);z-index:9999;pointer-events:none;animation:infpulse 2s infinite}
@keyframes infpulse{0%,100%{opacity:0}50%{opacity:1}}

/* 게시판 모바일 */
.blay{display:flex !important;flex-direction:column !important;border:none !important;gap:8px !important;min-height:0 !important}
.bside{width:100% !important;flex-shrink:0 !important;border:none !important;border-right:none !important;display:flex !important;flex-direction:row !important;overflow-x:auto !important;overflow-y:visible !important;padding:4px 0 !important;gap:6px !important;-webkit-overflow-scrolling:touch;scrollbar-width:none;background:transparent !important;height:auto !important;min-height:0 !important;align-items:center !important}
.bside::-webkit-scrollbar{display:none}
.bsi{padding:6px 14px !important;font-size:11px;white-space:nowrap;border-radius:20px !important;letter-spacing:-.02em;flex-shrink:0;border:1px solid var(--bd) !important;background:var(--bg2) !important;color:var(--txd) !important;height:auto !important;display:inline-block !important;cursor:pointer}
.bsi.on::before{display:none !important}
.bsi.on{background:var(--ac) !important;color:#fff !important;border-color:var(--ac) !important;font-weight:700 !important}
.bsic{display:none !important}
.bmain{padding:0 !important;border:none !important;width:100%}
.ptbl-head{display:none !important}
.ptr{flex-wrap:wrap !important;padding:12px 14px !important;gap:5px 8px !important;border-radius:6px;margin-bottom:4px;background:var(--bg2);border:1px solid var(--bd)}
.board-pager{display:flex;align-items:center;justify-content:center;flex-wrap:wrap;gap:4px;padding:12px 8px;border-top:1px solid var(--bd)}
.bpg-btn{background:var(--bgi);border:1px solid var(--bd);color:var(--tx);padding:5px 10px;font-size:11px;font-family:var(--m);cursor:pointer;min-width:32px;transition:background .1s,border-color .1s}
.bpg-btn:hover:not([disabled]){background:var(--acbg);border-color:var(--ac)}
.bpg-btn.on{background:var(--ac);border-color:var(--ac);color:#fff;font-weight:700}
.bpg-btn[disabled]{opacity:.3;cursor:default}
.bpg-info{font-family:var(--m);font-size:9px;color:var(--txf);margin-left:6px}
.ptr-num{display:none !important}
.ptr-cat{width:auto;flex-shrink:0;order:1}
.ptr-cmt{font-family:var(--m);font-size:9px;color:var(--txf);margin-left:4px}
.ptr-title{order:2;flex:1 1 100%;min-width:0}
.ptr-auth{order:3;flex:1 1 100%;text-align:left !important;font-size:9px;color:var(--txf) !important;display:block !important}

.pg{padding:10px}.m-stats{grid-template-columns:repeat(2,1fr)}
.pass-zones{grid-template-columns:repeat(3,1fr)}
#pg-board .btn{font-size:12px;padding:7px 14px}
}


/* =====================================================
   모바일 최적화 (@media)
   ===================================================== */
/* iOS 입력창 자동 확대 방지 */
input, textarea, select { touch-action: manipulation; }

@media (max-width: 600px) {
  /* 탑바 */
  .topbar { padding: 0 8px; }
  .topbar-title { font-size: 10px; letter-spacing: .04em; }
  /* 탭 */
  .tab { padding: 10px 8px; font-size: 9px; min-width: 30px; }
  /* 페이지 패딩 */
  .pg { padding: 10px 8px; }
  /* 게시판 */
  .blay { flex-direction: column !important; }
  .bside { width: 100% !important; }
  .ptr { padding: 10px 6px; }
  .ptr-title { font-size: 12px; }
  .ptr-auth { max-width: 60px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  /* 글쓰기 폼 */
  .fi, .fta, .fsl { font-size: 16px !important; } /* iOS 확대 방지 */
  /* 버튼 터치 영역 */
  .btn, .btn-o { min-height: 42px; padding: 9px 16px; font-size: 13px; }
  .compose-btn { min-height: 36px; }
  /* 모달 */
  .mob { padding: 16px 12px; margin: 8px; max-width: calc(100vw - 16px); }
  /* 인벤토리 */
  .inv-grid { grid-template-columns: repeat(auto-fill, minmax(70px, 1fr)); gap: 5px; }
  /* 프로필 카드 2열 → 1열 */
  .g2 { grid-template-columns: 1fr !important; }
  /* 퀘스트 */
  .quest { padding: 6px 8px; }
  .quest-rw { font-size: 9px; }
  /* 미션 */
  .mission-card { padding: 10px; }
  /* 통행증 */
  .pass-stamp { width: 54px; height: 54px; font-size: 10px; }
  /* 전체화면 쪽지 */
  .phone-fullscreen { padding: 10px; }
  .pf-compose { padding: 10px; }
  /* 거래소 카드 */
  .trade-card { padding: 10px; }
  /* 폰 팝업 — 화면 우측 밖으로 나가지 않게 */
  .phone-popup {
    right: 4px !important;
    bottom: 64px !important;
    transform: none !important;
    left: auto !important;
  }
  /* 폰 크기 */
  .iphone-shell { width: min(260px, 86vw) !important; height: min(520px, 80vh) !important; }
  /* 보급품 아이템 */
  .kit-it { font-size: 10px; padding: 3px; }
  /* 감염 시뮬레이션 */
  #inf-map { max-width: 100%; }
}

@media (max-width: 400px) {
  .tab { padding: 9px 5px; font-size: 8px; }
  .iphone-shell { width: 90vw !important; height: 76vh !important; }
  .inv-grid { grid-template-columns: repeat(3, 1fr); }
  .mob { padding: 12px 10px; }
}

/* 터치 기기: hover 효과 제거 (고스트 hover 방지) */
@media (hover: none) {
  .ptr:hover { background: transparent !important; }
  .btn:hover, .btn-o:hover { opacity: 1 !important; transform: none !important; }
  .inv-slot:hover { transform: none !important; box-shadow: none !important; }
  .bsi:hover { background: transparent !important; }
}

/* ============================================================
   CUSTOM CURSOR — 군사 조준경
   ============================================================ */
@media (pointer: fine) {
  * { cursor: none !important; }
  #vx-cursor {
    position: fixed; top: 0; left: 0; z-index: 99999;
    pointer-events: none; width: 24px; height: 24px;
    transform: translate(-50%, -50%);
    transition: transform .08s ease, opacity .15s;
  }
  #vx-cursor svg { display: block; }
  #vx-cursor.clicking { transform: translate(-50%,-50%) scale(.75); }
  #vx-cursor.on-interactive { opacity: .7; }
}

/* ============================================================
   CLIP-PATH — 패널 절단면 효과
   ============================================================ */
.clip-panel {
  clip-path: polygon(0 0, calc(100% - 12px) 0, 100% 12px, 100% 100%, 12px 100%, 0 calc(100% - 12px));
}
.clip-panel-sm {
  clip-path: polygon(0 0, calc(100% - 7px) 0, 100% 7px, 100% 100%, 0 100%);
}
.clip-panel-top {
  clip-path: polygon(0 0, calc(100% - 10px) 0, 100% 10px, 100% 100%, 0 100%);
}

/* ============================================================
   SCANLINE OVERLAY — 전체 화면 CRT 효과
   ============================================================ */
#vx-scanline {
  position: fixed; inset: 0; z-index: 9998; pointer-events: none;
  background: repeating-linear-gradient(
    0deg,
    transparent,
    transparent 2px,
    rgba(0,0,0,.07) 2px,
    rgba(0,0,0,.07) 4px
  );
  opacity: .4;
}
#vx-noise {
  position: fixed; inset: 0; z-index: 9997; pointer-events: none;
  opacity: .025;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  background-size: 180px 180px;
  animation: noiseAnim 0.15s steps(1) infinite;
}
@keyframes noiseAnim {
  0%   { background-position: 0 0; }
  25%  { background-position: -30px 10px; }
  50%  { background-position: 10px -20px; }
  75%  { background-position: -20px -10px; }
  100% { background-position: 0 0; }
}

/* ============================================================
   VIGNETTE — 화면 가장자리 어둠
   ============================================================ */
#vx-vignette {
  position: fixed; inset: 0; z-index: 9996; pointer-events: none;
  background: radial-gradient(ellipse at center, transparent 60%, rgba(0,0,0,.55) 100%);
}

/* ============================================================
   CARD / BTN / SECTION clip-path 적용
   ============================================================ */
.card { clip-path: polygon(0 0, calc(100% - 8px) 0, 100% 8px, 100% 100%, 8px 100%, 0 calc(100% - 8px)); }
.btn  { clip-path: polygon(0 0, calc(100% - 5px) 0, 100% 5px, 100% 100%, 0 100%); }
.m-section { clip-path: polygon(0 0, calc(100% - 8px) 0, 100% 8px, 100% 100%, 0 100%); }
.notice-box { clip-path: polygon(0 0, calc(100% - 7px) 0, 100% 7px, 100% 100%, 0 100%); }

/* ============================================================
   EFT-STYLE: 상태 코너 장식
   ============================================================ */
.eft-corner {
  position: relative;
}
.eft-corner::before,
.eft-corner::after {
  content: '';
  position: absolute;
  width: 8px; height: 8px;
  border-color: var(--bd2); border-style: solid;
  pointer-events: none;
}
.eft-corner::before { top: 0; left: 0; border-width: 1px 0 0 1px; }
.eft-corner::after  { bottom: 0; right: 0; border-width: 0 1px 1px 0; }


/* ================================================================
   VX-24 VISUAL OVERRIDE v4 — GAME UI
   ================================================================ */

/* ── 색상 변수 재정의 ────────────────────────────────────────── */
:root {
  --bg:   #1a1a22;
  --bg2:  #22222e;
  --bg3:  #2a2a38;
  --bgi:  #14141c;
  --bd:   #3a3a4e;
  --bd2:  #50506a;
  --tx:   #e2e2f0;
  --txd:  #9090a8;
  --txf:  #60607a;
  --w:    #f5f5ff;
  --ac:   #c42020;
  --acl:  #f05050;
  --acbg: rgba(240,80,80,.10);
  --grn:  #38e878;
  --ylw:  #f5c842;
  --pur:  #c07aff;
  --org:  #ff9a50;
}

/* ── body 배경 ───────────────────────────────────────────────── */
body { background: #13131a; }

/* ── 배경 이미지 레이어 ──────────────────────────────────────── */
#vx-bg {
  position: fixed; inset: 0; z-index: 0; pointer-events: none;
  background-image: url('data:image/jpeg;base64,');
  background-size: cover;
  background-position: center center;
  background-attachment: fixed;
  filter: brightness(0.32) saturate(0.5);
}
#vx-bg-overlay {
  position: fixed; inset: 0; z-index: 1; pointer-events: none;
  background:
    linear-gradient(180deg,
      rgba(10,8,14,0.60) 0%,
      rgba(14,10,10,0.25) 50%,
      rgba(16,10,10,0.55) 100%);
}

/* ── z-index 계층 (탑바/탭/페이지) ─────────────────────────── */
.topbar { z-index: 200 !important; }
.tabs   { z-index: 190 !important; top: 50px !important; }
.pg     { position: relative; z-index: 10; }

/* ================================================================
   TOPBAR — 게임 HUD
   ================================================================ */
.topbar {
  height: 50px !important;
  padding: 0 18px !important;
  background: rgba(12,10,16,0.98) !important;
  border-bottom: 1px solid rgba(240,80,80,0.25) !important;
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  box-shadow: 0 1px 0 rgba(240,80,80,0.10), 0 4px 28px rgba(0,0,0,0.70) !important;
}
.topbar::after {
  content: '';
  position: absolute; bottom: 0; left: 0; right: 0; height: 1px;
  background: linear-gradient(90deg,
    transparent 0%, rgba(240,80,80,0.6) 20%,
    rgba(240,80,80,0.6) 80%, transparent 100%);
  pointer-events: none;
}
.topbar-t {
  font-family: var(--o) !important;
  font-size: 11px !important;
  font-weight: 700 !important;
  letter-spacing: .14em !important;
  text-transform: uppercase !important;
  color: var(--w) !important;
  text-shadow: 0 0 16px rgba(240,80,80,0.40);
}
.topbar-dot {
  width: 8px !important; height: 8px !important;
  background: var(--acl) !important;
  box-shadow: 0 0 10px rgba(240,80,80,1.0), 0 0 22px rgba(240,80,80,0.50) !important;
}

/* ================================================================
   TABS — 게임 카테고리 바
   ================================================================ */
.tabs {
  background: rgba(10,9,15,0.98) !important;
  border-bottom: 1px solid rgba(255,255,255,0.06) !important;
  backdrop-filter: blur(16px) !important;
  -webkit-backdrop-filter: blur(16px) !important;
  box-shadow: 0 3px 20px rgba(0,0,0,0.60) !important;
}
.tab {
  font-family: var(--m) !important;
  font-size: 9px !important;
  font-weight: 700 !important;
  letter-spacing: .06em !important;
  text-transform: uppercase !important;
  padding: 12px 14px !important;
  color: #62627e !important;
  border-bottom: 2px solid transparent !important;
  transition: all .18s !important;
  position: relative;
}
.tab:hover {
  color: #c0c0d8 !important;
  background: rgba(255,255,255,0.04) !important;
}
.tab.on {
  color: var(--acl) !important;
  border-bottom-color: var(--acl) !important;
  background: rgba(240,80,80,0.08) !important;
  text-shadow: 0 0 14px rgba(240,80,80,0.50) !important;
}
/* 활성 탭 상단 포인트 라인 */
.tab.on::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0; height: 2px;
  background: var(--acl);
  box-shadow: 0 0 8px rgba(240,80,80,0.70);
}

/* ================================================================
   SL 섹션 라벨
   ================================================================ */
.sl {
  font-family: var(--m) !important;
  font-size: 8px !important;
  color: rgba(240,80,80,0.65) !important;
  letter-spacing: .16em !important;
  text-transform: uppercase !important;
  margin-bottom: 8px !important;
  opacity: 1 !important;
  display: flex !important;
  align-items: center !important;
  gap: 8px !important;
}
.sl::after {
  content: '';
  flex: 1;
  height: 1px;
  background: linear-gradient(90deg, rgba(240,80,80,0.20) 0%, transparent 100%);
}

/* ================================================================
   섹션 제목 ST
   ================================================================ */
.st {
  font-family: var(--o) !important;
  font-size: 18px !important;
  font-weight: 900 !important;
  letter-spacing: -.01em !important;
  text-shadow: 0 2px 24px rgba(0,0,0,0.90) !important;
}
.st .d {
  color: var(--acl) !important;
  text-shadow: 0 0 28px rgba(240,80,80,0.55) !important;
}

/* ================================================================
   CARD — 게임 패널
   ================================================================ */
.card {
  background: rgba(24,22,34,0.84) !important;
  border: 1px solid rgba(255,255,255,0.08) !important;
  border-top-color: rgba(255,255,255,0.13) !important;
  backdrop-filter: blur(12px) !important;
  -webkit-backdrop-filter: blur(12px) !important;
  box-shadow: 0 2px 16px rgba(0,0,0,0.40), inset 0 1px 0 rgba(255,255,255,0.04) !important;
}
.card:hover {
  background: rgba(30,26,42,0.92) !important;
  border-color: rgba(240,80,80,0.22) !important;
}

/* ================================================================
   BOARD — 게시판 (핵심 개선)
   ================================================================ */
.blay {
  background: rgba(16,14,24,0.88) !important;
  border: 1px solid rgba(255,255,255,0.07) !important;
  border-radius: 4px !important;
  backdrop-filter: blur(12px) !important;
  -webkit-backdrop-filter: blur(12px) !important;
  box-shadow: 0 4px 28px rgba(0,0,0,0.50) !important;
}
.bside {
  background: rgba(10,9,18,0.70) !important;
  border-right: 1px solid rgba(255,255,255,0.05) !important;
}
.bsi {
  font-family: var(--m) !important;
  font-size: 10px !important;
  letter-spacing: .03em !important;
  color: var(--txd) !important;
  padding: 9px 14px !important;
  border-left: 2px solid transparent !important;
  transition: all .15s !important;
}
.bsi:hover {
  color: var(--w) !important;
  background: rgba(255,255,255,0.04) !important;
}
.bsi.on {
  color: var(--w) !important;
  background: rgba(240,80,80,0.09) !important;
  border-left-color: var(--acl) !important;
}
.bsi.on::before { display: none !important; }

/* 게시판 헤더 */
.ptbl-head {
  background: rgba(10,9,18,0.60) !important;
  border-bottom: 1px solid rgba(255,255,255,0.07) !important;
  padding: 8px 12px !important;
}
.ptbl-head span {
  font-family: var(--m) !important;
  font-size: 8.5px !important;
  font-weight: 700 !important;
  letter-spacing: .08em !important;
  text-transform: uppercase !important;
  color: var(--txf) !important;
}

/* 게시글 행 */
.ptr {
  border-bottom: 1px solid rgba(255,255,255,0.04) !important;
  padding: 12px 12px !important;
  transition: background .12s !important;
}
.ptr:hover {
  background: rgba(240,80,80,0.05) !important;
}
.ptr:hover .ptt { color: var(--w) !important; }
.ptt { color: var(--tx) !important; font-size: 12.5px !important; }
.ptt.pin {
  color: var(--w) !important;
  font-weight: 700 !important;
}
.ppin { color: var(--acl) !important; }
.ptr-auth.adm { color: var(--acl) !important; }

/* 배지 */
.pb { border-radius: 3px !important; font-weight: 700 !important; }
.pbn { background: rgba(240,80,80,0.14) !important; color: #ff8080 !important; }
.pbr { background: rgba(80,140,240,0.14) !important; color: #80b0ff !important; }
.pbs { background: rgba(56,232,120,0.12) !important; color: #60ee90 !important; }
.pbsg { background: rgba(245,200,66,0.12) !important; color: #ffd060 !important; }
.pbm { background: rgba(192,122,255,0.14) !important; color: #d090ff !important; }
.pbl { background: rgba(240,80,80,0.10) !important; color: var(--acl) !important; }

/* 라이브 인디케이터 */
.board-live { color: var(--grn) !important; }
.board-live-dot {
  background: var(--grn) !important;
  box-shadow: 0 0 8px rgba(56,232,120,0.70) !important;
}

/* 페이저 */
.bpg-btn { background: rgba(16,14,24,0.90) !important; border-color: rgba(255,255,255,0.09) !important; }
.bpg-btn:hover:not([disabled]) {
  background: rgba(240,80,80,0.12) !important;
  border-color: rgba(240,80,80,0.35) !important;
  color: var(--acl) !important;
}
.bpg-btn.on {
  background: rgba(240,80,80,0.18) !important;
  border-color: var(--ac) !important;
  color: var(--acl) !important;
}

/* ================================================================
   REPORT — 신고 페이지
   ================================================================ */
.report-user-card {
  background: rgba(22,18,32,0.88) !important;
  border: 1px solid rgba(255,255,255,0.08) !important;
  border-left: 3px solid rgba(255,255,255,0.12) !important;
  backdrop-filter: blur(10px) !important;
  -webkit-backdrop-filter: blur(10px) !important;
