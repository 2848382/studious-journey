async function processTradeQueue() {
  if (!navigator.onLine) return;
  const queue = JSON.parse(localStorage.getItem('vx24_trade_queue') || '[]');
  if (!queue.length) return;
  const failed = [];
  for (const t of queue) {
    try {
      const { error } = await window.supabase.from('trades').insert(t);
      if (error) throw error;
    } catch { failed.push(t); }
  }
  localStorage.setItem('vx24_trade_queue', JSON.stringify(failed));
  const done = queue.length - failed.length;
  if (done > 0) console.log('[Sync] 처리 완료:', done, '건');
}

if ('serviceWorker' in navigator) {
  navigator.serviceWorker.addEventListener('message', e => {
    if (e.data?.type === 'FLUSH_TRADE_QUEUE') processTradeQueue();
  });
}

