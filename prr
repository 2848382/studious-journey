                  status: 'robbed',
                  robbed_by: currentUser ? currentUser.tag : 'UNKNOWN',
                  accepted_by: 'ANONYMOUS'  // 플레이어에겐 익명
                });
                // 강탈자 인벤 획득
                addToInv(offerP.name, offerP.icon, offerP.q);
                renderInv();
                if (typeof saveInvToDB === 'function') saveInvToDB();
                // 등록자에게 익명 알림
                sbReq('POST', 'notes', {
                  from_call: '⚠ 거래소',
                  to_call: t.author_tag,
                  body: '⚔ 등록하신 거래가 강탈당했습니다.\n['+t.offer+']\n강탈자는 알 수 없습니다.',
                  type: 'urgent',
                  created_at: new Date().toISOString()
                }).catch(function(){});
                if (typeof addMLog === 'function') addMLog('[강탈성공] '+currentUser.tag+' → 거래#'+robTargetId+' ('+t.offer+')');
                showToast('⚔ 강탈 성공! '+offerP.icon+' '+offerP.name+' ×'+offerP.q+' 획득');
                loadTrades();
              }
            } catch(e) {}
          })();
        }
      } else if (def > atk) {
        // ── 강탈 실패: 내 아이템 2개 → 등록자에게 이첩 ──
        defEl.classList.add('win'); atkEl.classList.add('lose');
        resEl.textContent = '강탈 실패! 아이템 2개 압수...'; resEl.classList.add('lose');
        (async function() {
          try {
            var inv = getInv();
            var lost = [];
            // 랜덤으로 최대 2개 선택
            var available = inv.filter(function(x){ return x.q > 0; });
            for (var i = 0; i < 2 && available.length > 0; i++) {
              var idx = Math.floor(Math.random() * available.length);
              var item = available[idx];
              removeFromInv(item.n, 1);
              lost.push(item.n);
              available.splice(idx, 1);
            }
            renderInv();
            if (typeof saveInvToDB === 'function') saveInvToDB();
            // 등록자에게 압수 아이템 전달 알림
            var lostStr = lost.join(', ') || '없음';
            if (robTargetAuthorTag) {
              sbReq('POST', 'notes', {
                from_call: '⚠ 거래소',
