let tagBannerTimer=null;

function showTagBanner(from,msg,source){
  const sourceLabels={notes:'📱 쪽지',board:'📋 게시판',comment:'💬 댓글'};
  const sourceLabel=sourceLabels[source]||'📡 알림';
  $('tag-banner-source').textContent=sourceLabel;
  $('tag-banner-title').textContent=`${from}님이 나를 태그했습니다`;
  $('tag-banner-sub').textContent=msg;
  $('tag-banner').classList.add('show');
  playS('alert');
  if(tagBannerTimer)clearTimeout(tagBannerTimer);
  tagBannerTimer=setTimeout(hideTagBanner,7000);
}

function hideTagBanner(){
  $('tag-banner').classList.remove('show');
  if(tagBannerTimer){clearTimeout(tagBannerTimer);tagBannerTimer=null;}
}

