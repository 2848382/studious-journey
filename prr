let realtimeWS=null;
let realtimeHB=null;

function connectRealtime(){
  const wsUrl=`wss://tyrqydzlyasqlxnjjwol.supabase.co/realtime/v1/websocket?apikey=${SB_KEY}&vsn=1.0.0`;
  try{
    realtimeWS=new WebSocket(wsUrl);
    realtimeWS.onopen=()=>{
      realtimeHB=setInterval(()=>{
        if(realtimeWS&&realtimeWS.readyState===1)
          realtimeWS.send(JSON.stringify({topic:'phoenix',event:'heartbeat',payload:{},ref:null}));
      },30000);
      // notes 구독 (쪽지·공지·보급 기록)
      realtimeWS.send(JSON.stringify({
        topic:'realtime:public:notes',event:'phx_join',
        payload:{config:{broadcast:{self:true},presence:{key:''},
          postgres_changes:[{event:'*',schema:'public',table:'notes'}]}},
        ref:'1'
      }));
      // trades 구독 (거래소 실시간)
      realtimeWS.send(JSON.stringify({
        topic:'realtime:public:trades',event:'phx_join',
        payload:{config:{broadcast:{self:true},presence:{key:''},
          postgres_changes:[{event:'*',schema:'public',table:'trades'}]}},
        ref:'2'
      }));
      // profiles 구독 (인벤토리 크로스 디바이스)
      realtimeWS.send(JSON.stringify({
        topic:'realtime:public:profiles',event:'phx_join',
        payload:{config:{broadcast:{self:true},presence:{key:''},
          postgres_changes:[{event:'UPDATE',schema:'public',table:'profiles'}]}},
        ref:'3'
      }));
    };
    realtimeWS.onmessage=e=>{
      try{
        const msg=JSON.parse(e.data);
        const ev=msg.event;
        if(ev==='postgres_changes'||ev==='INSERT'||ev==='UPDATE'||ev==='DELETE'){
          const rec=msg.payload&&(msg.payload.record||msg.payload.new);
          const tbl=msg.topic||'';
          if(tbl.includes('notes')&&rec) handleRealtimeNote(rec);
          if(tbl.includes('trades')) loadTrades();
          if(tbl.includes('profiles')&&rec&&currentUser&&rec.tag===currentUser.tag){
            if(rec.inv_data){
              localStorage.setItem('vx24_inv',rec.inv_data);
              renderInv();
            }
          }
        }
      }catch(ex){}
    };
    realtimeWS.onclose=()=>{
      clearInterval(realtimeHB);
      setTimeout(connectRealtime,6000);
    };
    realtimeWS.onerror=()=>{};
  }catch(ex){}
}

function handleRealtimeNote(note){
  if(!currentUser)return;
  // 탭 공지 실시간 갱신
  if(note.from_call&&note.from_call.startsWith('__NOTICE_')){
    loadAllTabNotices();
    return;
  }
  loadNotes();
  const myTag=currentUser.tag;
  const toMe=note.to_call===myTag||note.to_call===currentUser.name;
  if(toMe&&note.from_call&&!note.from_call.includes(myTag)){
