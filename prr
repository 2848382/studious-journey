function queueTrade(tradeData) {
  const queue = JSON.parse(localStorage.getItem('vx24_trade_queue') || '[]');
  queue.push({ ...tradeData, queued_at: Date.now() });
  localStorage.setItem('vx24_trade_queue', JSON.stringify(queue));
