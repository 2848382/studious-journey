async function masterResetEC(){
  const tagInput=$('m-ec-reset-tag');
  if(!tagInput)return;
  const tag=tagInput.value.trim().replace(/^@/,'');
  if(!tag){showToast('태그를 입력하세요');return;}
  if(!confirm('['+tag+'] 플레이어의 긴급연락처를 초기화하시겠습니까?\n이 작업은 되돌릴 수 없습니다.'))return;
  try{
    await sbReq('PATCH','profiles?tag=eq.'+encodeURIComponent(tag),{ec_data:null});
    tagInput.value='';
    addMLog('EC 초기화: @'+tag);
    showToast('✅ @'+tag+' 긴급연락처 초기화');
    masterLoadEC();
  }catch(e){
    const msg=(e&&e.message)?e.message:'오류';
    if(msg.includes('Could not find')||msg.includes('ec_data')||msg.includes('column')){
      showMasterSqlNotice();
    } else {
      showToast('초기화 실패: '+msg);
    }
  }
}

