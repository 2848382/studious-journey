    if (tick > 15) {
      clearInterval(anim);
      atkEl.classList.remove('rolling');
      defEl.classList.remove('rolling');
      var atk = parseInt(atkEl.textContent) || Math.ceil(Math.random() * 20);
      var def = parseInt(defEl.textContent) || Math.ceil(Math.random() * 20);
