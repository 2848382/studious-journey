async function submitPost(){
  const cat=$('wcat').value,auth=currentUser?currentUser.name:'익명',title=$('wtit').value.trim(),body=$('wbod').value.trim();
  if(!title||!body)return;
  if(chkBan(title+' '+body))return;
  const lockChk=$('w-lock-chk');
  const locked=lockChk&&lockChk.checked;
  const lockpw=locked?($('w-lock-pw').value.trim()||''):'';
  try{
    await sbReq('POST','posts',{
      cat,title,body,auth,
      author_tag:currentUser?currentUser.tag:'',
      pin:false,cen:false,locked,lockpw,
      cmts:[],
      created_at:new Date().toISOString()
    });
    closeMo('mo-write');
    $('wtit').value='';$('wbod').value='';
    if(lockChk)lockChk.checked=false;
    $('w-lock-pw-area').style.display='none';
    await loadPostsFromDB();
    buildSide();renderBoard();
    // @태그 알림
    const tagMatches=(title+' '+body).match(/@([a-zA-Z0-9_]+)/g);
    if(tagMatches&&currentUser){
      const uniqueTags=[...new Set(tagMatches.map(t=>t.substring(1)))];
      uniqueTags.forEach(taggedUser=>{
        if(taggedUser===currentUser.tag)showTagBanner(auth,'게시글에서 @'+taggedUser+' 태그됨','board');
        else saveMentionNotif(taggedUser,auth,title,'board');
      });
    }
    markQuestAct('post'); // 퀘스트: 게시판 글 작성 완료 보고
    playS('loot');showToast('✓ 등록 완료');
  }catch(e){showToast('등록 실패');}
}

async function saveMentionNotif(toTag,fromName,context,source){
  // 태그 알림을 notes 테이블에 저장 (to_call을 태그된 유저로 설정)
  try{
    await sbReq('POST','notes',{
      from_call:`${fromName} [${source}멘션]`,
      to_call:toTag,
      body:`"${context.substring(0,15)}..." 에서 태그됨`,
      type:'urgent'
    });
  }catch(e){}
}

function chkBan(t){
  const l=t.toLowerCase().replace(/[\s\-_.]/g,'');
  for(const w of BAN){if(l.includes(w.replace(/[\s\-_.]/g,''))){$('cov-d').textContent=w.toUpperCase();$('cov').classList.add('show');playS('alert');return true}}
  return false;
}

