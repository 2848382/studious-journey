  try{
 
    // quarantine_count 증가
    const profileData=await sbReq('GET','profiles?tag=eq.'+encodeURIComponent(tag));
    if(!profileData||!profileData.length){showToast('유저를 찾을 수 없습니다');return;}
    const profile=profileData[0];
    const newCount=(profile.quarantine_count||0)+1;
    await sbReq('PATCH','profiles?tag=eq.'+encodeURIComponent(tag),{quarantine_count:newCount});
    localStorage.setItem('vx24_rep_'+tag,'1');
    playS('alert');
    if(newCount>=3){
      showToast('⚠ '+name+' 격리 처리됨!');
      triggerQuarantineAlert(name,tag);
     
      // 자동: 격리 쪽지 발송
      sbReq('POST','notes',{from_call:'🔴 통합사령부',to_call:tag,body:name+'님은 신고 3건 누적으로 즉시 격리 처리되었습니다. 격리 구역으로 이동하십시오.',type:'urgent',created_at:new Date().toISOString()}).catch(()=>{});
      addMLog('[자동] 격리 쪽지 → '+name+'(@'+tag+')');
    } else {
      showToast('신고 접수 ('+newCount+'/3)');
  
      // 자동: 경고 쪽지
      sbReq('POST','notes',{from_call:'⚠ 감염통제센터',to_call:tag,body:'[경고 '+newCount+'/3] 감염 의심 신고가 접수되었습니다. 3회 누적 시 자동 격리됩니다.',type:'urgent',created_at:new Date().toISOString()}).catch(()=>{});
