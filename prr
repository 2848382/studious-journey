function renderBoard(){
  const q=($('bsearch').value||'').toLowerCase();
  if(q) bPage=1; // 검색 시 1페이지로
  let f=bCat==='all'?posts:posts.filter(p=>p.cat===bCat);
  if(q)f=f.filter(p=>(p.title||'').toLowerCase().includes(q));
  // 고정글 상단, 나머지 최신순
  const pinned=f.filter(p=>p.pin);
  const normal=f.filter(p=>!p.pin&&!p.cen);
  const cen=f.filter(p=>p.cen);
  // 페이지네이션은 일반글에만 적용
  const totalNormal=normal.length;
  const totalPages=Math.max(1,Math.ceil(totalNormal/BPER));
  if(bPage>totalPages)bPage=totalPages;
  const pageNormal=normal.slice((bPage-1)*BPER, bPage*BPER);
  const sorted=[...pinned,...pageNormal,...cen];
  const el=$('blist');
  el.innerHTML='';

  if(sorted.length===0&&pinned.length===0){
    el.innerHTML='<div style="padding:20px;text-align:center;color:var(--txf);font-family:var(--m);font-size:11px">게시글 없음</div>';
    renderBoardPager(0,1);
    return;
  }

  sorted.forEach(p=>{
    const row=document.createElement('div');
    row.className='ptr'+(p.cen?' cen':'');
    if(!p.cen) row.onclick=()=>{if(p.locked){pendingLP=p;openMo('mo-boardpw')}else openDet(p.id)};
    const badge=p.cen
      ?'<span class="pb pbg">삭제</span>'
      :`<span class="pb ${CB[p.cat]||'pbg'}">${CL[p.cat]||p.cat}</span>`;
    const cmts=Array.isArray(p.cmts)?p.cmts:[];
    const cmtBadge=cmts.length?`<span class="ptr-cmt">💬${cmts.length}</span>`:'';
    const pin=p.pin?'<span class="ppin">[고정]</span>':'';
    row.innerHTML=
      `<span class="ptr-num">${p.pin?'📌':(typeof p.id==='number'?p.id:'—')}</span>`+
      `<span class="ptr-cat">${badge}</span>`+
      `<span class="ptr-title">${pin}<span class="ptt${p.pin?' pin':''}">${renderTagsInText(p.title||'')}</span>${cmtBadge}</span>`+
      `<span class="ptr-auth${p.adm?' adm':''}">${p.auth||''}</span>`;
    el.appendChild(row);
  });
  renderBoardPager(totalNormal, totalPages);
}

function renderBoardPager(total, totalPages){
  let pg=$('board-pager');
  if(!pg){
    pg=document.createElement('div');
    pg.id='board-pager';
    pg.className='board-pager';
    const blist=$('blist');
    blist.parentNode.insertBefore(pg, blist.nextSibling);
  }
  if(totalPages<=1){pg.innerHTML='';return;}
  let html='';
  // 이전 버튼
  html+=`<button class="bpg-btn${bPage===1?' dis':''}" onclick="if(bPage>1){bPage--;renderBoard()}" ${bPage===1?'disabled':''}>‹</button>`;
  // 페이지 번호 (최대 5개)
  const start=Math.max(1,bPage-2);
  const end=Math.min(totalPages,start+4);
  for(let i=start;i<=end;i++){
    html+=`<button class="bpg-btn${i===bPage?' on':''}" onclick="bPage=${i};renderBoard()">${i}</button>`;
  }
  // 다음 버튼
  html+=`<button class="bpg-btn${bPage===totalPages?' dis':''}" onclick="if(bPage<${totalPages}){bPage++;renderBoard()}" ${bPage===totalPages?'disabled':''}>›</button>`;
  html+=`<span class="bpg-info">${total}개 / ${totalPages}p</span>`;
  pg.innerHTML=html;
}

