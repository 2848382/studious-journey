async function masterDeleteFromDetail(id){
  if(!masterUnlocked){showToast('마스터 권한 필요');return;}
  const p=posts.find(x=>x.id===id);
  if(!p)return;
  if(!confirm('['+((p.title||'').substring(0,14))+'...] 완전 삭제할까요?\n복구 불가합니다.'))return;
  try{
    await sbReq('DELETE','posts?id=eq.'+id);
    closeMo('mo-detail');
    await loadPostsFromDB();
    buildSide();renderBoard();
    addMLog('게시글 삭제: #'+id);
    showToast('🗑 삭제 완료');
    playS('alert');
  }catch(e){
    // Supabase RLS로 직접 DELETE 차단 시 cen 처리로 fallback
    try{
      await sbReq('PATCH','posts?id=eq.'+id,{cen:true});
      closeMo('mo-detail');
      await loadPostsFromDB();
      buildSide();renderBoard();
      addMLog('게시글 검열처리: #'+id);
      showToast('🗑 검열 처리됨');
    }catch(e2){showToast('삭제 실패');}
  }
}

async function addCmt(){
  const t=$('cmt-in').value.trim();
  if(!t||!currentUser)return;
  if(chkBan(t))return;
  const p=posts.find(x=>x.id===curDet);
  if(!p)return;
  const newCmts=[...(p.cmts||[]),{a:currentUser.name,t:t.replace(/</g,'&lt;'),ts:new Date().toISOString()}];
  try{
    await sbReq('PATCH','posts?id=eq.'+p.id,{cmts:newCmts});
    p.cmts=newCmts;
    const tagMatches=t.match(/@([a-zA-Z0-9_]+)/g);
    if(tagMatches){
      tagMatches.forEach(tm=>{
        const taggedUser=tm.substring(1);
        if(taggedUser===currentUser.tag)showTagBanner(currentUser.name,'댓글에서 @'+taggedUser+' 태그됨','board');
        else saveMentionNotif(taggedUser,currentUser.name,p.title,'board');
      });
    }
    openDet(curDet);playS('click');
  }catch(e){showToast('댓글 등록 실패');}
}

