.idp-close:hover { color:var(--w); border-color:rgba(255,255,255,0.25); }
.idp-desc { font-size:12px; color:var(--txd); line-height:1.75; margin-bottom:10px; }
.idp-eff-label { font-family:var(--m); font-size:8px; color:var(--txf); letter-spacing:.12em; text-transform:uppercase; margin-bottom:4px; }
.idp-eff { font-family:var(--m); font-size:11px; color:var(--grn); margin-bottom:10px; }
.idp-effect { font-family:var(--m); font-size:10px; color:var(--acl); padding:7px 10px; background:rgba(240,80,80,0.08); border:1px solid rgba(240,80,80,0.22); border-radius:2px; text-align:center; cursor:pointer; }
.idp-effect-locked { font-family:var(--m); font-size:10px; color:var(--txf); padding:7px 10px; background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.08); border-radius:2px; text-align:center; }

/* ── inventory upgrades ───────────────────────────────────────── */
.inv-tag { font-family:var(--m); font-size:7px; letter-spacing:.08em; margin-top:1px; opacity:.85; }
.inv-use-hint { font-family:var(--m); font-size:7px; color:var(--grn); margin-top:2px; }
.inv-battery-ready { font-family:var(--m); font-size:7px; color:var(--ylw); margin-top:2px; animation:timerBlink 1.5s infinite; }
.inv-rarity-bar { position:absolute; bottom:0; left:0; right:0; height:2px; opacity:0.5; border-radius:0 0 2px 2px; }
.inv-slot { position:relative; overflow:hidden; transition:all .2s; }
.inv-slot:hover { transform:translateY(-3px); box-shadow:0 6px 20px rgba(0,0,0,0.55); }
.inv-slot:active { transform:scale(0.95); }

/* ── supply page upgrades ─────────────────────────────────────── */
.sup-items-grid {
  display:grid; grid-template-columns:repeat(3, 1fr); gap:8px; margin-bottom:10px;
}
.sup-item-card {
  background:rgba(20,16,28,0.82);
  border:1px solid rgba(255,255,255,0.08);
  border-top:1px solid rgba(255,255,255,0.13);
  padding:10px 8px;
  text-align:center;
  backdrop-filter:blur(8px);
  transition:all .18s;
}
.sup-item-card:hover { border-color:rgba(240,80,80,0.25); transform:translateY(-2px); }
.sup-item-icon { font-size:22px; margin-bottom:4px; }
.sup-item-name { font-size:10px; font-weight:600; color:var(--w); }
.sup-item-qty  { font-family:var(--m); font-size:8px; color:var(--txf); margin-top:2px; }
.sup-battery-tip {
  font-family:var(--m); font-size:9px; color:var(--txd);
  padding:8px 12px; border:1px solid rgba(245,200,66,0.18);
  background:rgba(245,200,66,0.05); border-radius:2px;
  margin-top:4px; letter-spacing:.03em;
}
.sup-btn {
  display:inline-flex; align-items:center; gap:8px;
  background:rgba(240,80,80,0.16);
  border:1px solid rgba(240,80,80,0.45);
  color:var(--acl);
  font-family:var(--m); font-size:11px; font-weight:700;
  letter-spacing:.08em; text-transform:uppercase;
  padding:12px 32px; cursor:pointer;
  transition:all .2s;
  border-radius:2px;
}
.sup-btn:hover { background:rgba(240,80,80,0.28); box-shadow:0 0 24px rgba(240,80,80,0.22); }
.sup-btn:active { transform:scale(0.96); }
.sup-ok { font-family:var(--m); font-size:12px; color:var(--grn); letter-spacing:.08em; }
.kit-it {
  display:flex; align-items:center; gap:8px;
  padding:6px 10px;
  background:var(--bgi); border:1px solid var(--bd);
  font-size:12px; color:var(--tx);
  min-width:0; overflow:hidden;
  box-sizing:border-box;
}
.kit-it-icon { font-size:18px; flex-shrink:0; }
.kit-it-name { flex:1; min-width:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
.kit-q { font-family:var(--m); font-size:10px; color:var(--ylw); flex-shrink:0; margin-left:auto; }

/* ── loot particle ────────────────────────────────────────────── */
.loot-particle {
  position:fixed; width:6px; height:6px; border-radius:50%; z-index:9999;
  pointer-events:none;
  animation:lootPop 1.1s ease-out forwards;
}
@keyframes lootPop {
  0%   { opacity:1; transform:translate(0,0) scale(1); }
  100% { opacity:0; transform:translate(calc((var(--rx,0)*60px) - 30px), -80px) scale(0.2); }
}

/* ── board font fix ───────────────────────────────────────────── */
.bsi { font-family:var(--f) !important; letter-spacing:var(--ls) !important; }

/* ── PWA offline badge ────────────────────────────────────────── */
#pwa-offline-badge {
  font-family:var(--m); font-size:8px;
  animation:timerBlink 2s infinite;
}

/* ── game HUD scanlines on cards ─────────────────────────────── */
.card::after, .blay::after, .dp::after {
  content:'';
  position:absolute; inset:0;
  background:repeating-linear-gradient(0deg, transparent, transparent 3px, rgba(255,255,255,0.012) 3px, rgba(255,255,255,0.012) 4px);
  pointer-events:none; z-index:0; border-radius:inherit;
}
.card > *, .blay > *, .dp > * { position:relative; z-index:1; }

/* ── topbar glow pulse ────────────────────────────────────────── */
@keyframes topbarGlow {
  0%,100% { box-shadow:0 1px 0 rgba(240,80,80,0.10), 0 4px 28px rgba(0,0,0,0.70); }
  50%      { box-shadow:0 1px 0 rgba(240,80,80,0.20), 0 4px 28px rgba(0,0,0,0.70); }
}
.topbar { animation:topbarGlow 4s ease-in-out infinite; }

/* ── mission card glow ────────────────────────────────────────── */
.mission-card.m-active { box-shadow:inset 3px 0 0 var(--ylw), 0 0 14px rgba(245,200,66,0.08) !important; }
.mission-card.m-done   { box-shadow:inset 3px 0 0 var(--grn), 0 0 14px rgba(56,232,120,0.08) !important; }

/* ── zone card safe/danger ────────────────────────────────────── */
.zc.safe   { border-top-color:rgba(56,232,120,0.35) !important; }
.zc.danger { border-top-color:rgba(240,80,80,0.40) !important; }
.zc.biohazard { border-top-color:rgba(192,122,255,0.40) !important; }

/* ── tab on top indicator ─────────────────────────────────────── */
.tab.on::before {
  content:''; position:absolute; top:0; left:0; right:0; height:2px;
  background:var(--acl); box-shadow:0 0 8px rgba(240,80,80,0.70);
}

/* ── dice roll shake ──────────────────────────────────────────── */
.dn.roll { animation:diceShake .4s cubic-bezier(.36,.07,.19,.97); }
@keyframes diceShake {
  10%,90%  { transform:translate(-1px,0) rotate(-1deg); }
  20%,80%  { transform:translate(2px,0) rotate(2deg); }
  30%,50%,70% { transform:translate(-2px,0) rotate(-2deg); }
  40%,60%  { transform:translate(2px,0) rotate(2deg); }
}

/* ── board category font fix ──────────────────────────────────── */
.bsi, .ptbl-head span, .pb {
  font-family: var(--f) !important;
}
.bsi {
  letter-spacing: var(--ls) !important;
  font-size: 12px !important;
  color: var(--txd) !important;
  padding: 10px 14px !important;
  border-left: 2px solid transparent !important;
  transition: all .15s !important;
  cursor: pointer;
}
.bsi:hover { color:var(--w) !important; background:rgba(255,255,255,0.035) !important; }
.bsi.on   { color:var(--w) !important; background:rgba(240,80,80,0.09) !important; border-left-color:var(--acl) !important; }

/* ── iu-confirm-btn style ─────────────────────────────────────── */
#iu-confirm-btn {
  min-width:100px;
  font-family:var(--m) !important;
  font-size:9px !important;
  letter-spacing:.06em !important;
}


/* ── 선물 팝업 ─────────────────────────────────────────────── */
.gift-popup { display:none; position:fixed; inset:0; z-index:5100; background:rgba(0,0,0,0.75); align-items:center; justify-content:center; padding:16px; }
.gift-popup.show { display:flex; }
.gift-box { width:min(300px,90vw); background:rgba(16,12,22,0.99); border:1px solid rgba(255,255,255,0.10); border-top:2px solid var(--grn); padding:18px; animation:fu .22s; box-shadow:0 20px 60px rgba(0,0,0,0.90); }
.gift-header { display:flex; align-items:center; gap:10px; margin-bottom:14px; }
.gift-icon { font-size:28px; line-height:1; }
.gift-title { font-size:13px; font-weight:700; color:var(--w); }
.gift-sub { font-family:var(--m); font-size:8px; color:var(--txf); margin-top:2px; }
.gift-field-label { font-family:var(--m); font-size:8px; color:var(--txf); letter-spacing:.10em; text-transform:uppercase; margin-bottom:4px; }
.gift-sel { width:100%; background:rgba(10,10,18,0.92); border:1px solid rgba(255,255,255,0.10); color:var(--tx); font-family:var(--f); font-size:12px; padding:7px 10px; margin-bottom:12px; outline:none; }
.gift-qty-row { display:flex; align-items:center; gap:10px; margin-bottom:14px; }
.gift-qty-btn { width:30px; height:30px; background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.12); color:var(--tx); font-size:16px; cursor:pointer; transition:all .15s; }
.gift-qty-btn:hover { background:rgba(255,255,255,0.12); }
.gift-qty-disp { font-family:var(--o); font-size:18px; font-weight:700; color:var(--grn); min-width:32px; text-align:center; }
.gift-send-btn { width:100%; background:rgba(56,232,120,0.14); border:1px solid rgba(56,232,120,0.40); color:var(--grn); font-family:var(--m); font-size:11px; font-weight:700; letter-spacing:.08em; padding:11px; cursor:pointer; transition:all .18s; }
.gift-send-btn:hover { background:rgba(56,232,120,0.26); box-shadow:0 0 18px rgba(56,232,120,0.20); }
.idp-gift-btn { font-family:var(--m); font-size:10px; color:var(--grn); padding:7px 10px; background:rgba(56,232,120,0.08); border:1px solid rgba(56,232,120,0.25); border-radius:2px; text-align:center; cursor:pointer; margin-top:6px; transition:all .15s; }
.idp-gift-btn:hover { background:rgba(56,232,120,0.15); }
.idp-gift-used { font-family:var(--m); font-size:9px; color:var(--txf); padding:5px 10px; background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.06); border-radius:2px; text-align:center; margin-top:6px; }

/* ── 활동 통계 대시보드 ─────────────────────────────────────── */
.act-chart-title { font-family:var(--m); font-size:8px; color:var(--txf); letter-spacing:.10em; text-transform:uppercase; margin-bottom:6px; }
.act-bar-wrap { display:flex; align-items:flex-end; gap:4px; height:80px; padding-bottom:20px; position:relative; }
.act-bar-col { display:flex; flex-direction:column; align-items:center; flex:1; gap:2px; justify-content:flex-end; }
.act-bar-fill { width:100%; border-radius:2px 2px 0 0; min-height:4px; transition:height .4s; }
.act-bar-val { font-family:var(--m); font-size:8px; color:var(--txd); }
.act-bar-day { font-family:var(--m); font-size:7px; color:var(--txf); }
.act-player-list { display:flex; flex-direction:column; gap:4px; margin-top:6px; }
.act-player-row { display:flex; align-items:center; gap:8px; padding:7px 10px; background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.05); }
.act-rank { font-family:var(--o); font-size:11px; font-weight:700; min-width:24px; }
.act-pname { flex:1; font-size:11px; color:var(--tx); }
.act-pbadges { display:flex; gap:5px; }
.act-badge { font-family:var(--m); font-size:8px; padding:2px 6px; border-radius:2px; }
.act-badge.sup { background:rgba(240,80,80,0.12); color:var(--acl); }
.act-badge.tr  { background:rgba(245,200,66,0.10); color:var(--ylw); }


/* ── 이용약관 모달 ──────────────────────────────────────────── */
#tos-modal { animation: none; }
.tos-box {
  width: min(480px, 94vw);
  max-height: 90vh;
  background: rgba(10,8,16,0.99);
  border: 1px solid rgba(255,255,255,0.10);
  border-top: 2px solid var(--acl);
  display: flex; flex-direction: column;
  box-shadow: 0 28px 80px rgba(0,0,0,0.95), 0 0 40px rgba(185,28,28,0.08);
  animation: fu .25s;
}
.tos-header {
  padding: 14px 18px;
  border-bottom: 1px solid rgba(255,255,255,0.07);
  background: rgba(0,0,0,0.35);
  flex-shrink: 0;
}
.tos-body {
  flex: 1; overflow-y: auto; padding: 16px 18px;
  scroll-behavior: smooth;
}
.tos-body::-webkit-scrollbar { width: 3px; }
.tos-body::-webkit-scrollbar-thumb { background: rgba(240,80,80,0.3); }
.tos-section {
  margin-bottom: 16px;
  padding-bottom: 14px;
  border-bottom: 1px solid rgba(255,255,255,0.05);
}
.tos-last { border-bottom: none; }
.tos-sec-title {
  font-family: var(--m);
  font-size: 9px;
  font-weight: 700;
  color: var(--acl);
  letter-spacing: .10em;
  text-transform: uppercase;
  margin-bottom: 6px;
}
.tos-sec-body {
  font-size: 11.5px;
  color: var(--txd);
  line-height: 1.85;
}
.tos-footer {
  padding: 12px 18px 14px;
  border-top: 1px solid rgba(255,255,255,0.07);
  background: rgba(0,0,0,0.30);
