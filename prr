      const ts=`${String(dt.getMonth()+1).padStart(2,'0')}.${String(dt.getDate()).padStart(2,'0')} ${String(dt.getHours()).padStart(2,'0')}:${String(dt.getMinutes()).padStart(2,'0')}`;
      const badgeHtml=n.type==='secret'?'<span class="home-msg-badge badge-secret" style="font-size:9px">비밀</span>':n.type==='urgent'?'<span class="home-msg-badge badge-urgent" style="font-size:9px">긴급</span>':'';
