        const sql = `CREATE TABLE IF NOT EXISTS trades (\n  id bigint generated always as identity primary key,\n  offer text, want text, note text,\n  author_name text, author_tag text,\n  status text default 'open',\n  accepted_by text, robbed_by text,\n  created_at timestamptz default now()\n);\nALTER TABLE trades ENABLE ROW LEVEL SECURITY;\nCREATE POLICY "allow all" ON trades FOR ALL USING (true) WITH CHECK (true);`;
        wrap.innerHTML = `<div style="padding:14px;border:1px solid rgba(185,28,28,.3);background:rgba(185,28,28,.06);font-family:var(--m);font-size:10px;color:var(--acl)">
          <div style="font-weight:700;margin-bottom:8px">⚠ trades 테이블 설정 필요</div>
