<script>
  // loadTrades가 선언되기 전에 버튼이 눌리거나 afterLogin에서 호출돼도 크래시 방지
  window.loadTrades = window.loadTrades || function () {
    console.warn('[guard] loadTrades called before definition; ignored.');
  };

// ============================================================
// TRADE (물자 교환소)
// ============================================================
let robTargetId = null;
let tradePollInterval = null;
let tradePage = 1;
const TRADE_PER_PAGE = 10;

async function loadTrades(page) {
  var wrap = $('trade-list');
  var pager = $('trade-pager');
  if (!wrap) return;
  if (page !== undefined) tradePage = page;
  wrap.innerHTML = '<div style="padding:20px;text-align:center;font-family:var(--m);font-size:10px;color:var(--txf)">로딩 중...</div>';
  try {
    var data = await sbReq('GET', 'trades?order=created_at.desc&limit=200', null);
    if (!data || data.length === 0) {
      wrap.innerHTML = '<div style="padding:20px;text-align:center;font-family:var(--m);font-size:10px;color:var(--txf)">등록된 거래가 없습니다.</div>';
      if (pager) pager.innerHTML = '';
      return;
    }
    // 정렬: open 거래 먼저, 완료/강탈/만료는 하단
    var open = data.filter(function(t){ return t.status === 'open'; });
    var done = data.filter(function(t){ return t.status !== 'open'; });
    var sorted = open.concat(done);

    var total = sorted.length;
    var totalPages = Math.max(1, Math.ceil(total / TRADE_PER_PAGE));
    if (tradePage > totalPages) tradePage = totalPages;
    var start = (tradePage - 1) * TRADE_PER_PAGE;
    var pageData = sorted.slice(start, start + TRADE_PER_PAGE);

    wrap.innerHTML = pageData.map(function(t){ return renderTradeCard(t); }).join('');
    renderTradePager(totalPages, total);
  } catch(e) {
    var msg = (e && e.message) ? e.message : (typeof e === 'string' ? e : JSON.stringify(e));
    var isMissing = msg.includes('Could not find') || msg.includes('does not exist') || msg.includes('relation "trades"');
    if (isMissing) {
      wrap.innerHTML = '<div style="padding:16px;border:1px solid rgba(185,28,28,.3);background:rgba(185,28,28,.06);font-family:var(--m);font-size:10px;color:var(--acl)">⚠ 거래소 테이블 설정 필요<br><span style="color:var(--txd);font-size:9px;display:block;margin-top:6px">Supabase SQL Editor에서 trades 테이블을 생성하세요.</span></div>';
    } else {
      wrap.innerHTML = '<div style="padding:16px;border:1px solid rgba(185,28,28,.3);background:rgba(185,28,28,.06);font-family:var(--m);font-size:10px;color:var(--acl)">⚠ 거래소 로드 실패<br><span style="color:var(--txd);font-size:9px;display:block;margin-top:6px;word-break:break-all">' + msg + '</span><button onclick="loadTrades()" style="margin-top:8px;padding:4px 12px;background:none;border:1px solid var(--bd);color:var(--txd);font-family:var(--m);font-size:9px;cursor:pointer">↺ 다시 시도</button></div>';
    }
    if (pager) pager.innerHTML = '';
  }
}

function renderTradePager(totalPages, total) {
  var pager = $('trade-pager');
  if (!pager) return;
  if (totalPages <= 1) { pager.innerHTML = '<span style="color:var(--txf)">총 ' + total + '건</span>'; return; }
  var html = '<span style="color:var(--txf);margin-right:4px">총 ' + total + '건</span>';
  html += '<button onclick="loadTrades(1)" style="background:none;border:1px solid var(--bd);color:var(--txd);padding:3px 7px;font-family:var(--m);font-size:9px;cursor:pointer" ' + (tradePage===1?'disabled':'') + '>«</button>';
  html += '<button onclick="loadTrades(' + (tradePage-1) + ')" style="background:none;border:1px solid var(--bd);color:var(--txd);padding:3px 7px;font-family:var(--m);font-size:9px;cursor:pointer" ' + (tradePage===1?'disabled':'') + '>‹</button>';
  html += '<span style="color:var(--tx);padding:0 6px">' + tradePage + ' / ' + totalPages + '</span>';
  html += '<button onclick="loadTrades(' + (tradePage+1) + ')" style="background:none;border:1px solid var(--bd);color:var(--txd);padding:3px 7px;font-family:var(--m);font-size:9px;cursor:pointer" ' + (tradePage===totalPages?'disabled':'') + '>›</button>';
  html += '<button onclick="loadTrades(' + totalPages + ')" style="background:none;border:1px solid var(--bd);color:var(--txd);padding:3px 7px;font-family:var(--m);font-size:9px;cursor:pointer" ' + (tradePage===totalPages?'disabled':'') + '>»</button>';
  pager.innerHTML = html;
}
function startTradePoll() {
  if (tradePollInterval) return;
  loadTrades();
  tradePollInterval = setInterval(loadTrades, 12000);
}

function stopTradePoll() {
  if (tradePollInterval) { clearInterval(tradePollInterval); tradePollInterval = null; }
}

