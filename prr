// ── 수락: 자동 인벤토리 교환 ────────────────────────────────
async function acceptTradeAuto(id) {
  if (!currentUser) { showToast('로그인 필요'); return; }
  try {
    const trades = await sbReq('GET', 'trades?id=eq.'+id+'&select=*&limit=1', null);
    if (!trades || !trades.length) { showToast('거래 정보 없음'); return; }
    var t = trades[0];
    if (t.status !== 'open') { showToast('이미 완료된 거래입니다'); loadTrades(); return; }
    var offerP = parseItemName(t.offer||'');
    var wantP  = parseItemName(t.want||'');
    // 1) DB 상태 업데이트
    await sbReq('PATCH', 'trades?id=eq.'+id, {
      status: 'accepted',
      accepted_by: currentUser.tag,
      accepted_at: new Date().toISOString()
    });
    // 2) 수락자: want 차감 → offer 획득
    removeFromInv(wantP.name, wantP.q);
    addToInv(offerP.name, offerP.icon, offerP.q);
    renderInv();
    if (typeof saveInvToDB === 'function') saveInvToDB();
    // 3) 등록자에게 쪽지 알림 (자동)
    sbReq('POST', 'notes', {
      from_call: '⚔ 거래소',
      to_call: t.author_tag,
      body: '✓ 거래 성사됨\n['+t.offer+'] → ['+t.want+']\n상대방이 수락했습니다. 인벤토리를 확인하세요.',
      type: 'normal',
      created_at: new Date().toISOString()
    }).catch(function(){});
    showToast('✓ 거래 완료! '+offerP.icon+' '+offerP.name+' ×'+offerP.q+' 획득');
    if (typeof playS === 'function') playS('loot');
    if (typeof addMLog === 'function') addMLog('[자동거래] '+currentUser.name+'(수락) ↔ '+t.author_name+': '+t.offer+'⇄'+t.want);
    loadTrades();
  } catch(e) { showToast('수락 실패: '+(e.message||'오류')); }
}

