let pendingUseItem=null;
function openItemUse(name,icon,qty){
  const isBattery=(name==='건전지');
  const isTicket=(name===EXTRA_TICKET_NAME);
  pendingUseItem={name,icon,qty:qty||1,isBattery,isTicket};
  $('iu-icon').textContent=icon;
  $('iu-name').textContent=name;
  if(isBattery){
    $('iu-desc').textContent=`건전지 ${BATTERY_USE_THRESHOLD}개를 소모합니다. 보급품 추가 수령 티켓 1장이 지급됩니다.`;
    $('iu-confirm-btn').textContent=`⚡ ${BATTERY_USE_THRESHOLD}개 교환`;
  } else if(isTicket){
    $('iu-desc').textContent='이 티켓을 사용하면 오늘 보급품을 한 번 더 수령합니다.';
    $('iu-confirm-btn').textContent='🎫 티켓 사용';
  } else {
    $('iu-desc').textContent='사용하시겠습니까?';
    $('iu-confirm-btn').textContent='예';
  }
  $('item-use-popup').classList.add('show');
}
function closeItemUse(){
  $('item-use-popup').classList.remove('show');
  pendingUseItem=null;
}
function confirmUseItem(){
  if(!pendingUseItem)return;
  const{name,icon,isBattery,isTicket}=pendingUseItem;
  const inv=getInv();
  const it=inv.find(x=>x.n===name);
  if(!it){closeItemUse();return;}

  if(isBattery){
    if(it.q < BATTERY_USE_THRESHOLD){
      showToast(`건전지 ${BATTERY_USE_THRESHOLD}개 필요 (현재 ${it.q}개)`);
      closeItemUse();
      return;
    }
    it.q -= BATTERY_USE_THRESHOLD;
    if(it.q <= 0){ const idx=inv.indexOf(it); inv.splice(idx,1); }
    localStorage.setItem('vx24_inv',JSON.stringify(inv));
    addToInv(EXTRA_TICKET_NAME, EXTRA_TICKET_ICON, 1);
    saveInvToDB();
    closeItemUse();
    showToast(`⚡ 건전지 ${BATTERY_USE_THRESHOLD}개 교환 → ${EXTRA_TICKET_ICON} 추가 수령 티켓 획득!`);
    spawnLootParticles();
    playS('loot');
    renderInv();
    return;
  }

  if(isTicket){
    if(it.q>1){it.q--;}else{const idx=inv.indexOf(it);inv.splice(idx,1);}
    localStorage.setItem('vx24_inv',JSON.stringify(inv));
    saveInvToDB();
    closeItemUse();
    showToast('🎫 추가 수령 티켓 사용!');
    claimSup(true);
    renderInv();
    go('supply');
    return;
  }

  if(it.q>1){it.q--;}else{const idx=inv.indexOf(it);inv.splice(idx,1);}
  localStorage.setItem('vx24_inv',JSON.stringify(inv));
  saveInvToDB();
  addHpLog(icon,name,10);
  closeItemUse();
  const hp=$('hp-popup');
  hp.classList.remove('show');
  void hp.offsetWidth;
  hp.classList.add('show');
  setTimeout(()=>hp.classList.remove('show'),1900);
  showToast((icon||'🍽')+' '+name+' 사용 — 체력 +10');
  playS('loot');
  renderInv();
  renderHpLog();
}

