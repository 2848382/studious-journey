<script>
// [A] 레이더 애니메이션 (Radar Sweep)
(function initRadar(){
  var c = document.getElementById('radar-canvas');
  if(!c) return;
  var ctx = c.getContext('2d');
  var W = c.width, H = c.height, cx = W/2, cy = H/2, r = W/2 - 6;
  var angle = 0;
  var blips = [];
  for(var i=0;i<6;i++) blips.push({a:Math.random()*Math.PI*2, d:15+Math.random()*(r-20), label:['▲','◆','●','×'][Math.floor(Math.random()*4)]});

  function draw(){
    ctx.clearRect(0,0,W,H);
    ctx.save(); ctx.beginPath(); ctx.moveTo(cx,cy); ctx.arc(cx,cy,r, angle-Math.PI*0.6, angle); ctx.fillStyle='rgba(0,220,80,.07)'; ctx.fill(); ctx.restore();
    ctx.strokeStyle='rgba(0,255,80,.6)'; ctx.beginPath(); ctx.moveTo(cx,cy); ctx.lineTo(cx+Math.cos(angle)*(r+2), cy+Math.sin(angle)*(r+2)); ctx.stroke();
    angle += 0.025; requestAnimationFrame(draw);
  }
  draw();
})();

// [B] 위협 신호 그래프 (Threat Signal)
(function initThreat(){
  var c = document.getElementById('threat-canvas');
  if(!c) return;
  var ctx = c.getContext('2d');
  var points = [];
  var W = 600, H = 58;
  for(var i=0;i<W;i++) points.push(H/2);
  var t = 0;
  function draw(){
    var cw = c.offsetWidth || W;
    c.width = cw * (window.devicePixelRatio||1);
    c.height = H * (window.devicePixelRatio||1);
    ctx.scale(window.devicePixelRatio||1, window.devicePixelRatio||1);
    ctx.clearRect(0,0,cw,H);
    var v = H/2 + Math.sin(t*0.08)*10 + (Math.random()-0.5)*4;
    points.push(v); if(points.length > cw) points.shift();
    ctx.beginPath(); ctx.moveTo(0, points[0]);
    for(var i=1;i<points.length;i++) ctx.lineTo(i, points[i]);
    ctx.strokeStyle = 'rgba(220,38,38,.8)'; ctx.lineWidth = 1.2; ctx.stroke();
    t++; requestAnimationFrame(draw);
  }
  draw();
})();

// [C] 라디오 파형 (Waveform)
(function initWave(){
  var c = document.getElementById('wave-canvas');
  if(!c) return;
  var ctx = c.getContext('2d');
  var t = 0;
  function draw(){
    var cw = c.offsetWidth || 600;
    c.width = cw * (window.devicePixelRatio||1); c.height = 48 * (window.devicePixelRatio||1);
    ctx.scale(window.devicePixelRatio||1, window.devicePixelRatio||1);
    ctx.clearRect(0,0,cw,48);
    ctx.beginPath(); ctx.moveTo(0, 24);
    for(var x=0;x<cw;x++) ctx.lineTo(x, 24 + Math.sin(x*0.05+t*0.12)*8);
    ctx.strokeStyle = 'rgba(0,255,80,0.5)'; ctx.stroke();
    t++; requestAnimationFrame(draw);
  }
  draw();
})();

// [D] 커스텀 조준경 마우스 트래킹
(function(){
  var cur = document.getElementById('vx-cursor');
  if(!cur) return;
  var mx=0, my=0, cx=0, cy=0;
  document.addEventListener('mousemove', function(e){ mx = e.clientX; my = e.clientY; });
  function animate(){
    cx += (mx - cx) * 0.2; cy += (my - cy) * 0.2;
    cur.style.left = cx + 'px'; cur.style.top = cy + 'px';
    requestAnimationFrame(animate);
  }
  animate();
})();

// [E] 서비스 워커 등록
if('serviceWorker' in navigator){
  window.addEventListener('load', function(){
    navigator.serviceWorker.register('sw.js').catch(function(){});
  });
}
</script>


