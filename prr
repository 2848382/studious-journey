/* ════════════════════════════════════════════════════════════════
   2. 플레이어 활동 통계 (7일) — 마스터 대시보드
   ════════════════════════════════════════════════════════════════ */
async function loadActivityDashboard() {
  const el = document.getElementById('m-activity-dash');
  if (!el) return;
  el.innerHTML = '<div style="font-family:var(--m);font-size:9px;color:var(--txf)">조회 중...</div>';

  try {
    const today = new Date();
    const days = Array.from({length:7}, (_,i) => {
      const d = new Date(today);
      d.setDate(d.getDate() - (6 - i));
      return d.toISOString().slice(0,10).replace(/-/g,'.');
    });
    const isoFrom = new Date(today);
    isoFrom.setDate(isoFrom.getDate() - 6);
    isoFrom.setHours(0,0,0,0);

    const [supplyRows, tradeRows, noteRows, profiles] = await Promise.all([
      sbReq('GET', 'notes?from_call=eq.__SUPPLY__&created_at=gte.' + isoFrom.toISOString() + '&select=to_call,body&limit=500').catch(()=>[]),
      sbReq('GET', 'trades?created_at=gte.' + isoFrom.toISOString() + '&select=created_at,author_tag,status&limit=500').catch(()=>[]),
      sbReq('GET', 'notes?from_call=eq.__LOGIN__&created_at=gte.' + isoFrom.toISOString() + '&select=to_call,body&limit=1000').catch(()=>[]),
      sbReq('GET', 'profiles?select=name,tag,zone&limit=200').catch(()=>[])
    ]);

    // 날짜별 보급 수령 집계
    const supByDay = {};
    days.forEach(d => supByDay[d] = 0);
    (supplyRows||[]).forEach(r => {
      const d = (r.body||'').replace(/-/g,'.');
      if (supByDay[d] !== undefined) supByDay[d]++;
    });
    const maxSup = Math.max(...Object.values(supByDay), 1);

    // 날짜별 거래 집계
    const trByDay = {};
    days.forEach(d => trByDay[d] = 0);
    (tradeRows||[]).forEach(r => {
      const d = (r.created_at||'').slice(0,10).replace(/-/g,'.');
      if (trByDay[d] !== undefined) trByDay[d]++;
    });
    const maxTr = Math.max(...Object.values(trByDay), 1);

    // 플레이어별 통계
    const playerStats = {};
    (profiles||[]).forEach(p => {
      playerStats[p.tag] = { name: p.name, zone: p.zone, supply: 0, trades: 0, logins: 0 };
    });
    (supplyRows||[]).forEach(r => { if(playerStats[r.to_call]) playerStats[r.to_call].supply++; });
    (tradeRows||[]).forEach(r => { if(playerStats[r.author_tag]) playerStats[r.author_tag].trades++; });
    (noteRows||[]).forEach(r => { if(playerStats[r.to_call]) playerStats[r.to_call].logins++; });

    // 활동 점수 기반 정렬
    const ranked = Object.entries(playerStats)
      .map(([tag, s]) => ({tag, ...s, score: s.supply*3 + s.trades*2 + s.logins}))
      .sort((a,b) => b.score - a.score);

    // 렌더
    el.innerHTML = `
      <div class="act-chart-title">보급 수령 (7일)</div>
      <div class="act-bar-wrap">
        ${days.map(d => `
          <div class="act-bar-col">
            <div class="act-bar-fill" style="height:${Math.max(4, Math.round((supByDay[d]/maxSup)*60))}px;background:var(--acl)"></div>
            <div class="act-bar-val">${supByDay[d]}</div>
            <div class="act-bar-day">${d.slice(5)}</div>
          </div>`).join('')}
      </div>
      <div class="act-chart-title" style="margin-top:10px">거래 등록 (7일)</div>
      <div class="act-bar-wrap">
        ${days.map(d => `
          <div class="act-bar-col">
            <div class="act-bar-fill" style="height:${Math.max(4, Math.round((trByDay[d]/maxTr)*60))}px;background:var(--ylw)"></div>
            <div class="act-bar-val">${trByDay[d]}</div>
            <div class="act-bar-day">${d.slice(5)}</div>
          </div>`).join('')}
      </div>
      <div class="act-chart-title" style="margin-top:12px">생존자 활동 순위</div>
      <div class="act-player-list">
        ${ranked.slice(0,10).map((p,i) => `
          <div class="act-player-row">
            <div class="act-rank" style="color:${i===0?'var(--ylw)':i===1?'#aaa':i===2?'#c87':' var(--txf)'}">#${i+1}</div>
            <div class="act-pname">${escH(p.name)} <span style="color:var(--txf)">@${escH(p.tag)}</span></div>
            <div class="act-pbadges">
              <span class="act-badge sup">📦 ${p.supply}</span>
              <span class="act-badge tr">⚔ ${p.trades}</span>
            </div>
          </div>`).join('')}
      </div>`;
  } catch(e) {
    el.innerHTML = '<div style="color:var(--acl);font-family:var(--m);font-size:9px">통계 조회 실패: '+e.message+'</div>';
  }
}

/* ════════════════════════════════════════════════════════════════
   3. 미션 자동 완료 체크
   ════════════════════════════════════════════════════════════════ */
const MISSION_AUTO_CONDITIONS = {
  1: function() { return localStorage.getItem('vx24_act_radio') === getTodayStr() || localStorage.getItem('vx24_radio_ch') === '91.9'; },
  2: function() { return localStorage.getItem('vx24_act_radio404') === getTodayStr(); }
};

function checkMissionAutoComplete() {
  if (!missions || !missions.length) return;
  let changed = false;
  missions.forEach(function(m) {
    if (m.status !== 'active') return;
    const cond = MISSION_AUTO_CONDITIONS[m.id];
    if (!cond) return;
    if (cond()) {
      const prev = localStorage.getItem('vx24_miss_done_' + m.id);
      if (prev) return;
      m.status = 'done';
      const idx = missions.indexOf(m);
      if (idx < missions.length - 1 && missions[idx+1].status === 'locked') {
        missions[idx+1].status = 'active';
      }
      // 보상 아이템 지급
      if (m.reward) {
        const match = m.reward.match(/(.+?)\s*[xX×]\s*(\d+)/);
        if (match) addToInv(match[1].trim(), '🎁', parseInt(match[2]||'1'));
      }
      localStorage.setItem('vx24_miss_done_' + m.id, getTodayStr());
      localStorage.setItem('vx24_inv', JSON.stringify(getInv()));
      saveInvToDB && saveInvToDB();
      changed = true;
      showToast('✓ 미션 완료: ' + m.title + ' — 보상 지급!');
      showBrowserNotif('✓ 미션 완료!', m.title + ' 달성 — 보상이 지급됐습니다');
    }
  });
  if (changed) { renderMissions && renderMissions(); renderInv && renderInv(); }
}

// 로그인 시 + 탭 전환 시 자동 체크
setInterval(checkMissionAutoComplete, 60000);

/* ════════════════════════════════════════════════════════════════
   4. 푸시 알림 (Web Push + Notification API)
   ════════════════════════════════════════════════════════════════ */
async function requestNotifPermission() {
  if (!('Notification' in window)) return false;
  if (Notification.permission === 'granted') return true;
  if (Notification.permission === 'denied') return false;
  const result = await Notification.requestPermission();
  return result === 'granted';
}

function showBrowserNotif(title, body, icon) {
  if (!('Notification' in window) || Notification.permission !== 'granted') return;
  try {
    if (navigator.serviceWorker && navigator.serviceWorker.controller) {
      navigator.serviceWorker.ready.then(function(reg) {
        reg.showNotification(title, {
          body: body || '',
          icon: icon || 'data:image/svg+xml,%3Csvg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64"%3E%3Crect width="64" height="64" fill="%23111"/%3E%3Ctext x="32" y="44" font-size="36" text-anchor="middle"%3E⚠%3C/text%3E%3C/svg%3E',
          badge: 'data:image/svg+xml,%3Csvg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64"%3E%3Crect width="64" height="64" fill="%23dc2626"/%3E%3C/svg%3E',
          vibrate: [200, 100, 200],
          tag: 'vx24-notif',
          renotify: true
        });
      }).catch(function() {
        new Notification(title, { body: body, icon: icon || '' });
      });
    } else {
      new Notification(title, { body: body, icon: icon || '' });
    }
  } catch(e) {}
}

// 로그인 시 알림 권한 요청 + 로그인 ping
async function afterLoginExtras() {
  await requestNotifPermission();
  // 접속 ping (활동 통계용)
  if (currentUser) {
    const today = getTodayStr();
    const pingKey = 'vx24_login_ping_' + today;
    if (!localStorage.getItem(pingKey)) {
      try {
        await sbReq('POST', 'notes', {
          from_call: '__LOGIN__',
          to_call: currentUser.tag,
          body: today,
          type: 'normal',
          created_at: new Date().toISOString()
        });
      } catch(e) {}
      localStorage.setItem(pingKey, '1');
    }
    checkMissionAutoComplete();
  }
}

/* ════════════════════════════════════════════════════════════════
   handleRealtimeNote 확장 — 선물 + 푸시 알림 연동
   ════════════════════════════════════════════════════════════════ */
const _origHandleRealtimeNote = typeof handleRealtimeNote === 'function' ? handleRealtimeNote : null;
handleRealtimeNote = function(note) {
  if (_origHandleRealtimeNote) _origHandleRealtimeNote(note);
  if (!currentUser) return;
  const myTag = currentUser.tag;
  const toMe = note.to_call === myTag || note.to_call === currentUser.name;
  if (!toMe) return;

  // 선물 처리
  if (note.body && note.body.startsWith('__GIFT__:')) {
    checkGiftInNote(note);
    return;
  }
  // 재난문자 발동 알림
  if (note.from_call && note.from_call.startsWith('__SCHED__')) return;
  // 일반 쪽지 알림
  if (note.from_call && !note.from_call.includes(myTag)) {
    showBrowserNotif('📩 쪽지 도착', note.from_call + ' — ' + (note.body||'').slice(0,40));
  }
};
</script>

