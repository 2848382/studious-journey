async function doRegister(){
  const name=$('reg-name').value.trim(),tag=$('reg-tag').value.trim().toLowerCase(),pw=$('reg-pw').value,sch=$('reg-sch').value,zone=$('reg-zone').value;
  if(!name||!tag||!pw){$('login-err').textContent='모든 필드 입력';return}
  if(pw.length!==4){$('login-err').textContent='비밀번호 4자리';return}
  if(tag.length<2){$('login-err').textContent='태그 2자 이상';return}
  try{
    const ex=await sbReq('GET','profiles?tag=eq.'+encodeURIComponent(tag)+'&select=id');
    if(ex&&ex.length>0){$('login-err').textContent='이미 사용 중인 태그';return}
    const hpw=await hashPw(pw);
    await sbReq('POST','profiles',{name,tag,pw:hpw,school:sch,zone});
    // 등록 후 전체 프로필 다시 조회해서 저장 (서버 생성 필드 포함)
    try{
      const full=await sbReq('GET','profiles?tag=eq.'+encodeURIComponent(tag)+'&select=*');
      currentUser=full&&full.length>0?full[0]:{name,tag,pw,school:sch,zone};
    }catch(e2){currentUser={name,tag,pw,school:sch,zone};}
    localStorage.setItem('vx24_user',JSON.stringify(currentUser));
    $('login-screen').classList.remove('show');
    afterLogin();playS('loot');
  }catch(e){$('login-err').textContent='오류: '+(e.message||'')}
}

async function doLogin(){
  const tag=$('reg-tag').value.trim().toLowerCase(),pw=$('reg-pw').value;
  if(!tag||!pw){$('login-err').textContent='입력하세요';return}
  try{
    const hpw2=await hashPw(pw);
    // 해시 먼저 시도, 실패 시 plain text(구 계정) fallback
    let r=await sbReq('GET','profiles?tag=eq.'+encodeURIComponent(tag)+'&pw=eq.'+encodeURIComponent(hpw2)+'&select=*');
    if(!r||r.length===0) r=await sbReq('GET','profiles?tag=eq.'+encodeURIComponent(tag)+'&pw=eq.'+encodeURIComponent(pw)+'&select=*');
