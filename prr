  font-size: 11px;
  color: var(--tx);
  user-select: none;
}
.tos-confirm-btn {
  width: 100%;
  padding: 11px;
  background: rgba(240,80,80,0.16);
  border: 1px solid rgba(240,80,80,0.40);
  color: var(--acl);
  font-family: var(--m);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: .08em;
  cursor: pointer;
  transition: all .18s;
