function cancelStamp(zoneId){
  if(!confirm('이 구역 도장을 취소할까요?'))return;
  const stamps=getStamps();
  delete stamps[zoneId];
  localStorage.setItem('vx24_stamps',JSON.stringify(stamps));
  renderPass();
  showToast('도장 취소됨');
}
function checkPassCode(e){if(e.key!=='Enter')return;const input=$('pass-input').value.trim().toUpperCase();if(!input)return;let matched=false;for(const z of ZD){if(input===zoneCodes[z.id].toUpperCase()){const stamps=getStamps();if(stamps[z.id]){$('pass-msg').innerHTML='<span style="color:var(--ylw)">이미 도장 있음</span>';$('pass-input').value='';return}const now=new Date();stamps[z.id]=`${String(now.getMonth()+1).padStart(2,'0')}.${String(now.getDate()).padStart(2,'0')} ${String(now.getHours()).padStart(2,'0')}:${String(now.getMinutes()).padStart(2,'0')}`;localStorage.setItem('vx24_stamps',JSON.stringify(stamps));matched=true;$('pass-input').classList.add('success');$('pass-msg').innerHTML=`<span style="color:var(--grn)">✓ ${z.name} 통과!</span>`;playS('loot');showToast('🪪 '+z.name+' 도장!');setTimeout(()=>$('pass-input').classList.remove('success'),500);renderPass();if(Object.keys(getStamps()).length>=5)setTimeout(()=>showToast('🎉 전 구역 통과!'),1500);break}}if(!matched){$('pass-input').classList.add('fail');$('pass-msg').innerHTML='<span style="color:var(--acl)">✗ 유효하지 않음</span>';playS('alert');setTimeout(()=>$('pass-input').classList.remove('fail'),500)}$('pass-input').value=''}

