// 이름과 수량을 분리해 주는 똑똑한 함수
function parseItemName(str) {
  if (!str) return { name: '알수없음', q: 1, icon: '📦' };
  str = str.trim();
  
  const qm = str.match(/([x×]|\s)(\d+)(개|병|개씩)?$/);
  let q = 1, name = str;
  
  if (qm) {
    q = parseInt(qm[2]);
    name = str.slice(0, str.length - qm[0].length).trim();
  } else {
    const nm = str.match(/^(.+?)\s+(\d+)(개|병)?$/);
    if (nm) {
      name = nm[1].trim();
      q = parseInt(nm[2]);
    }
  }
  
  const icon = (ITEM_MAP[name] || {}).i || '📦';
  return { name, q, icon };
}

// 아이템 차감 함수 (방어 코드 추가)
function removeFromInv(name, q) {
  if (typeof getInv !== 'function') return false;
  
  const inv = getInv();
  const ex = inv.find(x => x.n === name);
  if (!ex) return false;
  
  ex.q -= q;
  if (ex.q <= 0) {
    const idx = inv.indexOf(ex);
    inv.splice(idx, 1);
  }
  
  localStorage.setItem('vx24_inv', JSON.stringify(inv));
  return true;
}

// 아이템 보유 확인 함수
function hasInvItem(name) {
  if (typeof getInv !== 'function') return false;
  return getInv().some(x => x.n === name && x.q > 0);
}

