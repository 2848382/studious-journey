function buildRandomDrop(){
  const pool = [...KIT].filter(k=>k.mx>0);
  const shuffled = pool.sort(()=>Math.random()-.5);
  const cnt = 3 + Math.floor(Math.random()*3);
  const picked = shuffled.slice(0, Math.min(cnt, shuffled.length));
  const countMap = {};
  const items = [];
  for(const it of picked){
    const n = it.n;
    countMap[n] = (countMap[n]||0) + 1;
    if(countMap[n] > 2) continue;
    const q = it.mn + Math.floor(Math.random()*(it.mx - it.mn + 1));
    if(q > 0) items.push({n, i:it.i, q});
  }
  return items;
}

