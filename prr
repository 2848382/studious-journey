// 스케줄 자동 실행 (startAutoLoop에서 호출)
async function checkScheduledMsgs(){
  try{
    var data = await sbReq('GET','notes?from_call=eq.__SCHED__&order=created_at.asc&limit=50');
    if(!data||!data.length) return;
    var now = new Date();
    var today = getTodayStr();
    for(var i=0;i<data.length;i++){
      var row = data[i];
      var s = {};
      try{s=JSON.parse(row.body||'{}');}catch(e){continue;}
      if(s.fired && s.repeat!=='daily') continue;
      var schedDate = s.date||today;
      if(s.repeat!=='daily' && schedDate!==today) continue;
      if(s.repeat==='daily' && s.firedDate===today) continue;
      var parts = (s.time||'00:00').split(':');
      var hh=parseInt(parts[0]),mm=parseInt(parts[1]);
      var target = new Date();
      target.setHours(hh,mm,0,0);
      var diff = now - target;
      // 지정 시각 ±2분 이내
      if(diff>=0 && diff<120000){
        // 재난문자 발송
        showDsms({title:s.title||'[자동 재난문자]', body:s.body||''});
        playS('alert');
        addMLog('[자동발송] '+s.title);
        // 발송 기록 업데이트
        s.fired = true;
        s.firedDate = today;
        await sbReq('PATCH','notes?id=eq.'+row.id,{body:JSON.stringify(s)});
      }
    }
  }catch(e){}
}


