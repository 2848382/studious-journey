/* ================================================================
   BUTTONS
   ================================================================ */
.btn {
  background: rgba(196,32,32,0.14) !important;
  border: 1px solid rgba(240,80,80,0.38) !important;
  color: var(--acl) !important;
  font-family: var(--m) !important;
  font-size: 10px !important;
  font-weight: 700 !important;
  letter-spacing: .05em !important;
  text-transform: uppercase !important;
  transition: all .18s !important;
}
.btn:hover {
  background: rgba(196,32,32,0.26) !important;
  border-color: var(--acl) !important;
  box-shadow: 0 0 18px rgba(240,80,80,0.22) !important;
}
.btn-o {
  background: rgba(255,255,255,0.04) !important;
  border-color: rgba(255,255,255,0.12) !important;
  color: var(--txd) !important;
}
.btn-o:hover {
  background: rgba(255,255,255,0.08) !important;
  color: var(--tx) !important;
}
.drbtn {
  background: rgba(196,32,32,0.22) !important;
  border: 1px solid rgba(240,80,80,0.42) !important;
  color: var(--acl) !important;
  font-family: var(--m) !important;
  font-weight: 700 !important;
  letter-spacing: .06em !important;
}
.drbtn:hover {
  background: rgba(196,32,32,0.40) !important;
  box-shadow: 0 0 18px rgba(240,80,80,0.26) !important;
}

/* ================================================================
   SUPPLY
   ================================================================ */
.sup-hero {
  background: rgba(22,18,28,0.88) !important;
  border-color: rgba(255,255,255,0.08) !important;
  border-top: 2px solid rgba(240,80,80,0.30) !important;
  backdrop-filter: blur(10px) !important;
  -webkit-backdrop-filter: blur(10px) !important;
}
.sup-item {
  background: rgba(22,18,28,0.82) !important;
  border-color: rgba(255,255,255,0.07) !important;
  backdrop-filter: blur(8px) !important;
  -webkit-backdrop-filter: blur(8px) !important;
  transition: all .18s !important;
}
.sup-item:hover {
  border-color: rgba(255,255,255,0.18) !important;
  transform: translateY(-3px) !important;
  box-shadow: 0 6px 20px rgba(0,0,0,0.45) !important;
}

/* ================================================================
   DICE
   ================================================================ */
.dp {
  background: rgba(20,16,28,0.88) !important;
  border-color: rgba(255,255,255,0.08) !important;
  backdrop-filter: blur(10px) !important;
  -webkit-backdrop-filter: blur(10px) !important;
}
.dr {
  background: rgba(10,10,18,0.95) !important;
  border-color: rgba(255,255,255,0.07) !important;
}
.dn { text-shadow: 0 0 24px rgba(255,255,255,0.30) !important; }

/* ================================================================
   PROFILE / PASS
   ================================================================ */
.prof-card, .pass-card {
  background: rgba(16,14,24,0.96) !important;
  border-color: rgba(255,255,255,0.09) !important;
  backdrop-filter: blur(14px) !important;
  -webkit-backdrop-filter: blur(14px) !important;
}
.pass-input-area {
  background: rgba(8,8,16,0.95) !important;
  border-color: rgba(255,255,255,0.08) !important;
}
.inv-slot {
  background: linear-gradient(135deg, rgba(18,14,26,0.92) 0%, rgba(22,18,32,0.84) 100%) !important;
  border-color: rgba(255,255,255,0.09) !important;
  backdrop-filter: blur(8px) !important;
  -webkit-backdrop-filter: blur(8px) !important;
  transition: all .18s !important;
}
.inv-slot:hover {
  border-color: rgba(255,255,255,0.22) !important;
  box-shadow: 0 4px 20px rgba(0,0,0,0.55) !important;
  transform: translateY(-2px) !important;
}
.inv-icon { filter: drop-shadow(0 2px 6px rgba(0,0,0,0.80)) !important; }
.inv-qty  { color: var(--ylw) !important; text-shadow: 0 0 6px rgba(245,200,66,0.35) !important; }

/* ================================================================
   MISSION / QUEST / TIMER
   ================================================================ */
.mission-card {
  background: rgba(20,16,28,0.88) !important;
  border-color: rgba(255,255,255,0.08) !important;
  backdrop-filter: blur(10px) !important;
  -webkit-backdrop-filter: blur(10px) !important;
}
.mission-card.m-active::before { background: var(--ylw) !important; box-shadow: 0 0 8px rgba(245,200,66,0.45) !important; }
.mission-card.m-done::before   { background: var(--grn) !important; box-shadow: 0 0 8px rgba(56,232,120,0.45) !important; }
.timer-bar {
  background: rgba(20,16,28,0.88) !important;
  border-color: rgba(255,255,255,0.08) !important;
  backdrop-filter: blur(8px) !important;
  -webkit-backdrop-filter: blur(8px) !important;
}
.timer-display { color: var(--acl) !important; text-shadow: 0 0 12px rgba(240,80,80,0.50) !important; }
.quest-chk.checked { border-color: var(--grn) !important; background: rgba(56,232,120,0.12) !important; }

/* ================================================================
   CAPSULE / MAP / INFECTION
   ================================================================ */
.capsule-box {
  background: rgba(20,16,28,0.88) !important;
  border-color: rgba(255,255,255,0.08) !important;
  backdrop-filter: blur(10px) !important;
  -webkit-backdrop-filter: blur(10px) !important;
}
.map-wrap {
  background: rgba(8,12,10,0.90) !important;
  border-color: rgba(255,255,255,0.07) !important;
  backdrop-filter: blur(8px) !important;
  -webkit-backdrop-filter: blur(8px) !important;
}
.map-header { background: rgba(0,0,0,0.55) !important; }
.map-legend { background: rgba(0,0,0,0.45) !important; }
.map-info {
  background: rgba(14,12,22,0.97) !important;
  backdrop-filter: blur(10px) !important;
  -webkit-backdrop-filter: blur(10px) !important;
}
.map-header-status { color: var(--grn) !important; text-shadow: 0 0 8px rgba(56,232,120,0.65) !important; }
.infection-viz { background: rgba(5,10,6,0.90) !important; }

/* ================================================================
   TRADE
   ================================================================ */
.trade-card {
  background: rgba(20,16,28,0.88) !important;
  border-color: rgba(255,255,255,0.08) !important;
  backdrop-filter: blur(10px) !important;
  -webkit-backdrop-filter: blur(10px) !important;
}
.trade-card:hover { border-color: rgba(255,255,255,0.14) !important; box-shadow: 0 4px 22px rgba(0,0,0,0.48) !important; }
.trade-offer, .trade-want { background: rgba(10,10,18,0.90) !important; border-color: rgba(255,255,255,0.08) !important; }
.trade-accept-btn { border-color: rgba(56,232,120,0.45) !important; color: var(--grn) !important; }
.trade-accept-btn:hover { background: rgba(56,232,120,0.12) !important; }
.trade-rob-btn { border-color: rgba(255,154,80,0.40) !important; color: var(--org) !important; }
.trade-rob-btn:hover { background: rgba(255,154,80,0.12) !important; }

/* ================================================================
   GUIDE
   ================================================================ */
.guide-section {
  background: rgba(20,16,28,0.85) !important;
  border-color: rgba(255,255,255,0.08) !important;
  border-left-color: rgba(255,255,255,0.14) !important;
  backdrop-filter: blur(10px) !important;
  -webkit-backdrop-filter: blur(10px) !important;
}
.guide-section:hover {
  border-left-color: var(--acl) !important;
  background: rgba(28,20,36,0.92) !important;
}
.guide-num { text-shadow: 0 0 16px rgba(240,80,80,0.40) !important; }

/* ================================================================
   LOGIN BOX / TOAST / TAG BANNER
   ================================================================ */
.login-box {
  background: rgba(16,14,24,0.99) !important;
  border-color: rgba(240,80,80,0.22) !important;
  border-top-color: rgba(240,80,80,0.55) !important;
  backdrop-filter: blur(22px) !important;
  -webkit-backdrop-filter: blur(22px) !important;
}
.toast, #toast {
  background: rgba(16,14,24,0.99) !important;
  border-color: rgba(240,80,80,0.38) !important;
  backdrop-filter: blur(14px) !important;
  -webkit-backdrop-filter: blur(14px) !important;
}
.tab-alert-inner {
  background: rgba(16,12,12,0.99) !important;
  border-color: rgba(240,80,80,0.55) !important;
  backdrop-filter: blur(18px) !important;
  -webkit-backdrop-filter: blur(18px) !important;
}

/* ================================================================
   MASTER
   ================================================================ */
.m-stat, .m-stat-card { background: rgba(12,10,20,0.90) !important; border-color: rgba(255,255,255,0.09) !important; }
.m-section { background: rgba(12,10,20,0.90) !important; border-color: rgba(255,255,255,0.09) !important; }
.m-log     { background: rgba(6,6,12,0.96) !important; border-color: rgba(255,255,255,0.07) !important; }
.m-header-t { text-shadow: 0 0 14px rgba(192,122,255,0.50) !important; }
.master-gate-box {
  background: rgba(14,8,24,0.92) !important;
  backdrop-filter: blur(14px) !important;
  -webkit-backdrop-filter: blur(14px) !important;
}

/* ================================================================
   ZONE CARDS
   ================================================================ */
.zc {
  background: rgba(20,16,28,0.84) !important;
  border-color: rgba(255,255,255,0.08) !important;
  backdrop-filter: blur(10px) !important;
  -webkit-backdrop-filter: blur(10px) !important;
  transition: transform .18s, border-color .18s !important;
}
.zc:hover { transform: translateY(-4px) !important; }
.z1 .zcd { text-shadow: 0 0 6px rgba(56,232,120,0.50) !important; }
.z4 .zcd { text-shadow: 0 0 6px rgba(240,80,80,0.50) !important; }
.z5 .zcd { text-shadow: 0 0 6px rgba(192,122,255,0.50) !important; }

/* ================================================================
   VIGNETTE / SCANLINE / SCROLLBAR
   ================================================================ */
#vx-vignette { background: radial-gradient(ellipse at center, transparent 40%, rgba(0,0,0,0.68) 100%) !important; }
#vx-scanline { opacity: .22 !important; }
::-webkit-scrollbar       { width: 4px !important; }
::-webkit-scrollbar-thumb { background: rgba(185,28,28,0.35) !important; border-radius: 2px !important; }

/* ================================================================
   RADIO
   ================================================================ */
.radio-display-val { text-shadow: 0 0 14px rgba(0,255,65,0.70), 0 0 36px rgba(0,255,65,0.25) !important; }

/* ================================================================
   QUIZ
   ================================================================ */
.quiz-q {
  background: rgba(20,16,28,0.85) !important;
  border-color: rgba(255,255,255,0.08) !important;
  backdrop-filter: blur(10px) !important;
  -webkit-backdrop-filter: blur(10px) !important;
}
.quiz-opt label:hover {
  border-color: rgba(240,80,80,0.32) !important;
  background: rgba(240,80,80,0.05) !important;
}
.quiz-result {
  background: rgba(20,16,28,0.92) !important;
  border-color: rgba(255,255,255,0.08) !important;
  backdrop-filter: blur(12px) !important;
  -webkit-backdrop-filter: blur(12px) !important;
}

/* ================================================================
   HIDDEN / SECRET PAGE
   ================================================================ */
.hidden-page {
  background: rgba(20,10,30,0.88) !important;
  border-color: rgba(192,122,255,0.18) !important;
}


/* ================================================================
   VX-24 EXTRA CSS — Game UI v4 additions
   ================================================================ */

/* ── item description popup ───────────────────────────────────── */
.item-desc-popup {
  display:none; position:fixed; inset:0; z-index:5000;
  background:rgba(0,0,0,0.72); align-items:center; justify-content:center;
  padding:16px;
}
.item-desc-popup.show { display:flex; }
.idp-box {
  width:min(320px,90vw);
  background:rgba(16,12,22,0.99);
  border:1px solid rgba(255,255,255,0.10);
  border-top:2px solid var(--acl);
  padding:18px;
  animation:fu .22s;
  box-shadow: 0 20px 60px rgba(0,0,0,0.90);
}
.idp-header { display:flex; align-items:center; gap:12px; margin-bottom:12px; }
.idp-icon { font-size:32px; line-height:1; }
