function searchEmergencyContact() {
    const input = $('ec-search-input');
    const val = input ? input.value : '';
    const search_ac = $('ec-tag-ac');
    
    // @ 태그 자동완성
    if (val.startsWith('@') && val.length > 1 && registeredUsers.length > 0) {
        const query = val.substring(1).toLowerCase();
        const matches = registeredUsers.filter(u => {
            if (currentUser && u.tag === currentUser.tag) return false;
            if (ecSelected.find(s => s.tag === u.tag)) return false;
            return u.tag.toLowerCase().includes(query) || u.name.toLowerCase().includes(query);
        }).slice(0, 5);
        
        if (matches.length > 0 && search_ac) {
            search_ac.style.display = 'block';
            search_ac.innerHTML = matches.map(u => 
                `<div class="tag-ac-item" onmousedown="addEcSelected('${u.tag}', '${u.name}'); document.getElementById('ec-search-input').value=''; document.getElementById('ec-tag-ac').style.display='none';">
                    <span class="tag-ac-tag">@${u.tag}</span>
                    <span class="tag-ac-name">${u.name}</span>
                </div>`
            ).join('');
            renderEcSearchList(query);
            return;
        }
    }
    if (search_ac) search_ac.style.display = 'none';
    // @ 없으면 목록 표시 안 함
    if(!val.startsWith('@') && val.length > 0){
      renderEcSearchList('');
      return;
    }
    const q = val.replace(/^@/, '').toLowerCase();
    renderEcSearchList(q);
}

