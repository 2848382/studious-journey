function positionPhoneAc(ac, inputEl){
  // fixed 포탈 위치 계산: input 바로 위
  const r=inputEl.getBoundingClientRect();
  ac.style.left=r.left+'px';
  ac.style.width=r.width+'px';
  const acH=Math.min(160, ac.scrollHeight||120);
  // 위로 열릴지 아래로 열릴지 판단
  if(r.top - acH > 10){
    ac.style.top=(r.top - acH - 4)+'px';
    ac.style.bottom='auto';
  } else {
    ac.style.top=(r.bottom+4)+'px';
    ac.style.bottom='auto';
  }
}

