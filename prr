async function submitTrade() {
  if (!currentUser) { showToast('로그인 필요'); return; }
  const offer = ($('tr-offer').value || '').trim();
  const want  = ($('tr-want').value  || '').trim();
  const note  = ($('tr-note').value  || '').trim();
  if (!offer || !want) { showToast('제공/원하는 아이템 모두 입력'); return; }
