function insertTagInBody(tag){
  const input=$('phone-note-body');
  const ac=$('phone-body-ac');
  if(!input)return;
  const text=input.value;
  const cursor=input.selectionStart||text.length;
  const before=text.substring(0,cursor);
  const atIdx=before.lastIndexOf('@');
  if(atIdx>=0){
    input.value=text.substring(0,atIdx)+'@'+tag+' '+text.substring(cursor);
    input.focus();
    const np=atIdx+tag.length+2;
    input.selectionStart=input.selectionEnd=np;
  }
  if(ac)ac.style.display='none';
}

function insertTag(e,tag,acId){
  e.preventDefault();
  const ac=$(acId);
  ac.style.display='none';
  // acId 기반 input 직접 매핑 (포커스 이탈 문제 방지)
  const acToInput={'wtit-ac':'wtit','wbod-ac':'wbod','cmt-ac':'cmt-in','pf-tag-ac':'pf-note-to'};
  let input=acToInput[acId]?$(acToInput[acId]):null;
  // 매핑 없는 경우 activeElement 또는 컨테이너에서 탐색
  if(!input){
    input=document.activeElement;
    if(!input||(!input.tagName.match(/INPUT|TEXTAREA/))){
      const container=ac.closest('.fg,.wf,.mcm,.pf-compose')||ac.parentElement;
      if(container)input=container.querySelector('input:not([readonly]),textarea');
    }
  }
  if(!input)return;
  const cursorPos=input.selectionStart||input.value.length;
  const text=input.value;
  const textBefore=text.substring(0,cursorPos);
  const atIdx=textBefore.lastIndexOf('@');
  if(atIdx>=0){
    input.value=text.substring(0,atIdx)+'@'+tag+' '+text.substring(cursorPos);
    input.focus();
    const newPos=atIdx+tag.length+2;
    input.selectionStart=input.selectionEnd=newPos;
  }
}

