.mot { font-family: var(--o) !important; font-size: 15px !important; }

/* ================================================================
   NOTICE BOX
   ================================================================ */
.notice-box {
  background: rgba(22,18,10,0.90) !important;
  border: 1px solid rgba(245,200,66,0.18) !important;
  border-left: 3px solid rgba(245,200,66,0.55) !important;
  backdrop-filter: blur(8px) !important;
  -webkit-backdrop-filter: blur(8px) !important;
}
.notice-box-header {
  background: rgba(245,200,66,0.05) !important;
