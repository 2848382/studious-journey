  background: var(--acl) !important;
  box-shadow: 0 0 4px rgba(240,80,80,0.50) !important;
}

/* ================================================================
   MODAL
   ================================================================ */
.mob {
  background: rgba(16,14,24,0.99) !important;
  border: 1px solid rgba(255,255,255,0.09) !important;
  border-top: 2px solid rgba(240,80,80,0.45) !important;
  box-shadow: 0 28px 70px rgba(0,0,0,0.92) !important;
}
