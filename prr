let phoneClickCount=0;
let phoneClickTimer=null;
let phoneScreenState='off'; // off | lock | home

function handlePhoneClick(){
  phoneClickCount++;
  if(phoneClickTimer)clearTimeout(phoneClickTimer);
  phoneClickTimer=setTimeout(()=>{
    if(phoneClickCount>=2){
      // 더블클릭: 전체화면
      openFullscreen();
    } else {
      // 싱글클릭: 팝업 토글
      togglePhonePopup();
    }
    phoneClickCount=0;
  },300);
}

function togglePhonePopup(){
  const popup=$('phone-popup');
  if(popup.classList.contains('open')){
    popup.classList.remove('open');
    // 자동완성 포탈 숨김
    const ta=$('phone-tag-ac');const ba=$('phone-body-ac');
    if(ta)ta.style.display='none';if(ba)ba.style.display='none';
  } else {
    popup.classList.add('open');
    if(phoneScreenState==='off'){
      wakePhoneScreen();
    }
  }
}

function wakePhoneScreen(withNotif){
  const off=$('screen-off');
  const lock=$('screen-lock');
  const home=$('screen-home');
  // 화면 켜지는 플래시
  const flash=document.createElement('div');
  flash.className='screen-wake-flash';
  $('iphone-shell').appendChild(flash);
  setTimeout(()=>flash.remove(),700);
  // 잠금화면 표시
  off.classList.add('hidden');
  lock.style.display='flex';
  home.style.display='none';
  phoneScreenState='lock';
  setTimeout(()=>{
    // 잠금화면→홈
    lock.classList.add('hidden');
    home.style.display='flex';
    phoneScreenState='home';
    loadNotesForPhone();
  },withNotif?2000:1000);
}

function triggerPhoneNotification(note){
  const wrapper=$('phone-fab-wrapper');
  // 진동 애니메이션
  wrapper.classList.add('vibrating');
  setTimeout(()=>wrapper.classList.remove('vibrating'),400);
  playS('vibrate');
  // 화면이 꺼져 있으면 켜기
  if(phoneScreenState==='off'&&$('phone-popup').classList.contains('open')){
    wakePhoneScreen(true);
  }
  // 잠금화면에 알림 추가
  addLockScreenNotif(note);
  // Dynamic Island 확장
  expandDynamicIsland(note.from_call+' → 새 쪽지');
  // 배지 업데이트
  updatePhoneBadge();
}

function addLockScreenNotif(note){
  const area=$('lock-notif-area');
  area.querySelector('div[style]')&&area.querySelector('div[style]').remove(); // 빈 메시지 제거
  const item=document.createElement('div');
  item.className='lock-notif-item';
  const typeIcon=note.type==='urgent'?'🚨':note.type==='secret'?'🔒':'📩';
  item.innerHTML=`<div class="lock-notif-icon">${typeIcon}</div><div style="flex:1;min-width:0"><div class="lock-notif-app">쪽지</div><div class="lock-notif-msg">${escH(note.from_call)}<br>${note.type==='secret'?'비밀 메시지':escH(note.body)}</div></div>`;
  area.prepend(item);
  // 최대 3개
  while(area.children.length>3)area.lastChild.remove();
}

function expandDynamicIsland(text){
  const di=$('dynamic-island');
  const notif=$('di-notif');
  notif.textContent=text;
  di.classList.add('expanded');
  setTimeout(()=>{di.classList.remove('expanded');notif.textContent=''},3000);
}

