function checkLogin(){
  const s=localStorage.getItem('vx24_user');
  if(s){
    try{
      currentUser=JSON.parse(s);
      // 캐시가 있으면 서버에서 최신 프로필 다시 불러오기 (혈액형/접종 최신화)
      sbReq('GET','profiles?tag=eq.'+encodeURIComponent(currentUser.tag)+'&select=*')
        .then(r=>{
          if(r&&r.length>0){
            currentUser=r[0];
            localStorage.setItem('vx24_user',JSON.stringify(currentUser));
          }
          afterLogin();
        })
        .catch(()=>afterLogin()); // 오프라인 등 오류 시 캐시로 진행
      return;
    }catch(e){}
  }
