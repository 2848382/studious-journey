      <div class="pz-code" style="color:${z.color}">${z.code}</div>
      <div class="pz-name">${z.name}</div>
      <div class="pz-stamp${s?' done':''}" style="${s?'border-color:'+z.color+';color:'+z.color:''}">${s?'✓':'?'}</div>
