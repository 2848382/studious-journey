const ZD=[{id:'A',code:'C-1',name:'A구역',color:'var(--grn)'},{id:'B',code:'P-2',name:'B구역',color:'var(--ylw)'},{id:'C',code:'S-3',name:'C구역',color:'var(--org)'},{id:'D',code:'C-4',name:'D구역',color:'var(--acl)'},{id:'E',code:'SC-5',name:'E구역',color:'var(--pur)'}];
let zoneCodes={A:'ALPHA1',B:'BRAVO2',C:'CHARLIE3',D:'DELTA4',E:'ECHO5'};
function getStamps(){try{return JSON.parse(localStorage.getItem('vx24_stamps'))||{}}catch(e){return{}}}
function renderPass(){
  const stamps=getStamps(),cnt=Object.keys(stamps).length;
  $('pass-count').textContent=cnt+'/5';
  $('pass-count').style.color=cnt>=5?'var(--grn)':'var(--w)';
