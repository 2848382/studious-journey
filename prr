let sndOn=false,actx=null;
function toggleSnd(){
  sndOn=!sndOn;
  $('snd-btn').textContent=sndOn?'♫':'♪';
  $('snd-btn').style.color=sndOn?'var(--grn)':'';
  if(sndOn&&!actx){actx=new(window.AudioContext||window.webkitAudioContext)();}
  if(sndOn) playS('boot');
}

// 화이트 노이즈 버퍼 생성
function makeNoiseBuf(dur, vol){
  var buf=actx.createBuffer(1,actx.sampleRate*dur,actx.sampleRate);
  var d=buf.getChannelData(0);
  for(var i=0;i<d.length;i++) d[i]=(Math.random()*2-1)*vol;
  var src=actx.createBufferSource(); src.buffer=buf;
  return src;
}
// 로우패스 필터
function makeLPF(freq){
  var f=actx.createBiquadFilter();
  f.type='lowpass'; f.frequency.value=freq;
  return f;
}
// 하이패스 필터
function makeHPF(freq){
  var f=actx.createBiquadFilter();
  f.type='highpass'; f.frequency.value=freq;
  return f;
}

function playS(t){
  if(!sndOn||!actx) return;
  var now=actx.currentTime;

  if(t==='click'){
    // 군용 버튼: 짧은 클릭 + 미세 노이즈
    var o=actx.createOscillator(),g=actx.createGain();
    o.type='square'; o.frequency.setValueAtTime(1200,now); o.frequency.exponentialRampToValueAtTime(600,now+.04);
    g.gain.setValueAtTime(.025,now); g.gain.exponentialRampToValueAtTime(.001,now+.06);
    o.connect(g); g.connect(actx.destination);
    o.start(now); o.stop(now+.06);
    var ns=makeNoiseBuf(.04,.03); var lpf=makeLPF(3000);
    var ng=actx.createGain(); ng.gain.setValueAtTime(.04,now); ng.gain.exponentialRampToValueAtTime(.001,now+.04);
    ns.connect(lpf); lpf.connect(ng); ng.connect(actx.destination); ns.start(now); ns.stop(now+.04);
  }
  else if(t==='boot'){
    // 시스템 부팅: 상승 스윕 + 딸깍
    var o=actx.createOscillator(),g=actx.createGain();
    o.type='sine';
    o.frequency.setValueAtTime(200,now);
    o.frequency.exponentialRampToValueAtTime(800,now+.12);
    o.frequency.setValueAtTime(600,now+.14);
    g.gain.setValueAtTime(.05,now); g.gain.exponentialRampToValueAtTime(.001,now+.25);
    o.connect(g); g.connect(actx.destination);
    o.start(now); o.stop(now+.25);
    // 고음 틱
    var o2=actx.createOscillator(),g2=actx.createGain();
    o2.type='square'; o2.frequency.value=2400;
    g2.gain.setValueAtTime(.018,now+.13); g2.gain.exponentialRampToValueAtTime(.001,now+.18);
    o2.connect(g2); g2.connect(actx.destination);
    o2.start(now+.13); o2.stop(now+.18);
  }
  else if(t==='alert'){
    // 경보: 두 번 울리는 군용 경보음
    [0, .28].forEach(function(d){
      var o=actx.createOscillator(),g=actx.createGain();
      o.type='square';
      o.frequency.setValueAtTime(880,now+d);
      o.frequency.setValueAtTime(660,now+d+.1);
      g.gain.setValueAtTime(.06,now+d); g.gain.exponentialRampToValueAtTime(.001,now+d+.22);
      o.connect(g); g.connect(actx.destination);
      o.start(now+d); o.stop(now+d+.22);
    });
  }
  else if(t==='loot'){
    // 아이템 획득: 상승 3단 틱
    [0,.07,.14].forEach(function(d,i){
      var o=actx.createOscillator(),g=actx.createGain();
      o.type='triangle';
      o.frequency.value=500+i*180;
      g.gain.setValueAtTime(.05,now+d); g.gain.exponentialRampToValueAtTime(.001,now+d+.1);
      o.connect(g); g.connect(actx.destination);
      o.start(now+d); o.stop(now+d+.1);
    });
  }
  else if(t==='noise'){
    // 무전기 잡음: 밴드패스 필터링된 노이즈 버스트
    var ns=makeNoiseBuf(.22,.4);
    var bpf=actx.createBiquadFilter();
    bpf.type='bandpass'; bpf.frequency.value=1800; bpf.Q.value=1.2;
    var g=actx.createGain();
    g.gain.setValueAtTime(.0,now);
    g.gain.linearRampToValueAtTime(.12,now+.02);
    g.gain.setValueAtTime(.1,now+.1);
    g.gain.exponentialRampToValueAtTime(.001,now+.22);
    ns.connect(bpf); bpf.connect(g); g.connect(actx.destination);
    ns.start(now); ns.stop(now+.22);
    // 캐리어 톤 (무전기 느낌)
    var o=actx.createOscillator(),og=actx.createGain();
    o.type='sine'; o.frequency.value=1200;
    og.gain.setValueAtTime(.012,now); og.gain.exponentialRampToValueAtTime(.001,now+.18);
    o.connect(og); og.connect(actx.destination);
    o.start(now); o.stop(now+.18);
  }
  else if(t==='roll'){
    // 주사위 / 강탈: 날카로운 드럼 롤
    for(var i=0;i<6;i++){
      (function(ii){
        var ns=makeNoiseBuf(.06,.3);
        var hpf=makeHPF(2000+ii*200);
        var g=actx.createGain();
        var d=ii*.045;
        g.gain.setValueAtTime(.08-ii*.008,now+d);
        g.gain.exponentialRampToValueAtTime(.001,now+d+.08);
        ns.connect(hpf); hpf.connect(g); g.connect(actx.destination);
        ns.start(now+d); ns.stop(now+d+.08);
      })(i);
    }
  }
  else if(t==='vibrate'){
    // 진동 / 알림: 서브 베이스 펄스
    [0,.12].forEach(function(d){
      var o=actx.createOscillator(),g=actx.createGain();
      o.type='sine'; o.frequency.setValueAtTime(55,now+d); o.frequency.exponentialRampToValueAtTime(40,now+d+.1);
      g.gain.setValueAtTime(.18,now+d); g.gain.exponentialRampToValueAtTime(.001,now+d+.18);
      o.connect(g); g.connect(actx.destination);
      o.start(now+d); o.stop(now+d+.18);
    });
  }
}

