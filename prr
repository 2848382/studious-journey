      const bodyOnclick=n.type==='secret'?`onclick="this.classList.remove('pf-msg-secret-body');this.classList.add('pf-msg-body');localStorage.setItem('vx24_rv_${n.id}','1')"`:'';
      const isMy=(currentUser&&(n.from_call===currentUser.name||n.from_call.includes('@'+currentUser.tag)));
      const fsDelBtn=(isForMe||isMy)?`<button data-noteid="${n.id}" class="note-del-btn" style="background:rgba(255,80,80,.1);border:1px solid rgba(255,80,80,.2);color:rgba(255,100,100,.7);font-size:9px;padding:2px 6px;cursor:pointer;border-radius:3px;font-family:var(--m);-webkit-tap-highlight-color:transparent">✕ 삭제</button>`:'';
