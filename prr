let invInfoStep={};

function showItemInfo(name, icon, qty){
  const prev = invInfoStep[name] || 0;
  if(prev === 0){
    invInfoStep[name] = 1;
    showItemDescPopup(name, icon, qty);
    setTimeout(()=>{ invInfoStep[name]=0; }, 6000);
  } else {
    invInfoStep[name] = 0;
    closeItemDesc();
    const isBattery = (name === '건전지');
    if(isBattery){
      if(qty < BATTERY_USE_THRESHOLD){
        showToast(`건전지 ${BATTERY_USE_THRESHOLD}개 이상이어야 교환 가능합니다 (현재 ${qty}개)`);
        return;
      }
    }
    const isUsable = USABLE.includes(name);
    if(!isUsable){ showToast('사용할 수 없는 아이템입니다'); return; }
    openItemUse(name, icon, qty);
  }
}

function showItemDescPopup(name, icon, qty) {
  closeItemDesc();
  const rawDesc = ITEM_DESC[name] || '등록된 정보 없음';
  const descText = typeof rawDesc === 'object' ? rawDesc.desc : rawDesc;
  const isBattery = (name === '건전지');
  const isTicket = (name === '보급품 추가 수령 티켓');
  const isUsable = USABLE.includes(name);

  let effectText = '';
  if (isBattery) { effectText = '건전지 ' + BATTERY_USE_THRESHOLD + '개 소모 → 보급품 추가 수령 티켓 획득'; }
  else if (isTicket) { effectText = '오늘 보급품 1회 추가 수령'; }
  else if (isUsable) { effectText = '체력 +10'; }
  else { effectText = '사용 불가'; }

  const giftAlreadySent = localStorage.getItem('vx24_gift_' + getTodayStr());
  
  let giftBtn = '';
  if (name !== '보급품 추가 수령 티켓' && !isBattery) {
    if (giftAlreadySent) {
      giftBtn = '<div class="idp-gift-used">🎁 오늘 선물 완료</div>';
    } else {
      let safeName = name.replace(/'/g, "\\'");
      let safeIcon = (icon || '📦').replace(/'/g, "\\'");
      giftBtn = '<div class="idp-gift-btn" onclick="openGiftUI(\'' + safeName + '\', \'' + safeIcon + '\', ' + qty + ')">🎁 선물하기</div>';
    }
  }

  let useHint = '';
  if (isBattery) {
    if (qty >= BATTERY_USE_THRESHOLD) {
      useHint = '<div class="idp-effect">⚡ 한 번 더 탭 → 건전지 ' + BATTERY_USE_THRESHOLD + '개 교환</div>';
    } else {
      useHint = '<div class="idp-effect-locked">🔒 ' + BATTERY_USE_THRESHOLD + '개 필요 (현재 ' + qty + '개)</div>';
    }
  } else if (isUsable) {
    useHint = '<div class="idp-effect">▶ 한 번 더 탭하여 사용</div>';
  }

  const box = document.createElement('div');
  box.id = 'item-desc-popup';
