익일 06:00 야간 통행이 전면 금지됩니다.\n\n해당 시간 외출 시 감염자로 간주하여 격리 조치합니다. 응급 시 통신망을 통해 의료반에 연락하십시오.\n\n─ 수도방위사령부"},   {title:"[변이체 목격 신고 요청]",body:"최근 변이체의 행동 반경이 확대되고 있습니다.\n\n변이체 목격 시 절대 단독 대응하지 말고 즉시 군 통신망으로 위치와 수량을 보고하십시오. 신고 보상: 보급품 추가 지급.\n\n─ 특수대응팀 ALPHA-1"},   {title:"[마스크 착용 의무화 재공지]",body:"실내외 모든 구역에서 마스크 착용이 의무화되어 있습니다.\n\nVX-24는 호흡기를 통한 감염이 주 경로입니다. 마스크 미착용 적발 시 당일 배급 제한 조치가 취해집니다.\n\n─ 중앙방역대책본부"},   {title:"[Echo-404 정보 차단 경보]",body:"⚠ 보안 경보 ⚠\n\n'Echo-404' 관련 정보를 유포하거나 검색하는 행위는 군사기밀보호법 위반입니다.\n\n해당 정보 접촉 즉시 상급자에게 보고하고 자체 확산을 금지합니다. 위반자는 즉시 구금됩니다.\n\n─ 보안사령부"},   {title:"[배급소 운영 일정 공지]",body:"오늘 보급품 배급은 아래 일정으로 진행됩니다.\n\nA구역 10:00 / B구역 12:00 / C구역 14:00 / D구역은 오염으로 인해 금일 배급 중단.\n\n1인 수령 시 통행증 필히 지참. 대리 수령 불가.\n\n─ 보급물자관리단"},   {title:"[감염 의심 증상 자가 신고]",body:"다음 증상이 있으면 즉시 자가 신고하십시오.\n\n▸ 38.5°C 이상 발열\n▸ 청각 과민 (소음 민감)\n▸ 동공 확장\n▸ 원인 불명 근육통\n\n신고처: 군 의료반 통신채널 7번\n무신고 감염자 적발 시 강제격리됩니다.\n\n─ VX-24 대응팀"},   {title:"[구조 요청 공식 채널 안내]",body:"민간인 구조 요청은 반드시 공식 통신망을 통해 접수하십시오.\n\n개인 간 구조 활동은 허가 없이 금지되며 무단 구역 진입은 위험 지역 격리 조치 대상입니다.\n\n구조 대기 시간: 최대 72시간\n\n─ 구조작전팀"},   {title:"[집단 행동 금지 명령]",body:"3인 이상 집회 및 집단 행동을 금지합니다.\n\n감염 확산 방지를 위해 개인 간 거리 2m 이상 유지가 의무입니다. 위반 시 전원 격리 조치합니다.\n\n─ 수도방위사령부"},   {title:"[VX-24 확산 현황 D+102]",body:"오늘 기준 VX-24 감염 현황입니다.\n\n확진: 2,847명 (+312 / 전일 대비)\n변이체 전환: 218명\n격리 중: 1,094명\n\nD구역 봉쇄선 유지 중. 전국 위기경보 수준 [심각] 유지.\n\n생존자 여러분의 협조를 당부드립니다.\n─ 전국재난안전대책본부"}, ];  let dsmsQueue=[]; let dsmsShowing=false; let dsmsUsed=new Set();  function playDisasterSound(){   if(!actx){     try{actx=new(window.AudioContext||window.webkitAudioContext)()}catch(e){return}   }   // 재난문자 특유의 "띠리리링" 경보음   const times=[0,0.15,0.3,0.45];   times.forEach((t,i)=>{     const o=actx.createOscillator();     const g=actx.createGain();     o.connect(g);g.connect(actx.destination);     o.type='square';     o.frequency.value=i%2===0?880:1100;     g.gain.setValueAtTime(0,actx.currentTime+t);     g.gain.linearRampToValueAtTime(0.12,actx.currentTime+t+0.02);     g.gain.exponentialRampToValueAtTime(0.001,actx.currentTime+t+0.13);     o.start(actx.currentTime+t);     o.stop(actx.currentTime+t+0.14);   }); }  function vibrateDevice(){   if(navigator.vibrate){     navigator.vibrate([200,100,200,100,400]);   } }  function showDsms(msg){   if(dsmsShowing){dsmsQueue.push(msg);return;}   dsmsShowing=true;   const now=new Date();   const timeStr=`${String(now.getFullYear()).slice(2)}.${String(now.getMonth()+1).padStart(2,'0')}.${String(now.getDate()).padStart(2,'0')} ${String(now.getHours()).padStart(2,'0')}:${String(now.getMinutes()).padStart(2,'0')}`;   $('dsms-body').innerHTML=`<div style="font-size:12px;font-weight:700;color:#ff6666;margin-bottom:10px;letter-spacing:-.01em">${msg.title}</div>${msg.body.replace(/\n/g,'<br>')}`;   $('dsms-time').textContent=timeStr+' 수신';   $('disaster-sms').classList.add('show');   playDisasterSound();   vibrateDevice();   // 핸드폰 위젯 진동 효과   const shell=$('iphone-shell');   if(shell){shell.classList.add('vibrating');setTimeout(()=>shell.classList.remove('vibrating'),500);} }  function closeDsms(){   $('disaster-sms').classList.remove('show');   dsmsShowing=false;   if(dsmsQueue.length>0){     setTimeout(()=>showDsms(dsmsQueue.shift()),1500);   } }  function scheduleDisasterSms(){   // 첫 발송: 30~90초 후   const firstDelay=30000+Math.random()*60000;   setTimeout(function fire(){     // 아직 안 쓴 것 중에서 랜덤 선택     const remaining=DISASTER_MSGS.filter((_,i)=>!dsmsUsed.has(i));     if(remaining.length===0){dsmsUsed.clear();}     const pool=DISASTER_MSGS.filter((_,i)=>!dsmsUsed.has(i));     const idx=DISASTER_MSGS.indexOf(pool[Math.floor(Math.random()*pool.length)]);     dsmsUsed.add(idx);     showDsms(DISASTER_MSGS[idx]);     // 다음 발송: 2~6분 랜덤     const nextDelay=120000+Math.random()*240000;     setTimeout(fire,nextDelay);   },firstDelay); }  // 재난문자 시작 (로그인 후에도 동작) scheduleDisasterSms();
