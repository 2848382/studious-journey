}  // ============================================================ // 긴급연락처 시스템 // ============================================================ let ecSelected=[]; let ecContacts=null; // 확정 후 저장  function loadEC(){   try{     const raw=localStorage.getItem('vx24_ec');     if(raw) ecContacts=JSON.parse(raw);   }catch(e){} } loadEC();  function renderEmergencyContacts(){   const listEl=$('phone-contacts-list');   const setupEl=$('phone-ec-setup');   if(!listEl||!setupEl)return;    if(ecContacts&&ecContacts.length>0){     // 확정됨 — 목록 표시     setupEl.style.display='none';     listEl.innerHTML=ecContacts.map((c,i)=>`       <div style="display:flex;align-items:center;padding:8px 10px;border-bottom:1px solid rgba(255,0,0,.08);cursor:pointer;gap:8px" onclick="openEcMsg(${i})">         <div style="width:28px;height:28px;border-radius:50%;background:rgba(220,38,38,.2);border:1px solid rgba(220,38,38,.4);display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0">🚨</div>         <div style="flex:1;min-width:0">           <div style="font-size:11px;font-weight:600;color:#fff">${c.name}</div>           <div style="font-family:var(--m);font-size:8px;color:rgba(255,100,100,.7)">@${c.tag}</div>         </div>         <div style="font-family:var(--m);font-size:8px;color:rgba(255,255,255,.3)">메시지 ›</div>       </div>`).join('');   } else {     // 미설정 — 설정 UI     setupEl.style.display='block';     listEl.innerHTML='';     renderEcSearchList('');   } }  function searchEmergencyContact(){   const q=$('ec-search-input').value.toLowerCase();   renderEcSearchList(q); }  function renderEcSearchList(q){   const el=$('ec-search-list');   if(!el)return;   const filtered=registeredUsers.filter(u=>{     if(currentUser&&u.tag===currentUser.tag)return false;     if(ecSelected.find(s=>s.tag===u.tag))return false;     return !q||(u.tag.toLowerCase().includes(q)||u.name.toLowerCase().includes(q));   }).slice(0,8);   el.innerHTML=filtered.map(u=>`     <div onclick="addEcSelecte