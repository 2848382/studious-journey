function renderMissions(){$('mission-list').innerHTML=missions.map((m,i)=>{const isLast=i===missions.length-1;const badge=m.status==='active'?'<span class="mc-badge active">진행중</span>':m.status==='done'?'<span class="mc-badge done">완료</span>':'<span class="mc-badge locked">잠김</span>';return`<div class="mission-card m-${m.status}"><div class="mc-header"><div class="mc-title">${m.status==='locked'?'🔒 ':m.status==='done'?'✓ ':'▸ '}${m.title}</div>${badge}</div><div class="mc-desc">${m.status==='locked'?'이전 미션 완료 후 해제':m.desc}</div>${m.status!=='locked'?`<div class="mc-reward">보상: ${m.reward}</div>`:''}${m.status==='active'&&m.code?`<div style="margin-top:5px;display:flex;gap:4px"><input class="fi" style="max-width:120px;font-family:var(--m);text-transform:uppercase;font-size:11px" placeholder="코드" id="mis-${m.id}"><button class="mc-btn" onclick="completeMission(${m.id})">완료</button></div>`:''}</div>${!isLast?`<div class="mc-chain-line${m.status==='done'?' done':''}"></div>`:''}`}).join('')}
function completeMission(id){const m=missions.find(x=>x.id===id);if(!m||m.status!=='active')return;if(m.code){const inp=$('mis-'+id);if(!inp||inp.value.trim().toUpperCase()!==m.code.toUpperCase()){showToast('코드 불일치');playS('alert');return}}m.status='done';const idx=missions.indexOf(m);if(idx<missions.length-1)missions[idx+1].status='active';renderMissions();playS('loot');if(m.reward&&m.reward!=='없음'){const _p=parseItemName(m.reward);if(_p&&_p.name&&_p.name!==m.reward){addToInv(_p.name,_p.icon,_p.q);renderInv();showToast('🎯 '+_p.icon+' '+_p.name+' ×'+_p.q+' 지급');}else{showToast('🎯 '+m.title+' — '+m.reward);}if(currentUser)addMLog('[자동]미션:'+currentUser.name+'→'+m.reward);}else{showToast('🎯 '+m.title);}}

