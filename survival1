async function submitTrade(){
  if(!currentUser){showToast('로그인 필요');return;}
  const offer=$('tr-offer').value.trim();
  const want=$('tr-want').value.trim();
  const note=$('tr-note').value.trim();
  if(!offer||!want){showToast('제공/원하는 아이템을 입력하세요');return;}
  // 인벤토리에서 제공 아이템 확인
  const {name,q}=parseItemName(offer);
  const inv=getInv();
  const ex=inv.find(x=>x.n===name);
  if(!ex||ex.q<q){
    if(!confirm('인벤토리에 해당 아이템이 없거나 수량이 부족합니다. 그래도 등록하시겠습니까?'))return;
  }
  try{
    await sbReq('POST','trades',{
      from_name:currentUser.name,
      from_tag:currentUser.tag,
      offer,want,note,
      status:'open',
      created_at:new Date().toISOString()
    });
    closeMo('mo-trade-write');
    $('tr-offer').value='';$('tr-want').value='';$('tr-note').value='';
    playS('loot');showToast('✓ 거래 등록 완료');
    addMLog(`거래등록: ${currentUser.name} — ${offer} ⇄ ${want}`);
    loadTrades();
  }catch(e){showToast('등록 실패');}
}

async function acceptTrade(id, fromTag, offerStr, wantStr){
  if(!currentUser){showToast('로그인 필요');return;}
  // 내가 제공해야 할 것 = want (등록자가 원하는 것)
  const wantParsed=parseItemName(wantStr);
  const offerParsed=parseItemName(offerStr);
  try{
    await sbReq('PATCH','trades?id=eq.'+id,{
      status:'accepted',
      accepted_by:currentUser.name+'(@'+currentUser.tag+')',
      accepted_at:new Date().toISOString()
    });
    // ── 인벤토리 자동 이전 ──
    // 수락자: want 아이템 차감, offer 아이템 획득
    removeFromInv(wantParsed.name, wantParsed.q);
    addToInv(offerParsed.name, offerParsed.icon, offerParsed.q);
    // 등록자 인벤토리는 localStorage가 다르므로 쪽지로 알림
    await sbReq('POST','notes',{
      from_call:'거래소',
      to_call:fromTag,
      body:`✓ 거래 수락됨: [${offerStr}] → [${wantStr}] 교환 완료. 인벤토리를 확인하세요.`,
      type:'urgent',
      created_at:new Date().toISOString()
    });
    renderInv();
    playS('loot');
    showToast('✓ 거래 성사! 아이템 자동 이전됨');
    addMLog(`거래성사: ${currentUser.name} ↔ @${fromTag} | ${offerStr} ⇄ ${wantStr}`);
    loadTrades();
  }catch(e){showToast('수락 실패');}
}

async function cancelTrade(id){
  if(!currentUser)return;
  try{
    await sbReq('DELETE','trades?id=eq.'+id+'&from_tag=eq.'+encodeURIComponent(currentUser.tag));
    showToast('거래 취소됨');
    addMLog(`거래취소: ${currentUser.name}`);
    loadTrades();
  }catch(e){showToast('취소 실패');}
}

// ============================================================
// 강탈 시스템 — 주사위 결투
// ============================================================
let robPending={};

function attemptRob(tradeId, victimTag, offerStr){
  if(!currentUser){showToast('로그인 필요');return;}
  // 결투 오버레이 열기
  robPending={tradeId, victimTag, offerStr};
  $('rob-atk-val').textContent='?';
  $('rob-atk-val').className='rob-dice-val';
  $('rob-def-val').textContent='?';
  $('rob-def-val').className='rob-dice-val';
  $('rob-result').textContent='';
  $('rob-result').className='rob-result';
  $('rob-duel-sub').textContent=`[${offerStr}] 강탈 시도`;
  $('rob-attacker-label').textContent=currentUser.name;
  $('rob-defender-label').textContent='@'+victimTag;
  $('rob-roll-btn').style.display='block';
  $('rob-close-btn').style.display='none';
  $('rob-duel').classList.add('show');
  vibrateDevice();
}

function rollRobDice(){
  $('rob-roll-btn').disabled=true;
  const atkEl=$('rob-atk-val');
  const defEl=$('rob-def-val');
  atkEl.className='rob-dice-val rolling';
  defEl.className='rob-dice-val rolling';

  let ticks=0;
  const iv=setInterval(()=>{
    atkEl.textContent=Math.ceil(Math.random()*6);
    defEl.textContent=Math.ceil(Math.random()*6);
    ticks++;
    if(ticks>18){
      clearInterval(iv);
      const atk=Math.ceil(Math.random()*6);
      const def=Math.ceil(Math.random()*6);
      atkEl.textContent=atk;
      defEl.textContent=def;
      atkEl.className='rob-dice-val '+(atk>def?'win':'lose');
      defEl.className='rob-dice-val '+(def>=atk?'win':'lose');
      playS(atk>def?'loot':'alert');
      finishRob(atk, def);
    }
  }, 80);
}

async function finishRob(atk, def){
  const {tradeId, victimTag, offerStr}=robPending;
  const success = atk > def;
  const resultEl=$('rob-result');
  const offerParsed=parseItemName(offerStr);

  if(success){
    resultEl.textContent='강탈 성공!';
    resultEl.className='rob-result win';
    try{
      await sbReq('PATCH','trades?id=eq.'+tradeId,{status:'robbed',accepted_by:'UNKNOWN'});
      addToInv(offerParsed.name, offerParsed.icon, offerParsed.q);
      renderInv();
      await sbReq('POST','notes',{
        from_call:'⚠ 시스템',to_call:victimTag,
        body:`귀하의 거래품 [${offerStr}]이 정체불명의 누군가에게 강탈되었습니다.`,
        type:'urgent',created_at:new Date().toISOString()
      });
      addMLog(`[강탈성공] ${currentUser.name}(@${currentUser.tag}) → @${victimTag} [${offerStr}] (${atk}vs${def})`);
    }catch(e){}
  } else {
    resultEl.textContent='강탈 실패 — 격리 위험도 +1';
    resultEl.className='rob-result lose';
    try{
      const pr=await sbReq('GET','profiles?tag=eq.'+encodeURIComponent(currentUser.tag)+'&select=quarantine_count');
      if(pr&&pr[0]){
        const newCount=(pr[0].quarantine_count||0)+1;
        await sbReq('PATCH','profiles?tag=eq.'+encodeURIComponent(currentUser.tag),{quarantine_count:newCount});
        currentUser.quarantine_count=newCount;
        localStorage.setItem('vx24_user',JSON.stringify(currentUser));
        if(newCount>=3) resultEl.textContent='강탈 실패 — 격리 위험 3회 도달!';
      }
      addMLog(`[강탈실패] ${currentUser.name}(@${currentUser.tag}) → @${victimTag} (${atk}vs${def}) 위험도+1`);
    }catch(e){}
  }
  $('rob-roll-btn').style.display='none';
  $('rob-close-btn').style.display='block';
  loadTrades();
}

function closeRobDuel(){
  $('rob-duel').classList.remove('show');
  $('rob-roll-btn').disabled=false;
  robPending={};
}

// ============================================================
// 마스터 — 거래 전체 내역 조회
// ============================================================
async function masterLoadTrades(){
  const el=$('m-trade-log');
  if(!el)return;
  try{
    const data=await sbReq('GET','trades?order=created_at.desc&limit=100');
    if(!data||!data.length){el.innerHTML='<div style="color:var(--txf)">거래 내역 없음</div>';return;}
    el.innerHTML=data.map(t=>{
      const statusColor=t.status==='accepted'?'var(--grn)':t.status==='robbed'?'var(--org)':'var(--txd)';
      const statusLabel=t.status==='accepted'?'✓완료':t.status==='robbed'?'⚠강탈':'진행중';
      const robber=t.status==='robbed'&&t.accepted_by&&t.accepted_by!=='UNKNOWN'?` [범인:${t.accepted_by}]`:'';
      const accepter=t.status==='accepted'&&t.accepted_by?` → ${t.accepted_by}`:'';
      return`<div style="padding:5px 0;border-bottom:1px solid rgba(255,255,255,.04)">
        <div style="display:flex;justify-content:space-between;align-items:flex-start">
          <div>
            <span style="color:var(--tx);font-size:10px">${t.from_name}</span>
            <span style="color:var(--txf)"> ${t.offer} ⇄ ${t.want}</span>
          </div>
          <span style="color:${statusColor};flex-shrink:0;margin-left:8px">${statusLabel}</span>
        </div>
        <div style="color:var(--txf);font-size:8px;margin-top:2px">${formatTs(t.created_at||'')}${accepter}${robber}</div>
      </div>`;
    }).join('');
    addMLog('거래내역 조회');
  }catch(e){el.innerHTML='<div style="color:var(--acl)">조회 실패</div>';}
}

function formatTs(iso){
  const d=new Date(iso);
  return`${String(d.getMonth()+1).padStart(2,'0')}.${String(d.getDate()).padStart(2,'0')} ${String(d.getHours()).padStart(2,'0')}:${String(d.getMinutes()).padStart(2,'0')}`;
}

// ============================================================
// 감염 의심 신고 & 격리
// ============================================================
let reportSearchResults=[];

async function searchReportTarget(){
  const q=$('report-tag-in').value.trim();
  if(!q){$('report-search-result').innerHTML='';return;}
  try{
    const data=await sbReq('GET','profiles?or=(tag.ilike.*'+encodeURIComponent(q)+'*,name.ilike.*'+encodeURIComponent(q)+'*)&limit=5');
    reportSearchResults=data||[];
    renderReportSearch();
  }catch(e){}
}

function renderReportSearch(){
  const el=$('report-search-result');
  if(!reportSearchResults.length){el.innerHTML='<div style="font-family:var(--m);font-size:9px;color:var(--txf);padding:6px">검색 결과 없음</div>';return;}
  el.innerHTML=reportSearchResults.map(u=>{
    const isMe=currentUser&&u.tag===currentUser.tag;
    const alreadyReported=localStorage.getItem('vx24_rep_'+u.tag);
    return`<div class="report-user-card" style="margin-bottom:4px">
      <div>
        <div class="ru-name">${u.name} ${u.quarantine_count>=3?'<span style="color:var(--ac);font-size:9px">[격리중]</span>':''}</div>
        <div class="ru-tag">@${u.tag}</div>
        <div class="ru-meta">${u.school||''} ${u.zone||''}</div>
      </div>
      ${!isMe?`<button class="report-btn" onclick="submitReport('${u.tag}','${u.name}')" ${alreadyReported?'disabled':''}>
        ${alreadyReported?'신고완료':'⚠ 신고'}
      </button>`:'<span style="font-family:var(--m);font-size:9px;color:var(--txf);margin-left:auto">본인</span>'}
    </div>`;
  }).join('');
}

async function submitReport(tag,name){
  if(!currentUser){showToast('로그인 필요');return;}
  if(localStorage.getItem('vx24_rep_'+tag)){showToast('이미 신고한 유저입니다');return;}
  if(tag===currentUser.tag){showToast('본인 신고 불가');return;}
  try{
    // quarantine_count 증가
    const profileData=await sbReq('GET','profiles?tag=eq.'+encodeURIComponent(tag));
    if(!profileData||!profileData.length){showToast('유저를 찾을 수 없습니다');return;}
    const profile=profileData[0];
    const newCount=(profile.quarantine_count||0)+1;
    await sbReq('PATCH','profiles?tag=eq.'+encodeURIComponent(tag),{quarantine_count:newCount});
    localStorage.setItem('vx24_rep_'+tag,'1');
    playS('alert');
    if(newCount>=3){
      showToast('⚠ '+name+' 격리 처리됨!');
      triggerQuarantineAlert(name,tag);
      // 자동: 격리 쪽지 발송
      sbReq('POST','notes',{from_call:'🔴 통합사령부',to_call:tag,body:name+'님은 신고 3건 누적으로 즉시 격리 처리되었습니다. 격리 구역으로 이동하십시오.',type:'urgent',created_at:new Date().toISOString()}).catch(()=>{});
      addMLog('[자동] 격리 쪽지 → '+name+'(@'+tag+')');
    } else {
      showToast('신고 접수 ('+newCount+'/3)');
      // 자동: 경고 쪽지
      sbReq('POST','notes',{from_call:'⚠ 감염통제센터',to_call:tag,body:'[경고 '+newCount+'/3] 감염 의심 신고가 접수되었습니다. 3회 누적 시 자동 격리됩니다.',type:'urgent',created_at:new Date().toISOString()}).catch(()=>{});
      addMLog('[자동] 경고 쪽지 → '+name+' ('+newCount+'/3)');sendReportConfirmation(name,newCount);
    }
    searchReportTarget();
    loadQuarantineList();
  }catch(e){showToast('신고 실패 — profiles에 quarantine_count 컬럼 필요');}
}

function triggerQuarantineAlert(name,tag){
  // 격리 경고 오버레이
  const ov=document.createElement('div');
  ov.className='infected-overlay';
  document.body.appendChild(ov);
  setTimeout(()=>ov.remove(),4000);
  // 긴급 방송 트리거
  $('ea').textContent='⚠ 격리 명령 ⚠';
  $('em').textContent=name+'(@'+tag+') 격리 처리';
  $('es').textContent='감염 의심 신고 3건 누적\n즉시 격리 구역으로 이동하십시오';
  $('emg').classList.add('show');
}

async function loadQuarantineList(){
  const el=$('quarantine-list');
  if(!el)return;
  try{
    const data=await sbReq('GET','profiles?quarantine_count=gte.1&order=quarantine_count.desc&limit=20');
    if(!data||!data.length){el.innerHTML='<div style="font-family:var(--m);font-size:9px;color:var(--txf);padding:8px">신고 내역 없음</div>';return;}
    el.innerHTML=data.map(u=>{
      const cnt=u.quarantine_count||0;
      const isQuarantined=cnt>=3;
      const pips=[1,2,3].map(i=>`<div class="report-pip${i<=cnt?' filled':''}"></div>`).join('');
      return`<div class="quarantine-card">
        <div>
          <div class="qc-name">${u.name}</div>
          <div class="qc-tag">@${u.tag} · ${u.school||''} ${u.zone||''}</div>
          <div class="report-count-bar">${pips}</div>
        </div>
        <span class="quarantine-badge${isQuarantined?' danger':''}">
          ${isQuarantined?'🔴 격리중':'🟡 의심 '+cnt+'/3'}
        </span>
      </div>`;
    }).join('');
  }catch(e){el.innerHTML='<div style="color:var(--acl);font-family:var(--m);font-size:10px;padding:8px">불러오기 실패</div>';}
}

// 로그인 시 본인 격리 상태 체크
async function checkMyQuarantineStatus(){
  if(!currentUser)return;
  try{
    const data=await sbReq('GET','profiles?tag=eq.'+encodeURIComponent(currentUser.tag));
    if(data&&data.length&&(data[0].quarantine_count||0)>=3){
      // 격리된 유저 — 화면에 경고 표시
      const banner=document.createElement('div');
      banner.style.cssText='position:fixed;top:0;left:0;width:100%;background:var(--ac);color:#fff;text-align:center;padding:6px;font-family:var(--m);font-size:11px;z-index:9000;';
      banner.textContent='⚠ 당신은 격리 처리되었습니다. 즉시 격리 구역으로 이동하십시오.';
      document.body.prepend(banner);
    }
  }catch(e){}
}


