  const sorted=[...f.filter(p=>p.pin),...f.filter(p=>!p.pin)];
  const el=$('blist');
  el.innerHTML='';

  if(sorted.length===0){
    el.innerHTML='<div style="padding:20px;text-align:center;color:var(--txf);font-family:var(--m);font-size:11px">게시글 없음</div>';
    return;
  }

  sorted.forEach(p=>{
    const row=document.createElement('div');
    row.className='ptr'+(p.cen?' cen':'');
    if(!p.cen) row.onclick=()=>{if(p.locked){pendingLP=p;openMo('mo-boardpw')}else openDet(p.id)};
