})/);   return m?m[1]:null; }  async function masterSetYouTube(){   const url=$('m-yt-url').value.trim();   const freq=$('m-yt-freq').value.trim();   const vid=extractYtId(url);   if(!vid){showToast('유효한 유튜브 URL이 아닙니다');return;}   if(!freq||isNaN(parseFloat(freq))){showToast('주파수를 입력하세요');return;}   const f=parseFloat(freq).toFixed(1);   // Supabase에 저장 (기존 레코드 삭제 후 새로 삽입)   try{     await sbReq('DELETE','notes?from_call=eq.__SYSTEM_RADIO__');     await sbReq('POST','notes',{       from_call:'__SYSTEM_RADIO__',       to_call:'__ALL__',       body:JSON.stringify({videoId:vid,freq:f}),       type:'normal',       created_at:new Date().toISOString()     });     ytVideoId=vid; ytFreq=f;     const statusEl=$('m-yt-status');     if(statusEl) statusEl.textContent='✓ '+f+' MHz 설정 완료';     addMLog('유튜브 라디오 설정: '+f+'MHz');     showToast('📻 '+f+'MHz에 음악 숨김');   }catch(e){showToast('설정 실패: '+e);} }  async function masterClearYouTube(){   try{     await sbReq('DELETE','notes?from_call=eq.__SYSTEM_RADIO__');     ytVideoId=null; ytFreq=null;     const wrap=$('yt-player-wrap');     if(wrap) wrap.style.display='none';     const statusEl=$('m-yt-status');     if(statusEl) statusEl.textContent='제거됨';     addMLog('유튜브 라디오 제거');     showToast('라디오 음악 제거됨');   }catch(e){} }  // 모든 플레이어가 30초마다 라디오 설정 동기화 async function syncRadioFromServer(){   try{     const data=await sbReq('GET','notes?from_call=eq.__SYSTEM_RADIO__&select=body&limit=1');     if(data&&data[0]){       const parsed=JSON.parse(data[0].body);       ytVideoId=parsed.videoId||null;       ytFreq=parsed.freq||null;     } else {       ytVideoId=null; ytFreq=null;     }   }catch(e){} } // 페이지 로드 후 즉시 + 30초마다 동기화 syncRadioFromServer(); setInterval(syncRadioFromServer,30000);  function checkYtFreq(freq){   if(!ytFreq||!ytVideoId)return;   const wrap=$('yt-player-wrap');   const inner=$('yt-player-inner');   const label=$('yt-freq-label');   const link=$('yt-open-link');   const hit=Math.abs(parseFloat(freq)-parseFloat(ytFreq))<0.5;  