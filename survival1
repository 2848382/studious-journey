let customBC=[];
function updateRadialSlider(){
  const dial=$('radio-dial');
  if(!dial)return;
  const pct=((parseFloat(dial.value)-10)/(500-10)*100).toFixed(1)+'%';
  dial.style.setProperty('--pct',pct);
}
function syncFreqInput(){
  const v=parseFloat($('radio-dial').value).toFixed(1);
  $('radio-freq-display').textContent=v;
  updateRadialSlider();
  const inp=$('radio-freq-input');
  if(inp&&document.activeElement!==inp) inp.value=v;
  tuneRadio();
}
function syncFreqDial(){
  const inp=$('radio-freq-input');
  if(!inp)return;
  let v=parseFloat(inp.value);
  if(isNaN(v))return;
  v=Math.min(500,Math.max(10,v));
  $('radio-dial').value=v;
  $('radio-freq-display').textContent=v.toFixed(1);
  updateRadialSlider();
  tuneRadio();
}
function updateSignalBars(strength){
  // strength 0~5
  const bars=document.querySelectorAll('#radio-sig-bars span');
  bars.forEach((b,i)=>{b.classList.toggle('active',i<strength)});
}
function tuneRadio(){const freq=parseFloat($('radio-dial').value).toFixed(1);$('radio-freq-display').textContent=freq;
  // 신호 강도: 채널 근처면 강하게
  let sigStrength=Math.floor(Math.random()*2)+1;
  const RCHkeys=Object.keys(RCH||{});
  for(const k of RCHkeys){if(Math.abs(parseFloat(k)-parseFloat(freq))<2)sigStrength=4;}
  if(ytFreq&&Math.abs(parseFloat(ytFreq)-parseFloat(freq))<2)sigStrength=5;
  updateSignalBars(sigStrength);
  playS('noise');checkYtFreq(freq);const custom=customBC.find(b=>Math.abs(parseFloat(b.freq)-parseFloat(freq))<0.5);if(custom){addRadioMsg(custom.freq+' MHz',custom.msg,'var(--ylw)');return}let found=null;for(const[f,ch]of Object.entries(RCH)){if(Math.abs(parseFloat(f)-parseFloat(freq))<0.5){found={freq:f,...ch};break}}if(found){if(found.type==='blocked')addRadioMsg(found.freq+' — '+found.name,found.msg,'var(--acl)');else if(found.type==='secret'){addRadioMsg(found.freq+' — '+found.name,found.msg,'var(--pur)');if(!$('pg-hidden').dataset.hinted){$('pg-hidden').dataset.hinted='1';setTimeout(()=>showToast('LAZARUS를 암호 해독기에 입력하라'),2000)}}else addRadioMsg(found.freq+' — '+found.name,found.msg,'#00ff41')}}
function addRadioMsg(ch,msg,color){const chat=$('radio-chat');const now=new Date();const t=`${String(now.getHours()).padStart(2,'0')}:${String(now.getMinutes()).padStart(2,'0')}`;const div=document.createElement('div');div.className='radio-msg';div.innerHTML=`<span class="radio-msg-time">[${t}]</span> <span style="color:${color}">${ch}</span><br><span style="color:${color}">${msg.replace(/\n/g,'<br>')}</span>`;chat.appendChild(div);chat.scrollTop=chat.scrollHeight}
function scanRadio(){let f=10;const dial=$('radio-dial');const iv=setInterval(()=>{f+=3;if(f>500){clearInterval(iv);return}dial.value=f;$('radio-freq-display').textContent=parseFloat(f).toFixed(1);const has=Object.keys(RCH).some(k=>Math.abs(parseFloat(k)-parseFloat(f))<0.5);if(has){clearInterval(iv);tuneRadio();playS('loot')}},60)}
function resetRadio(){$('radio-dial').value=91;$('radio-chat').innerHTML='<div style="color:rgba(0,255,65,.3)">주파수를 조정하세요...</div>'}
function decodeCipher(){const input=$('cipher-in').value.trim();if(!input){$('cipher-out').textContent='';return}if(input.toUpperCase()==='LAZARUS'){$('cipher-out').innerHTML='<span style="color:var(--pur)">⚠ LAZARUS 접근 확인</span>';$('pg-hidden').style.display='block';if(!document.querySelector('#hidden-tab')){const tab=document.createElement('div');tab.className='tab';tab.id='hidden-tab';tab.style.color='var(--pur)';tab.textContent='🔮';tab.onclick=function(){go('hidden');this.classList.add('on')};$('master-tab').before(tab)}playS('alert');showToast('⚠ 기밀 접근');return}let r='';for(let s=1;s<=25;s++){let d='';for(const c of input){const code=c.charCodeAt(0);if(code>=65&&code<=90)d+=String.fromCharCode((code-65+s)%26+65);else if(code>=97&&code<=122)d+=String.fromCharCode((code-97+s)%26+97);else d+=c}r+=`[+${s}] ${d}\n`}$('cipher-out').textContent=r}

