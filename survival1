      // 하트비트
      realtimeHB=setInterval(()=>{
        if(realtimeWS&&realtimeWS.readyState===1)
          realtimeWS.send(JSON.stringify({topic:'phoenix',event:'heartbeat',payload:{},ref:null}));
      },30000);
      // notes 테이블 구독
      realtimeWS.send(JSON.stringify({
        topic:'realtime:public:notes',
        event:'phx_join',
        payload:{config:{broadcast:{self:true},presence:{key:''},postgres_changes:[{event:'INSERT',schema:'public',table:'notes'}]}},
        ref:'1'
      }));
      // posts 폴링은 별도로
      
    };
    realtimeWS.onmessage=e=>{
      try{
        const msg=JSON.parse(e.data);
        if(msg.event==='postgres_changes'||msg.event==='INSERT'){
          const rec=msg.payload&&(msg.payload.record||msg.payload.new);
          if(rec&&msg.topic&&msg.topic.includes('notes')){
            handleRealtimeNote(rec);
          }
        }
      }catch(ex){}
    };
    realtimeWS.onclose=()=>{
      clearInterval(realtimeHB);
      // 재연결
      setTimeout(connectRealtime,5000);
    };
    realtimeWS.onerror=()=>{};
  }catch(ex){}
}

