<!-- LOGIN -->
<div id="login-screen"><div class="login-box">
<div style="font-family:var(--o);font-size:15px;color:var(--w);text-align:center;margin-bottom:4px">생존자 등록</div>
<div style="font-size:10px;color:var(--txf);text-align:center;margin-bottom:14px">통행증 발급</div>
<div style="display:flex;margin-bottom:12px;border-bottom:1px solid var(--bd)"><div class="tab on" onclick="loginMode('register',this)">신규 등록</div><div class="tab" onclick="loginMode('login',this)">로그인</div></div>
<div id="login-form">
<div class="fg"><label class="fl">이름 (실명)</label><input class="fi" id="reg-name" placeholder="이름" maxlength="10"></div>
<div class="fg"><label class="fl">@태그 (고유 ID, 영문+숫자)</label><input class="fi" id="reg-tag" placeholder="hong123" maxlength="16" oninput="this.value=this.value.replace(/[^a-zA-Z0-9_]/g,'')"></div>
