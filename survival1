async function loadNotes(){
  if(!currentUser)return;
  try{
    // 내가 받은 쪽지 + 내가 보낸 쪽지만 로드
    const myTag=currentUser.tag;
    const myName=currentUser.name;
    const data=await sbReq('GET',
      'notes?or=(to_call.eq.'+encodeURIComponent(myTag)+',to_call.eq.'+encodeURIComponent(myName)+',from_call.ilike.*'+encodeURIComponent('(@'+myTag+')')+')&order=created_at.desc&limit=50'
    );
    const prevCount=notes.length;
    notes=data||[];
    // 새 쪽지 도착 시 진동+소리 + 거래 자동 인벤 처리
    if(notes.length>prevCount&&prevCount>0){
      vibrateDevice();
      playDisasterSound();
      const shell=$('iphone-shell');
      if(shell){shell.classList.add('vibrating');setTimeout(()=>shell.classList.remove('vibrating'),500);}
      // 거래소 알림 → 등록자 인벤토리 자동 처리
      const newNotes=notes.slice(0,notes.length-prevCount);
      for(const n of newNotes){
        if(n.from_call==='거래소'&&n.body&&n.body.includes('거래 수락됨')){
          // "✓ 거래 수락됨: [offer] → [want]" 파싱
          const m=n.body.match(/\[(.+?)\] → \[(.+?)\]/);
          if(m){
            // 등록자: offer(내가 줄 것) 차감, want(받을 것) 추가
            const offerP=parseItemName(m[1]);
            const wantP=parseItemName(m[2]);
            removeFromInv(offerP.name,offerP.q);
            addToInv(wantP.name,wantP.icon,wantP.q);
            renderInv();
          }
        }
      }
    }
    loadNotesForPhone();
    updatePhoneBadge();
  }catch(e){}
}

function loadNotesForPhone(){
  const el=$('home-msgs-list');
  if(!el||!notes.length){
    if(el)el.innerHTML='<div style="text-align:center;color:rgba(255,255,255,.2);font-size:10px;padding:20px;font-family:var(--m)">쪽지 없음</div>';
    return;
  }
  const myTag=currentUser?currentUser.tag:'';
  el.innerHTML=notes.map(n=>{
    const isForMe=n.to_call===myTag||n.to_call===currentUser.name||n.to_call==='전체';
    const badgeHtml=n.type==='secret'?'<span class="home-msg-badge badge-secret">비밀</span>':n.type==='urgent'?'<span class="home-msg-badge badge-urgent">긴급</span>':'';
    const bodyHtml=n.type==='secret'&&isForMe?`<div class="home-msg-secret" onclick="this.classList.remove('home-msg-secret');localStorage.setItem('vx24_rv_${n.id}','1')">${n.body}</div>`:`<div>${n.body}</div>`;
    const seen=localStorage.getItem('vx24_rv_'+n.id)||!isForMe;
    if(isForMe)localStorage.setItem('vx24_rv_'+n.id,'1');
    const dt=new Date(n.created_at);
    const ts=`${String(dt.getMonth()+1).padStart(2,'0')}.${String(dt.getDate()).padStart(2,'0')} ${String(dt.getHours()).padStart(2,'0')}:${String(dt.getMinutes()).padStart(2,'0')}`;
    return`<div class="home-msg-item${isForMe&&!seen?' unread':''}"><div class="home-msg-from"><span>${n.from_call}${badgeHtml}</span><span>${ts}</span></div><div style="font-size:9px;color:rgba(255,255,255,.25);font-family:var(--m)">→ @${n.to_call}</div>${bodyHtml}</div>`;
  }).join('');
}

