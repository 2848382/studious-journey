let infCells=[];
function initInfSim(){const v=$('inf-viz');v.innerHTML='';infCells=[];for(let i=0;i<50;i++){const c=document.createElement('div');c.className='inf-cell healthy';c.style.left=Math.random()*93+'%';c.style.top=Math.random()*88+'%';v.appendChild(c);infCells.push({el:c,state:'healthy',x:parseFloat(c.style.left),y:parseFloat(c.style.top)})}}initInfSim();
function startInfSim(){initInfSim();infCells[Math.floor(Math.random()*infCells.length)].state='infected';let step=0;const iv=setInterval(()=>{step++;infCells.forEach(c=>{if(c.state==='healthy'){if(infCells.some(o=>o.state==='infected'&&Math.abs(o.x-c.x)<12&&Math.abs(o.y-c.y)<12)&&Math.random()<.3)c.state='infected'}else if(c.state==='infected'&&step>5){if(Math.random()<.05)c.state='mutant';else if(Math.random()<.03)c.state='dead'}});infCells.forEach(c=>{c.el.className='inf-cell '+c.state;if(c.state!=='dead'){c.x+=Math.random()*2-1;c.y+=Math.random()*2-1;c.x=Math.max(0,Math.min(93,c.x));c.y=Math.max(0,Math.min(88,c.y));c.el.style.left=c.x+'%';c.el.style.top=c.y+'%'}});if(step>45||!infCells.some(c=>c.state==='healthy'))clearInterval(iv)},500)}
function resetInfSim(){initInfSim()}

