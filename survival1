function markQuestAct(key){
  // 실제 행동 발생 시 호출 → 퀘스트 해금
  localStorage.setItem('vx24_act_'+key, getTodayStr());
  renderQuests();
}

function isQuestUnlocked(key){
  return localStorage.getItem('vx24_act_'+key) === getTodayStr();
}

function initQ(){
  const today=getTodayStr();
  let s;
  try{s=JSON.parse(localStorage.getItem('vx24_qs'));if(localStorage.getItem('vx24_qd')!==today)s=null}
  catch(e){s=null}
  if(!s){
    s=[...QP].sort(()=>Math.random()-.5).slice(0,3).map(q=>({...q,done:false}));
    localStorage.setItem('vx24_qs',JSON.stringify(s));
    localStorage.setItem('vx24_qd',today);
  }
  return s;
}

function renderQuests(){
  const qs=initQ(),el=$('quest-list');
  el.innerHTML='';
  qs.forEach((q,i)=>{
    const unlocked=isQuestUnlocked(q.key);
    const d=document.createElement('div');
    d.className='quest'+(q.done?' done':'')+(unlocked&&!q.done?' unlocked':'');
    const chkHtml=q.done
      ?`<div class="quest-chk checked">✓</div>`
      :unlocked
        ?`<div class="quest-chk" onclick="complQ(${i})" style="cursor:pointer;border-color:var(--grn)">□</div>`
        :`<div class="quest-chk locked" title="${q.hint||''}">🔒</div>`;
    d.innerHTML=`${chkHtml}<div class="quest-txt" style="${!unlocked&&!q.done?'color:var(--txf)':''}">${q.t}</div><div class="quest-rw" style="${!unlocked&&!q.done?'opacity:.4':''}">${q.ri} ${q.rw}</div>`;
    el.appendChild(d);
  });
}

function complQ(i){
  const qs=initQ();
  if(qs[i].done)return;
  if(!isQuestUnlocked(qs[i].key)){showToast('🔒 '+qs[i].hint);return;}
  qs[i].done=true;
  localStorage.setItem('vx24_qs',JSON.stringify(qs));
  addToInv(qs[i].rw,qs[i].ri,1);
  renderQuests();renderInv();
  playS('loot');
  showToast(qs[i].ri+' '+qs[i].rw+' 수령!');
}

