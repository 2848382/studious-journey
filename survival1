let sndOn=false,actx=null;
function toggleSnd(){sndOn=!sndOn;$('snd-btn').textContent=sndOn?'♫':'♪';$('snd-btn').style.color=sndOn?'var(--grn)':'';if(sndOn&&!actx)actx=new(window.AudioContext||window.webkitAudioContext)()}
function playS(t){
  if(!sndOn||!actx)return;
  const o=actx.createOscillator(),g=actx.createGain();
  o.connect(g);g.connect(actx.destination);
  if(t==='click'){o.frequency.value=800;g.gain.value=.03;o.start();o.stop(actx.currentTime+.05)}
  else if(t==='roll'){o.frequency.value=200;o.type='triangle';g.gain.setValueAtTime(.08,actx.currentTime);g.gain.exponentialRampToValueAtTime(.001,actx.currentTime+.3);o.start();o.stop(actx.currentTime+.3)}
  else if(t==='alert'){o.frequency.value=440;o.type='square';g.gain.setValueAtTime(.05,actx.currentTime);g.gain.exponentialRampToValueAtTime(.001,actx.currentTime+.5);o.start();o.stop(actx.currentTime+.5)}
  else if(t==='boot'){o.frequency.value=600;g.gain.value=.04;o.start();o.stop(actx.currentTime+.15)}
  else if(t==='loot'){o.frequency.setValueAtTime(400,actx.currentTime);o.frequency.linearRampToValueAtTime(800,actx.currentTime+.2);g.gain.setValueAtTime(.06,actx.currentTime);g.gain.exponentialRampToValueAtTime(.001,actx.currentTime+.3);o.start();o.stop(actx.currentTime+.3)}
  else if(t==='noise'){const buf=actx.createBuffer(1,actx.sampleRate*.2,actx.sampleRate);const d=buf.getChannelData(0);for(let i=0;i<d.length;i++)d[i]=(Math.random()*2-1)*.12;const src=actx.createBufferSource();src.buffer=buf;const gn=actx.createGain();gn.gain.value=.08;src.connect(gn);gn.connect(actx.destination);src.start();src.stop(actx.currentTime+.2)}
  else if(t==='vibrate'){// 진동 소리 시뮬레이션
    o.type='sine';o.frequency.setValueAtTime(60,actx.currentTime);o.frequency.setValueAtTime(80,actx.currentTime+.05);o.frequency.setValueAtTime(60,actx.currentTime+.1);g.gain.setValueAtTime(.15,actx.currentTime);g.gain.exponentialRampToValueAtTime(.001,actx.currentTime+.3);o.start();o.stop(actx.currentTime+.3);
  }
}

