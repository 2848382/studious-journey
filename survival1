function updatePhoneBadge(){
  if(!currentUser)return;
  const myTag=currentUser.tag;
  const unread=notes.filter(n=>(n.to_call===myTag||n.to_call===currentUser.name||n.to_call==='전체')&&!localStorage.getItem('vx24_rv_'+n.id)).length;
