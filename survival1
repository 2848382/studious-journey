function sbReq(method,path,body){
  return new Promise(function(ok,fail){
    var x=new XMLHttpRequest();
    x.open(method,SB_URL+'/rest/v1/'+path,true);
    x.setRequestHeader('apikey',SB_KEY);
    x.setRequestHeader('Authorization','Bearer '+SB_KEY);
    x.setRequestHeader('Content-Type','application/json');
    if(method==='POST')x.setRequestHeader('Prefer','return=representation');
    x.onreadystatechange=function(){
      if(x.readyState!==4)return;
      if(x.status>=200&&x.status<300){try{ok(x.responseText?JSON.parse(x.responseText):null)}catch(e){ok(null)}}
      else{try{fail(JSON.parse(x.responseText))}catch(e){fail({message:x.responseText||'HTTP '+x.status})}}
    };
    x.onerror=function(){fail({message:'네트워크 오류'})};
    x.send(body?JSON.stringify(body):null);
  });
}

