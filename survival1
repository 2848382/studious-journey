des['${z.id}']=this.value.toUpperCase();addMLog('${z.name} 코드 변경')"></div>`).join('')} function masterRandomizeCodes(){const ch='ABCDEFGHJKLMNPQRSTUVWXYZ23456789';ZD.forEach(z=>{let c='';for(let i=0;i<6;i++)c+=ch[Math.floor(Math.random()*ch.length)];zoneCodes[z.id]=c});renderMPassCodes();addMLog('코드 랜덤');showToast('코드 변경')} function masterAddMission(){const t=$('m-mis-title').value.trim(),d=$('m-mis-desc').value.trim(),r=$('m-mis-reward').value.trim()||'없음',c=$('m-mis-code').value.trim().toUpperCase();if(!t||!d)return;const id=missions.length?Math.max(...missions.map(m=>m.id))+1:1;missions.push({id,title:t,desc:d,reward:r,code:c,status:missions.every(m=>m.status==='done')?'active':'locked'});$('m-mis-title').value='';$('m-mis-desc').value='';$('m-mis-reward').value='';$('m-mis-code').value='';addMLog('미션: '+t);renderMMissionList();renderMissions()} function renderMMissionList(){const el=$('m-mission-list');if(!el)return;el.innerHTML=missions.map(m=>`<div style="display:flex;justify-content:space-between;padding:2px 0;font-size:10px;border-bottom:1px solid rgba(255,255,255,.03)"><span style="color:${m.status==='done'?'var(--grn)':m.status==='active'?'var(--ylw)':'var(--txf)'}">${m.title}</span><div><button class="m-btn" style="padding:1px 5px;font-size:8px" onclick="missions.find(x=>x.id===${m.id}).status='active';renderMMissionList();renderMissions()">해제</button><button class="m-btn danger" style="padding:1px 5px;font-size:8px;margin-left:2px" onclick="missions=missions.filter(x=>x.id!==${m.id});renderMMissionList();renderMissions()">삭제</button></div></div>`).join('')} function masterAddTimer(){const name=$('m-timer-name').value.trim(),min=parseInt($('m-timer-min').value),desc=$('m-timer-desc').value.trim()||'';if(!name||!min)return;activeTimers.push({name,desc,endTime:Date.now()+min*60000,totalMs:min*60000,fired:false});addMLog('타이머: '+name);$('m-timer-name').value='';$('m-timer-min').value='';$('m-timer-desc').value='';$('ea').textContent='⚠ 타이머 ⚠';$('em').textContent=name;$('es').textContent=min+'분';$('emg').classList.add('show');playS('alert')} function masterClearTimers(){activeTimers=[];addMLog('타이머 제거');renderTimers()} function masterRadio(){const f=$('m-radio-freq').value.trim(),m=$('m-radio-msg').value.trim();if(!f||!m)return;customBC.push({freq:f,msg:m});addMLog('라디오: '+f+'MHz');showToast('📻 '+f);$('m-radio-freq').value='';$('m-radio-msg').value=''} function renderBanList(){$('m-ban-list').innerHTML=BAN.map((w,i)=>`<span style="font-family:var(--m);font-size:9px;padding:2px 5px;background:var(--bgi);border:1px solid var(--bd);color:var(--txd);cursor:pointer" onclick="BAN.splice(${i},1);renderBanList()">${w} ✕</span>`).join('')} function masterAddBan(){const w=$('m-ban-word').value.trim().toLowerCase();if(!w||BAN.includes(w))return;BAN.push(w);$('m-ban-word').value='';renderBanList();addMLog('금지어: '+w)} async function masterLoadCapsules(){try{const data=await sbReq('GET','capsules?select=*&order=created_at.desc&limit=50');$('m-capsule-list').innerHTML=(data||[]).map(c=>`<div style="padding:4px 0;border-bottom:1px solid rgba(255,255,255,.03);font-size:10px"><span style="color:var(--ylw)">${c.author_name}(@${c.author_tag})</span><div style="color:var(--tx);margin-top:2px">${c.message}</div><div style="color:var(--txf);font-family:var(--m);font-size:8px">pw: ${c.pw}</div></div>`).join('')||'없음'}catch(e){$('m-capsule-list').innerHTML='실패'}}    // ============================================================ // 배터리 + 신호 강도 // ============================================================ function updateBatteryUI(pct, charging, online){   const pctEl=$('lock-battery-pct');   const fillEl=$('lock-battery-fill');   const chargeEl=$('lock-charge-icon');   const sigEl=$('lock-signal');   if(pctEl){     pctEl.textContent=(pct!==null?Math.round(pct)+'%':'--');     if(fillEl){       fillEl.style.width=(pct!==null?pct:'100')+'%';       fillEl.style.background=pct<20?'#ef4444':pct<50?'#eab308':'#4ade80';     }     if(chargeEl) chargeEl.style.display=charging?'inline':'none';   }   if(sigEl){     if(!online) sigEl.innerHTML='✕ NO SIGNAL';     else sigEl.innerHTML='▂▄▆ LTE';   } }  async function initBattery(){   const online=navigator.onLine;   if(navigator.getBattery){     try{       const bat=await navigator.getBattery();       const update=()=>updateBatteryUI(bat.level*100, bat.charging, navigator.onLine);       update();       bat.addEventListener('levelchange',update);       bat.addEventListener('chargingchange',update);     }catch(e){updateBatteryUI(null,false,online);}   } else {     updateBatteryUI(null,false,online);   }   window.addEventListener('online',()=>updateBatteryUI(null,false,true));   window.addEventListener('offline',()=>updateBatteryUI(null,false,false)); } // initBattery는 DOM 준비 후 실행 if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',initBattery);}else{initBattery();}  // ============================================================ // 폰 탭 전환 // ============================================================ 
