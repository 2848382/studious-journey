  if(!tag||!pw){$('login-err').textContent='입력하세요';return}
  try{
    const r=await sbReq('GET','profiles?tag=eq.'+encodeURIComponent(tag)+'&pw=eq.'+encodeURIComponent(pw)+'&select=*');
    if(!r||r.length===0){$('login-err').textContent='태그/비밀번호 오류';return}
    currentUser=r[0];
    localStorage.setItem('vx24_user',JSON.stringify(currentUser));
    $('login-screen').classList.remove('show');
    afterLogin();playS('boot');
  }catch(e){$('login-err').textContent='오류: '+(e.message||'')}
}

