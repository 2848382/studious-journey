function handleTagInput(input,acId){
  const val=typeof input==='string'?$(input):input;
  const text=val.value;
  const cursorPos=val.selectionStart;
  const textBefore=text.substring(0,cursorPos);
  const atMatch=textBefore.match(/@([a-zA-Z0-9_]*)$/);
  const ac=$(acId);
  if(!ac)return;
  if(atMatch&&registeredUsers.length>0){
    const query=atMatch[1].toLowerCase();
    const matches=registeredUsers.filter(u=>
      u.tag.toLowerCase().includes(query)||u.name.toLowerCase().includes(query)
    ).slice(0,6);
    if(matches.length>0){
      ac.innerHTML=matches.map(u=>
        `<div class="tag-ac-item" onmousedown="insertTag(event,'${u.tag}','${acId}')">
          <span class="tag-ac-tag">@${u.tag}</span>
          <span class="tag-ac-name">${u.name}</span>
        </div>`
      ).join('');
