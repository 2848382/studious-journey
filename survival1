const PERISHABLE=['생수','즉석밥','건빵','라면','빵','음식','식수','라면'];

function getInv(){try{return JSON.parse(localStorage.getItem('vx24_inv'))||[]}catch(e){return[]}}

function addToInv(n,i,q){
  const inv=getInv();
  const today=getTodayStr();
  const ex=inv.find(x=>x.n===n);
  const isFood=PERISHABLE.includes(n);
  if(ex){ex.q+=q;}
  else{
    const item={n,i,q};
    if(isFood) item.exp=today; // 수령일 = 유통기한
    inv.push(item);
  }
  localStorage.setItem('vx24_inv',JSON.stringify(inv));
}

function expirePerishables(){
  try{
    const inv=getInv();
    const today=getTodayStr();
    let expired=[];
    const filtered=inv.filter(it=>{
      if(it.exp && it.exp!==today){expired.push(it.n);return false;}
      return true;
    });
    if(expired.length){
      localStorage.setItem('vx24_inv',JSON.stringify(filtered));
      showToast('🗑 유통기한 만료: '+expired.join(', ')+' 폐기됨');
    }
  }catch(e){}
}

function renderInv(){
  expirePerishables();
  const inv=getInv();
  const today=getTodayStr();
  const g=$('inv-grid');
  g.innerHTML='';
  inv.forEach(it=>{
