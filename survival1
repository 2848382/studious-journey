      ?'<span class="pb pbg">삭제</span>'
      :`<span class="pb ${CB[p.cat]||'pbg'}">${CL[p.cat]||p.cat}</span>`;
    const cmts=Array.isArray(p.cmts)?p.cmts:[];
    const cmtBadge=cmts.length?`<span class="ptr-cmt">💬${cmts.length}</span>`:'';
    const pin=p.pin?'<span class="ppin">[고정]</span>':'';
    row.innerHTML=
      `<span class="ptr-num">${p.pin?'📌':(typeof p.id==='number'?p.id:'—')}</span>`+
      `<span class="ptr-cat">${badge}</span>`+
      `<span class="ptr-title">${pin}<span class="ptt${p.pin?' pin':''}">${renderTagsInText(p.title||'')}</span>${cmtBadge}</span>`+
      `<span class="ptr-auth${p.adm?' adm':''}">${p.auth||''}</span>`;
    el.appendChild(row);
  });
}

